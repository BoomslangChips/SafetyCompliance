@inherits LayoutComponentBase
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IServiceProvider ServiceProvider
@implements IDisposable

<div class="app-layout @(_sidebarCollapsed ? "sidebar-collapsed" : "")">
    @if (_sidebarOpen)
    {
        <div class="sidebar-backdrop" @onclick="CloseSidebar"></div>
    }
    <aside class="sidebar @(_sidebarOpen ? "sidebar-open" : "")">
        <div class="sidebar-brand">
            <div class="brand-logo"><i class="fa-sharp fa-light fa-shield-keyhole"></i></div>
            <div class="brand-names">
                <span class="brand-name-main">MIS</span>
                <span class="brand-name-sub">Majesty Oil Mills</span>
            </div>
        </div>
        <NavMenu />
        <button class="sidebar-collapse-btn" @onclick="ToggleCollapsed" title="@(_sidebarCollapsed ? "Expand sidebar" : "Collapse sidebar")">
            <i class="fa-sharp fa-light @(_sidebarCollapsed ? "fa-angles-right" : "fa-angles-left")"></i>
        </button>
    </aside>
    <main class="main-content">
        <header class="top-bar">
            <button class="sidebar-toggle-btn" @onclick="ToggleSidebar" title="Open menu">
                <i class="fa-sharp fa-light fa-bars"></i>
            </button>

            @if (_syncService is not null)
            {
                @* Native sync status (MAUI) *@
                @if (!_isOnline)
                {
                    <div class="net-status offline" title="No connection to server">
                        <i class="fa-sharp fa-light fa-wifi-slash"></i>
                        <span>Offline</span>
                    </div>
                }
                else if (_isSyncing)
                {
                    <div class="net-status syncing">
                        <i class="fa-sharp fa-light fa-arrows-rotate fa-spin"></i>
                        <span>Syncing…</span>
                    </div>
                }
                else if (_isOnline && _pendingSyncCount == 0)
                {
                    <div class="net-status online" title="@(_lastSyncText)">
                        <i class="fa-sharp fa-light fa-cloud-check"></i>
                        <span>Synced</span>
                    </div>
                }

                @if (_pendingSyncCount > 0)
                {
                    <div class="net-status pending" @onclick="TrySyncNow" title="Click to sync now">
                        <i class="fa-sharp fa-light fa-cloud-arrow-up"></i>
                        <span>@_pendingSyncCount pending</span>
                    </div>
                }
            }
            else
            {
                @* Web fallback — JS-based network status *@
                @if (!_isOnline)
                {
                    <div class="net-status offline">
                        <i class="fa-sharp fa-light fa-wifi-slash"></i>
                        <span>Offline</span>
                    </div>
                }
            }

            <div style="flex:1;"></div>

            <button class="theme-toggle-btn" @onclick="ToggleTheme" title="Toggle dark/light mode">
                <i class="fa-sharp fa-light @_themeIconClass"></i>
            </button>
            <AuthorizeView>
                <Authorized>
                    <span class="user-greeting">@context.User.Identity?.Name</span>
                </Authorized>
            </AuthorizeView>
        </header>
        <div class="page-content">
            @Body
        </div>
    </main>
</div>

@code {
    private SafetyCompliance.Application.Interfaces.ISyncService? _syncService;

    private string _themeIconClass = "fa-sun-bright";
    private bool _sidebarOpen;
    private bool _sidebarCollapsed;
    private bool _isOnline = true;
    private int _pendingSyncCount;
    private bool _isSyncing;
    private string _lastSyncText = "";
    private DotNetObjectReference<MainLayout>? _dotNetRef;

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;

        // Resolve ISyncService optionally — only registered in MAUI, not in web
        _syncService = ServiceProvider.GetService(typeof(SafetyCompliance.Application.Interfaces.ISyncService))
            as SafetyCompliance.Application.Interfaces.ISyncService;

        if (_syncService is not null)
        {
            _syncService.OnSyncStateChanged += OnSyncStateChanged;
            UpdateSyncState();
            _syncService.StartAutoSync();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = await JS.InvokeAsync<string>("getTheme");
            _themeIconClass = theme == "dark" ? "fa-moon" : "fa-sun-bright";

            _sidebarCollapsed = await JS.InvokeAsync<bool>("getSidebarCollapsed");

            // JS-based network status (web + mobile)
            try
            {
                _isOnline = await JS.InvokeAsync<bool>("getNetworkStatus");
                _dotNetRef = DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync("registerNetworkCallbacks", _dotNetRef);
            }
            catch { /* JS not available yet */ }

            StateHasChanged();
        }
    }

    private void OnSyncStateChanged()
    {
        InvokeAsync(() =>
        {
            UpdateSyncState();
            StateHasChanged();
        });
    }

    private void UpdateSyncState()
    {
        if (_syncService is null) return;
        _isOnline = _syncService.IsOnline;
        _isSyncing = _syncService.IsSyncing;
        _pendingSyncCount = _syncService.PendingChangeCount;

        if (_syncService.LastSyncTime.HasValue)
        {
            var ago = DateTime.Now - _syncService.LastSyncTime.Value;
            _lastSyncText = ago.TotalMinutes < 1 ? "Just synced"
                : ago.TotalMinutes < 60 ? $"Synced {(int)ago.TotalMinutes}m ago"
                : $"Synced {(int)ago.TotalHours}h ago";
        }
        else
        {
            _lastSyncText = "Not yet synced";
        }
    }

    [JSInvokable]
    public async Task OnNetworkStatusChanged(bool isOnline)
    {
        _isOnline = isOnline;
        if (isOnline && _syncService is not null)
        {
            // Auto-sync when coming back online
            await TrySyncNow();
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task TrySyncNow()
    {
        if (_syncService is not null)
        {
            await _syncService.SyncAsync();
            return;
        }

        // Web fallback
        if (_isSyncing) return;
        _isSyncing = true;
        StateHasChanged();
        try
        {
            _pendingSyncCount = await JS.InvokeAsync<int>("offlineQueueCount");
        }
        catch { }
        finally
        {
            _isSyncing = false;
            StateHasChanged();
        }
    }

    private async Task ToggleTheme()
    {
        var newTheme = await JS.InvokeAsync<string>("toggleTheme");
        _themeIconClass = newTheme == "dark" ? "fa-moon" : "fa-sun-bright";
    }

    private void ToggleSidebar()
    {
        _sidebarOpen = !_sidebarOpen;
    }

    private void CloseSidebar()
    {
        _sidebarOpen = false;
    }

    private async Task ToggleCollapsed()
    {
        _sidebarCollapsed = !_sidebarCollapsed;
        await JS.InvokeVoidAsync("setSidebarCollapsed", _sidebarCollapsed);
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (_sidebarOpen)
        {
            _sidebarOpen = false;
            InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        if (_syncService is not null)
            _syncService.OnSyncStateChanged -= OnSyncStateChanged;
        _dotNetRef?.Dispose();
    }
}
