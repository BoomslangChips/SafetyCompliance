@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="app-layout">
    <aside class="sidebar">
        <div class="sidebar-brand">
            <i class="fa-light fa-shield-check brand-icon"></i>
            <span class="brand-text">SafeCheck</span>
        </div>
        <NavMenu />
    </aside>
    <main class="main-content">
        <header class="top-bar">
            <button class="theme-toggle-btn" @onclick="ToggleTheme" title="Toggle dark/light mode">
                <i class="fa-light @_themeIconClass"></i>
            </button>
            <AuthorizeView>
                <Authorized>
                    <span class="user-greeting">@context.User.Identity?.Name</span>
                </Authorized>
            </AuthorizeView>
        </header>
        <div class="page-content">
            @Body
        </div>
    </main>
</div>

@code {
    private string _themeIconClass = "fa-sun-bright";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = await JS.InvokeAsync<string>("getTheme");
            _themeIconClass = theme == "dark" ? "fa-moon" : "fa-sun-bright";
            StateHasChanged();
        }
    }

    private async Task ToggleTheme()
    {
        var newTheme = await JS.InvokeAsync<string>("toggleTheme");
        _themeIconClass = newTheme == "dark" ? "fa-moon" : "fa-sun-bright";
    }
}
