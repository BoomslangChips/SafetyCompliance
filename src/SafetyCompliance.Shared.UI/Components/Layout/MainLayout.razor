@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="app-layout">
    <aside class="sidebar">
        <div class="sidebar-brand">
            <span class="brand-icon">&#9888;</span>
            <span class="brand-text">SafeCheck</span>
        </div>
        <NavMenu />
    </aside>
    <main class="main-content">
        <header class="top-bar">
            <button class="theme-toggle-btn" @onclick="ToggleTheme" title="Toggle dark/light mode">
                @_themeIcon
            </button>
            <AuthorizeView>
                <Authorized>
                    <span class="user-greeting">@context.User.Identity?.Name</span>
                </Authorized>
            </AuthorizeView>
        </header>
        <div class="page-content">
            @Body
        </div>
    </main>
</div>

@code {
    private string _themeIcon = "\u2600\ufe0f";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = await JS.InvokeAsync<string>("getTheme");
            _themeIcon = theme == "dark" ? "\ud83c\udf19" : "\u2600\ufe0f";
            StateHasChanged();
        }
    }

    private async Task ToggleTheme()
    {
        var newTheme = await JS.InvokeAsync<string>("toggleTheme");
        _themeIcon = newTheme == "dark" ? "\ud83c\udf19" : "\u2600\ufe0f";
    }
}
