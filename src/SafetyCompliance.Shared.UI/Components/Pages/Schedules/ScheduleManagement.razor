@page "/schedules"
@inject IScheduleService ScheduleService
@inject IPlantService PlantService
@inject ICompanyService CompanyService
@inject IInspectionService InspectionService
@inject NavigationManager Navigation

<div class="sched-page">
    @* ── Header ── *@
    <div class="sched-hero ov-fadeIn">
        <div class="sched-hero-left">
            <h1>Inspection Schedules</h1>
            <p>Manage recurring inspection schedules across your plants</p>
        </div>
        <button class="btn btn-primary btn-lg" @onclick="() => _showCreate = true">
            <i class="fa-light fa-plus-circle"></i> New Schedule
        </button>
    </div>

    @if (_loading)
    {
        <div class="ov-loading"><div class="ov-spinner"></div><p>Loading&hellip;</p></div>
    }
    else
    {
        @* ── Filter bar ── *@
        <div class="sched-filter-bar ov-fadeIn">
            <div class="sched-filter-pills">
                <button class="sched-pill @(_filterPlantId == null ? "active" : "")"
                        @onclick="() => FilterByPlant(null)">
                    <i class="fa-light fa-globe"></i> All Plants
                    <span class="sched-pill-count">@_schedules.Count</span>
                </button>
                @foreach (var plant in _allPlants)
                {
                    var p = plant;
                    var ct = _schedules.Count(s => s.PlantId == p.Id);
                    @if (ct > 0)
                    {
                        <button class="sched-pill @(_filterPlantId == p.Id ? "active" : "")"
                                @onclick="() => FilterByPlant(p.Id)">
                            @p.Name
                            <span class="sched-pill-count">@ct</span>
                        </button>
                    }
                }
            </div>
        </div>

        @if (!FilteredSchedules.Any())
        {
            <div class="ov-empty ov-fadeIn">
                <div class="ov-empty-icon"><i class="fa-light fa-calendar-circle-plus"></i></div>
                <h2>No schedules yet</h2>
                <p>Create an inspection schedule to automate your compliance tracking.</p>
                <button class="btn btn-primary btn-lg" @onclick="() => _showCreate = true">
                    <i class="fa-light fa-plus-circle"></i> Create First Schedule
                </button>
            </div>
        }
        else
        {
            @* ── Schedule Timeline ── *@
            <div class="sched-timeline">
                @{ var schedIdx = 0; }
                @foreach (var sched in FilteredSchedules)
                {
                    var s = sched;
                    var si = schedIdx;
                    var isOverdue = s.NextDueDate < DateOnly.FromDateTime(DateTime.UtcNow) && s.IsActive;
                    var pct = s.TotalRounds > 0 ? (int)((double)s.CompletedRounds / s.TotalRounds * 100) : 0;

                    <div class="sched-card @(isOverdue ? "overdue" : "") @(!s.IsActive ? "inactive" : "") ov-staggerUp"
                         style="animation-delay: @(si * 0.05)s">
                        @* Left strip indicator *@
                        <div class="sched-card-strip @(isOverdue ? "danger" : !s.IsActive ? "muted" : "primary")"></div>

                        <div class="sched-card-body">
                            @* Top row *@
                            <div class="sched-card-top">
                                <div class="sched-card-info">
                                    <h3>@s.Name</h3>
                                    <div class="sched-card-tags">
                                        <span class="sched-tag plant"><i class="fa-light fa-industry"></i> @s.PlantName</span>
                                        <span class="sched-tag freq"><i class="fa-light fa-repeat"></i> @FormatFrequency(s.Frequency, s.FrequencyInterval)</span>
                                    </div>
                                </div>
                                <div class="sched-card-status">
                                    @if (!s.IsActive)
                                    {
                                        <span class="status-badge status-draft">Inactive</span>
                                    }
                                    else if (isOverdue)
                                    {
                                        <span class="status-badge status-completedwithissues">Overdue</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-completed">Active</span>
                                    }
                                </div>
                            </div>

                            @if (s.Description is not null)
                            {
                                <p class="sched-card-desc">@s.Description</p>
                            }

                            @* Dates row *@
                            <div class="sched-card-dates">
                                <div class="sched-date-item @(isOverdue ? "overdue" : "")">
                                    <i class="fa-light fa-calendar-arrow-down"></i>
                                    <div>
                                        <span class="sched-date-label">Next Due</span>
                                        <span class="sched-date-value">@s.NextDueDate.ToString("MMM dd, yyyy")</span>
                                    </div>
                                </div>
                                @if (s.LastCompletedDate.HasValue)
                                {
                                    <div class="sched-date-item">
                                        <i class="fa-light fa-calendar-check"></i>
                                        <div>
                                            <span class="sched-date-label">Last Completed</span>
                                            <span class="sched-date-value">@s.LastCompletedDate.Value.ToString("MMM dd, yyyy")</span>
                                        </div>
                                    </div>
                                }
                                <div class="sched-date-item">
                                    <i class="fa-light fa-calendar-lines"></i>
                                    <div>
                                        <span class="sched-date-label">Started</span>
                                        <span class="sched-date-value">@s.StartDate.ToString("MMM dd, yyyy")</span>
                                    </div>
                                </div>
                            </div>

                            @* Progress row *@
                            <div class="sched-card-footer">
                                <div class="sched-progress">
                                    <div class="sched-progress-bar">
                                        <div class="sched-progress-fill" style="width: @pct%"></div>
                                    </div>
                                    <span class="sched-progress-text">@s.CompletedRounds / @s.TotalRounds rounds completed</span>
                                </div>
                                <div class="sched-card-actions">
                                    @if (s.IsActive)
                                    {
                                        <button class="sched-action-btn" title="Start inspection"
                                                @onclick="() => StartInspection(s)" @onclick:stopPropagation>
                                            <i class="fa-light fa-play-circle"></i>
                                        </button>
                                    }
                                    <button class="sched-action-btn" title="View rounds"
                                            @onclick="() => ViewScheduleRounds(s)" @onclick:stopPropagation>
                                        <i class="fa-light fa-list-timeline"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    schedIdx++;
                }
            </div>
        }
    }
</div>

@* ── Create Schedule Modal ── *@
@if (_showCreate)
{
    <div class="chk-modal-overlay" @onclick="() => _showCreate = false">
        <div class="chk-modal ov-scaleIn" @onclick:stopPropagation>
            <div class="chk-modal-header">
                <div class="chk-modal-icon info"><i class="fa-light fa-calendar-plus"></i></div>
                <div>
                    <h2>New Schedule</h2>
                    <span class="chk-modal-sub">Set up a recurring inspection</span>
                </div>
                <button class="chk-modal-close" @onclick="() => _showCreate = false"><i class="fa-light fa-xmark"></i></button>
            </div>
            <div class="chk-modal-body">
                <EditForm Model="_createModel" OnValidSubmit="CreateSchedule">
                    <div class="sched-form-row">
                        <div class="sched-form-group">
                            <label><i class="fa-light fa-tag"></i> Schedule Name</label>
                            <InputText @bind-Value="_createModel.Name" class="form-control" placeholder="e.g. Monthly Fire Extinguisher Check" />
                        </div>
                        <div class="sched-form-group">
                            <label><i class="fa-light fa-industry"></i> Plant</label>
                            <select class="form-control" @onchange="OnCreatePlantChanged">
                                <option value="">Select a plant&hellip;</option>
                                @foreach (var plant in _allPlants)
                                {
                                    <option value="@plant.Id">@plant.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="sched-form-group">
                        <label><i class="fa-light fa-align-left"></i> Description (optional)</label>
                        <InputText @bind-Value="_createModel.Description" class="form-control" placeholder="Brief description of this schedule" />
                    </div>
                    <div class="sched-form-row">
                        <div class="sched-form-group">
                            <label><i class="fa-light fa-repeat"></i> Frequency</label>
                            <InputSelect @bind-Value="_createModel.Frequency" class="form-control">
                                <option value="@FrequencyType.Daily">Daily</option>
                                <option value="@FrequencyType.Weekly">Weekly</option>
                                <option value="@FrequencyType.BiWeekly">Bi-Weekly</option>
                                <option value="@FrequencyType.Monthly">Monthly</option>
                                <option value="@FrequencyType.Quarterly">Quarterly</option>
                                <option value="@FrequencyType.SemiAnnually">Semi-Annually</option>
                                <option value="@FrequencyType.Annually">Annually</option>
                            </InputSelect>
                        </div>
                        <div class="sched-form-group">
                            <label><i class="fa-light fa-arrow-right-arrow-left"></i> Interval</label>
                            <InputNumber @bind-Value="_createModel.FrequencyInterval" class="form-control" min="1" />
                        </div>
                    </div>
                    <div class="sched-form-row">
                        <div class="sched-form-group">
                            <label><i class="fa-light fa-calendar"></i> Start Date</label>
                            <InputDate @bind-Value="_createModel.StartDate" class="form-control" />
                        </div>
                        <div class="sched-form-group">
                            <label><i class="fa-light fa-calendar-xmark"></i> End Date (optional)</label>
                            <InputDate @bind-Value="_createModel.EndDate" class="form-control" />
                        </div>
                    </div>
                    <div class="chk-modal-footer" style="margin-top: var(--spacing-md); padding: 0; border: none;">
                        <button type="button" class="btn btn-ghost" @onclick="() => _showCreate = false">Cancel</button>
                        <button type="submit" class="btn btn-primary">
                            <i class="fa-light fa-check"></i> Create Schedule
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private List<InspectionScheduleDto> _schedules = [];
    private List<PlantDto> _allPlants = [];
    private bool _loading = true;
    private bool _showCreate;
    private int? _filterPlantId;
    private ScheduleCreateModel _createModel = new();

    private IEnumerable<InspectionScheduleDto> FilteredSchedules =>
        _filterPlantId.HasValue ? _schedules.Where(s => s.PlantId == _filterPlantId) : _schedules;

    protected override async Task OnInitializedAsync()
    {
        var companies = await CompanyService.GetAllCompaniesAsync();
        foreach (var company in companies)
        {
            var plants = await PlantService.GetPlantsByCompanyAsync(company.Id);
            _allPlants.AddRange(plants);
        }
        _schedules = await ScheduleService.GetSchedulesAsync();
        _loading = false;
    }

    private void FilterByPlant(int? plantId) => _filterPlantId = plantId;

    private void OnCreatePlantChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id))
            _createModel.PlantId = id;
    }

    private async Task CreateSchedule()
    {
        if (_createModel.PlantId == 0) return;
        var dto = new InspectionScheduleCreateDto(
            _createModel.PlantId, _createModel.Name, _createModel.Description,
            _createModel.Frequency, _createModel.FrequencyInterval,
            _createModel.StartDate, _createModel.EndDate, true);
        await ScheduleService.CreateScheduleAsync(dto, "current-user");
        _schedules = await ScheduleService.GetSchedulesAsync();
        _showCreate = false;
        _createModel = new();
    }

    private async Task StartInspection(InspectionScheduleDto sched)
    {
        var round = await InspectionService.StartInspectionRoundAsync(sched.PlantId, "current-user");
        Navigation.NavigateTo($"/inspections/{round.Id}");
    }

    private void ViewScheduleRounds(InspectionScheduleDto sched)
    {
        Navigation.NavigateTo($"/inspections");
    }

    private static string FormatFrequency(FrequencyType freq, int interval)
    {
        var baseText = freq switch
        {
            FrequencyType.Daily => "Daily",
            FrequencyType.Weekly => "Weekly",
            FrequencyType.BiWeekly => "Bi-Weekly",
            FrequencyType.Monthly => "Monthly",
            FrequencyType.Quarterly => "Quarterly",
            FrequencyType.SemiAnnually => "Semi-Annually",
            FrequencyType.Annually => "Annually",
            _ => freq.ToString()
        };
        return interval > 1 ? $"Every {interval} {baseText.ToLower()}" : baseText;
    }

    private class ScheduleCreateModel
    {
        public int PlantId { get; set; }
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public FrequencyType Frequency { get; set; } = FrequencyType.Monthly;
        public int FrequencyInterval { get; set; } = 1;
        public DateOnly StartDate { get; set; } = DateOnly.FromDateTime(DateTime.UtcNow);
        public DateOnly? EndDate { get; set; }
    }
}
