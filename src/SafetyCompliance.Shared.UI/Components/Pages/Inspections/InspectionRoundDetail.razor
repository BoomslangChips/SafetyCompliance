                        </div>
                    }
                </div>
            </div>
            <div class="chk-modal-footer">
                <button class="btn btn-ghost" @onclick="() => _showDeleteConfirm = false">Cancel</button>
                <button class="btn btn-danger" @onclick="ConfirmDeleteRound">
                    <i class="fa-sharp fa-light fa-trash"></i> Delete Round
                </button>
