@* ── Log Incident Modal (from inspection) ── *@
@if (_showLogIncident)
{
    <div class="chk-modal-overlay" @onclick="() => _showLogIncident = false">
        <div class="chk-modal chk-modal-wide ov-scaleIn" @onclick:stopPropagation>
            <div class="chk-modal-header">
                <div class="chk-modal-icon warning"><i class="fa-sharp fa-light fa-triangle-exclamation"></i></div>
                <div>
                    <h2>Log Incident</h2>
                    <span class="chk-modal-sub">Round #@RoundId</span>
                </div>
                <button class="chk-modal-close" @onclick="() => _showLogIncident = false"><i class="fa-sharp fa-light fa-xmark"></i></button>
            </div>
            <div class="chk-modal-body">
                <div class="form-group">
                    <label>Incident Title <span class="form-required">*</span></label>
                    <input @bind="_incTitle" class="form-control" placeholder="Brief description of the incident" />
                </div>
                <div class="form-group">
                    <label>Details</label>
                    <textarea @bind="_incDescription" class="form-control" rows="3"
                              placeholder="Describe what happened, where, and the impact..."></textarea>
                </div>
                <div class="form-group">
                    <label>Priority</label>
                    <div class="chk-priority-select">
                        @foreach (var p in new[] { IssuePriority.Low, IssuePriority.Medium, IssuePriority.High, IssuePriority.Critical })
                        {
                            var pv = p;
                            <button type="button" class="chk-priority-btn priority-@p.ToString().ToLower() @(_incPriority == p ? "active" : "")"
                                    @onclick="() => _incPriority = pv">
                                <i class="fa-sharp fa-light @PriorityIconStatic(pv)"></i> @p
                            </button>
                        }
                    </div>
                </div>
                <div class="form-group picker-section">
                    <label>Link to Equipment <span class="form-hint">(optional)</span></label>
                    <div class="picker-grid">
                        <select @onchange="OnIncPickerCompanyChanged">
                            <option value="">— Company —</option>
                            @foreach (var c in _incCompanies)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </select>
                        <select @onchange="OnIncPickerPlantChanged" disabled="@(_incPickerCompanyId == null)">
                            <option value="">— Plant —</option>
                            @foreach (var p in _incPickerPlants)
                            {
                                <option value="@p.Id">@p.Name</option>
                            }
                        </select>
                        <select @onchange="OnIncPickerSectionChanged" disabled="@(_incPickerPlantId == null)">
                            <option value="">— Section —</option>
                            @foreach (var s in _incPickerSections)
                            {
                                <option value="@s.Id">@s.Name</option>
                            }
                        </select>
                        <select @onchange="e => _incEquipmentId = ParseIncId(e)" disabled="@(_incPickerSectionId == null)">
                            <option value="">— Equipment —</option>
                            @foreach (var eq in _incPickerEquipment)
                            {
                                <option value="@eq.Id">@eq.Identifier — @eq.EquipmentTypeName@(eq.SubTypeName != null ? $" ({eq.SubTypeName})" : "")@(!string.IsNullOrEmpty(eq.Description) ? $" · {eq.Description}" : "")</option>
                            }
                        </select>
                    </div>
                    @if (_incEquipmentId.HasValue)
                    {
                        var sel = _incPickerEquipment.FirstOrDefault(e => e.Id == _incEquipmentId);
                        <div class="picker-summary"><i class="fa-sharp fa-light fa-circle-check"></i> @sel?.Identifier — @sel?.EquipmentTypeName@(sel?.SubTypeName != null ? $" ({sel.SubTypeName})" : "")@(!string.IsNullOrEmpty(sel?.Description) ? $" · {sel!.Description}" : "")</div>
                    }
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Assigned To</label>
                        <input @bind="_incAssignedTo" class="form-control" placeholder="Name or email" />
                    </div>
                    <div class="form-group">
                        <label>Due Date</label>
                        <InputDate @bind-Value="_incDueDate" class="form-control" />
                    </div>
                </div>
            </div>
            <div class="chk-modal-footer">
                <button class="btn btn-ghost" @onclick="() => _showLogIncident = false">Cancel</button>
                <button class="btn btn-warning" @onclick="SubmitLogIncident"
                        disabled="@(string.IsNullOrWhiteSpace(_incTitle))">
                    <i class="fa-sharp fa-light fa-triangle-exclamation"></i> Log Incident
                </button>
            </div>
        </div>
    </div>
}

@* ── Photo Lightbox ── *@
@if (_lightboxPhotos is not null && _lightboxPhotos.Count > 0)
{
    var _lb = _lightboxPhotos[_lightboxIndex];
    <div class="photo-lightbox" @onclick="CloseLightbox">
        <button class="photo-lb-close" @onclick="CloseLightbox" @onclick:stopPropagation="true" aria-label="Close">
            <i class="fa-sharp fa-light fa-xmark"></i>
        </button>
        <div class="photo-lb-counter">@(_lightboxIndex + 1) / @_lightboxPhotos.Count</div>
        @if (_lightboxPhotos.Count > 1)
        {
            <button class="photo-lb-nav prev" @onclick="LightboxPrev" @onclick:stopPropagation="true" aria-label="Previous">
                <i class="fa-sharp fa-light fa-chevron-left"></i>
            </button>
            <button class="photo-lb-nav next" @onclick="LightboxNext" @onclick:stopPropagation="true" aria-label="Next">
                <i class="fa-sharp fa-light fa-chevron-right"></i>
            </button>
        }
        <div class="photo-lb-img-wrap" @onclick:stopPropagation="true">
            <img src="@_lb.FilePath" alt="Photo @(_lightboxIndex + 1)" class="photo-lb-img" />
        </div>
        <div class="photo-lb-caption">@_lb.FileName</div>
    </div>
}

@* ── Quick Resolve Incident Modal ── *@
@if (_showQuickResolve)
{
    <div class="chk-modal-overlay" @onclick="() => _showQuickResolve = false">
        <div class="chk-modal ov-scaleIn" @onclick:stopPropagation>
            <div class="chk-modal-header">
                <div class="chk-modal-icon success"><i class="fa-sharp fa-light fa-circle-check"></i></div>
                <div>
                    <h2>Resolve Incident</h2>
                    <span class="chk-modal-sub">Add resolution notes (optional)</span>
                </div>
                <button class="chk-modal-close" @onclick="() => _showQuickResolve = false"><i class="fa-sharp fa-light fa-xmark"></i></button>
            </div>
            <div class="chk-modal-body">
                <div class="form-group">
                    <label>How was this resolved?</label>
                    <textarea @bind="_resolveNotes" class="form-control" rows="3"
                              placeholder="Describe the actions taken..."></textarea>
                </div>
            </div>
            <div class="chk-modal-footer">
                <button class="btn btn-ghost" @onclick="() => _showQuickResolve = false">Cancel</button>
                <button class="btn btn-success" @onclick="DoResolveIssue">
                    <i class="fa-sharp fa-light fa-check"></i> Mark Resolved
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int RoundId { get; set; }

    private List<EquipmentInspectionDto> _inspections = [];
    private List<CommentDto> _comments = [];
    private List<IssueDto> _roundIssues = [];
    private Dictionary<int, string?> _equipmentComments = new();
    private bool _loading = true;
    private int _completedCount;
    private double _progress;
    private int _incompleteCount;
    private int _failedItemCount;
    private int _outForServiceCount;
    private string _newCommentText = string.Empty;

    // Section navigation
    private List<SectionGroup> _sectionGroups = [];
    private int _activeSectionId;
    private SectionGroup? ActiveSection => _sectionGroups.FirstOrDefault(s => s.SectionId == _activeSectionId);

    // Flag issue modal
    private bool _showFlagIssue;
    private int _flagEquipmentInspectionId;
    private int _flagEquipmentId;
    private string _flagEquipmentIdentifier = "";
    private string _flagIssueTitle = string.Empty;
    private string? _flagIssueDescription;
    private IssuePriority _flagIssuePriority = IssuePriority.Medium;

    // Service booking modal
    private bool _showServiceModal;
    private int _serviceEquipmentId;
    private int _serviceEquipmentInspectionId;
    private string _serviceEquipmentIdentifier = "";
    private string _serviceProvider = string.Empty;
    private string _serviceReason = string.Empty;
    private DateOnly? _serviceExpectedReturn;
    private string? _serviceNotes;

    // Delete confirmation
    private bool _showDeleteConfirm;

    // Complete confirmation
    private bool _showCompleteConfirmation;

    // Log incident (from round)
    private bool _showLogIncident;
    private string _incTitle = string.Empty;
    private string? _incDescription;
    private IssuePriority _incPriority = IssuePriority.Medium;
    private string? _incAssignedTo;
    private DateOnly? _incDueDate;
    private int? _incEquipmentId;

    // Cascading picker for log incident modal
    private List<CompanyDto>   _incCompanies = [];
    private List<PlantDto>     _incPickerPlants = [];
    private List<SectionDto>   _incPickerSections = [];
    private List<EquipmentDto> _incPickerEquipment = [];
    private int? _incPickerCompanyId, _incPickerPlantId, _incPickerSectionId;

    // Quick resolve issue
    private bool _showQuickResolve;
    private int _resolveIssueId;
    private string? _resolveNotes;

    // Photos (lazy-loaded per equipment inspection)
    private Dictionary<int, List<InspectionPhotoDto>> _photos        = new();
    private HashSet<int>                              _loadingPhotos  = new();
    private HashSet<int>                              _uploadingPhoto = new();

    // Lightbox
    private List<InspectionPhotoDto>? _lightboxPhotos;
    private int                       _lightboxIndex;

    private record SectionGroup(int SectionId, string SectionName, List<EquipmentInspectionDto> Items);

    protected override async Task OnInitializedAsync()
    {
        _incCompanies = await CompanyService.GetAllCompaniesAsync();
        await LoadData();
    }

    private async Task LoadData()
    {
        _inspections = await InspectionService.GetEquipmentInspectionsAsync(RoundId);
        _comments = await IssueService.GetInspectionCommentsAsync(RoundId);
        _roundIssues = await IssueService.GetIssuesAsync(roundId: RoundId);

        _equipmentComments.Clear();
        foreach (var insp in _inspections)
            _equipmentComments[insp.Id] = insp.Comments;

        _completedCount = _inspections.Count(i => i.IsComplete);
        _progress = _inspections.Count > 0 ? (double)_completedCount / _inspections.Count * 100 : 0;
        _incompleteCount = _inspections.Count(i => !i.IsComplete);
        _failedItemCount = _inspections.Sum(i => i.Responses.Count(r => r.Response == false));
        _outForServiceCount = _inspections.Count(i => i.ActiveServiceBooking is not null);

        // Build section groups
        _sectionGroups = _inspections
            .GroupBy(i => new { i.SectionId, i.SectionName })
            .Select(g => new SectionGroup(g.Key.SectionId, g.Key.SectionName, g.ToList()))
            .ToList();

        if (_activeSectionId == 0 && _sectionGroups.Any())
            _activeSectionId = _sectionGroups.First().SectionId;

        // Load all photos for this round in a single query
        var allPhotos = await InspectionService.GetPhotosByRoundAsync(RoundId);
        foreach (var kvp in allPhotos)
            _photos[kvp.Key] = kvp.Value;
        // Ensure empty lists for inspections with no photos
        foreach (var insp in _inspections)
        {
            if (!_photos.ContainsKey(insp.Id))
                _photos[insp.Id] = [];
        }

        _loading = false;
    }

    private void SetActiveSection(int sectionId) => _activeSectionId = sectionId;

    private async Task SubmitResponse(int equipmentInspectionId, int checklistItemTemplateId, bool response)
    {
        try { await JS.InvokeVoidAsync("hapticTap"); } catch { }
        await InspectionService.SubmitResponseAsync(new SubmitResponseDto(equipmentInspectionId, checklistItemTemplateId, response, null));
        await LoadData();
    }

    private async Task OnCommentChanged(int equipmentInspectionId, ChangeEventArgs e)
    {
        var comment = e.Value?.ToString();
        _equipmentComments[equipmentInspectionId] = comment;
        await InspectionService.SaveEquipmentCommentAsync(equipmentInspectionId, comment);
    }

    // Flag Issue
    private void ShowFlagIssue(EquipmentInspectionDto inspection)
    {
        _flagEquipmentInspectionId = inspection.Id;
        _flagEquipmentId = inspection.EquipmentId;
        _flagEquipmentIdentifier = inspection.EquipmentIdentifier;
        _flagIssueTitle = $"Issue with {inspection.EquipmentIdentifier}";
        _flagIssueDescription = null;
        _flagIssuePriority = IssuePriority.Medium;
        _showFlagIssue = true;
    }

    private async Task CreateFlaggedIssue()
    {
        var dto = new IssueCreateDto(
            _flagIssueTitle, _flagIssueDescription, _flagIssuePriority,
            null, null, RoundId, _flagEquipmentInspectionId, _flagEquipmentId, null, null);
        await IssueService.CreateIssueAsync(dto, "current-user");
        _showFlagIssue = false;
    }

    // Service Booking
    private void ShowServiceModal(EquipmentInspectionDto inspection)
    {
        _serviceEquipmentId = inspection.EquipmentId;
        _serviceEquipmentInspectionId = inspection.Id;
        _serviceEquipmentIdentifier = inspection.EquipmentIdentifier;
        _serviceProvider = string.Empty;
        _serviceReason = string.Empty;
        _serviceExpectedReturn = null;
        _serviceNotes = null;
        _showServiceModal = true;
    }

    private async Task CreateServiceBooking()
    {
        var dto = new ServiceBookingCreateDto(
            _serviceEquipmentId, _serviceEquipmentInspectionId,
            _serviceProvider, _serviceReason,
            _serviceExpectedReturn, _serviceNotes);
        await ServiceBookingService.CreateBookingAsync(dto, "current-user");
        _showServiceModal = false;
        await LoadData();
    }

    // Complete Round
    private void ShowCompleteConfirmation()
    {
        _incompleteCount = _inspections.Count(i => !i.IsComplete);
        _failedItemCount = _inspections.Sum(i => i.Responses.Count(r => r.Response == false));
        _outForServiceCount = _inspections.Count(i => i.ActiveServiceBooking is not null);
        _showCompleteConfirmation = true;
    }

    private async Task ConfirmCompleteRound()
    {
        await InspectionService.CompleteRoundAsync(RoundId);
        _showCompleteConfirmation = false;
        Navigation.NavigateTo("/inspections");
    }

    private async Task ConfirmDeleteRound()
    {
        await InspectionService.DeleteRoundAsync(RoundId);
        _showDeleteConfirm = false;
        Navigation.NavigateTo("/inspections");
    }

    // Comments
    private async Task AddComment()
    {
        if (string.IsNullOrWhiteSpace(_newCommentText)) return;
        var dto = new CommentCreateDto(RoundId, null, _newCommentText, null, null);
        await IssueService.AddInspectionCommentAsync(dto, "current-user");
        _newCommentText = string.Empty;
        await LoadData();
    }

    // Incident management
    private void OpenLogIncident()
    {
        _incTitle = string.Empty;
        _incDescription = null;
        _incPriority = IssuePriority.Medium;
        _incAssignedTo = null;
        _incDueDate = null;
        _incEquipmentId = null;
        _incPickerCompanyId = null;
        _incPickerPlantId = null;
        _incPickerSectionId = null;
        _incPickerPlants = [];
        _incPickerSections = [];
        _incPickerEquipment = [];
        _showLogIncident = true;
    }

    private async Task SubmitLogIncident()
    {
        if (string.IsNullOrWhiteSpace(_incTitle)) return;
        var dto = new IssueCreateDto(_incTitle, _incDescription, _incPriority,
            _incAssignedTo, _incDueDate, RoundId, null, _incEquipmentId, null, null);
        await IssueService.CreateIssueAsync(dto, "current-user");
        _showLogIncident = false;
        await LoadData();
    }

    // Cascading picker for incident modal
    private async Task OnIncPickerCompanyChanged(ChangeEventArgs e)
    {
        _incPickerCompanyId = ParseIncId(e);
        _incPickerPlantId = null; _incPickerSectionId = null;
        _incPickerPlants = []; _incPickerSections = []; _incPickerEquipment = [];
        _incEquipmentId = null;
        if (_incPickerCompanyId.HasValue)
            _incPickerPlants = await PlantService.GetPlantsByCompanyAsync(_incPickerCompanyId.Value);
    }
    private async Task OnIncPickerPlantChanged(ChangeEventArgs e)
    {
        _incPickerPlantId = ParseIncId(e);
        _incPickerSectionId = null;
        _incPickerSections = []; _incPickerEquipment = [];
        _incEquipmentId = null;
        if (_incPickerPlantId.HasValue)
            _incPickerSections = await SectionService.GetSectionsByPlantAsync(_incPickerPlantId.Value);
    }
    private async Task OnIncPickerSectionChanged(ChangeEventArgs e)
    {
        _incPickerSectionId = ParseIncId(e);
        _incPickerEquipment = [];
        _incEquipmentId = null;
        if (_incPickerSectionId.HasValue)
            _incPickerEquipment = await EquipmentService.GetEquipmentBySectionAsync(_incPickerSectionId.Value);
    }
    private static int? ParseIncId(ChangeEventArgs e) =>
        int.TryParse(e.Value?.ToString(), out var v) && v > 0 ? v : null;

    private void QuickResolveIssue(int id) { _resolveIssueId = id; _resolveNotes = null; _showQuickResolve = true; }

    private async Task DoResolveIssue()
    {
        await IssueService.ResolveIssueAsync(_resolveIssueId, _resolveNotes, "current-user");
        _showQuickResolve = false;
        await LoadData();
    }

    private void GoToIncident(int id) => Navigation.NavigateTo($"/issues/{id}");

    // ── Photo upload / delete / lightbox ──────────────────────────────────────

    private async Task TriggerPhotoInput(int equipmentInspectionId)
        => await JS.InvokeVoidAsync("clickPhotoInput", $"photo-input-{equipmentInspectionId}");

    private async Task HandlePhotoUpload(int equipmentInspectionId, InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;

        _uploadingPhoto.Add(equipmentInspectionId);
        StateHasChanged();

        try
        {
            // Try client-side compression first (for images > 500KB)
            var inputId = $"photo-input-{equipmentInspectionId}";
            string webPath;
            string fileName;
            string contentType;
            long fileSize;

            try
            {
                // compressPhoto always returns a stamped image (with timestamp watermark)
                var compressed = await JS.InvokeAsync<CompressedPhoto?>("compressPhoto", inputId, 1920, 0.80);
                if (compressed is not null)
                {
                    var bytes = Convert.FromBase64String(compressed.Base64);
                    using var ms = new MemoryStream(bytes);
                    webPath = await PhotoStorage.SavePhotoAsync(ms, compressed.FileName, equipmentInspectionId);
                    fileName = compressed.FileName;
                    contentType = compressed.ContentType;
                    fileSize = compressed.Size;
                }
                else
                {
                    // Fallback if JS returns null unexpectedly
                    const long maxSize = 10L * 1024 * 1024;
                    await using var stream = file.OpenReadStream(maxSize);
                    webPath = await PhotoStorage.SavePhotoAsync(stream, file.Name, equipmentInspectionId);
                    fileName = file.Name;
                    contentType = file.ContentType;
                    fileSize = file.Size;
                }
            }
            catch
            {
                // JS failed — fallback to raw upload (no timestamp)
                const long maxSize = 10L * 1024 * 1024;
                await using var stream = file.OpenReadStream(maxSize);
                webPath = await PhotoStorage.SavePhotoAsync(stream, file.Name, equipmentInspectionId);
                fileName = file.Name;
                contentType = file.ContentType;
                fileSize = file.Size;
            }

            await InspectionService.UploadPhotoAsync(
                equipmentInspectionId, fileName, webPath,
                contentType, fileSize, "current-user");

            _photos[equipmentInspectionId] = await InspectionService.GetPhotosAsync(equipmentInspectionId);
            var idx = _inspections.FindIndex(i => i.Id == equipmentInspectionId);
            if (idx >= 0)
                _inspections[idx] = _inspections[idx] with { PhotoCount = _photos[equipmentInspectionId].Count };

            // Haptic feedback on success
            try { await JS.InvokeVoidAsync("hapticSuccess"); } catch { }
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Photo upload error: {ex.Message}");
        }
        finally
        {
            _uploadingPhoto.Remove(equipmentInspectionId);
        }
    }

    private record CompressedPhoto(string Base64, string FileName, string ContentType, long Size);

    private async Task DeletePhoto(int photoId, int equipmentInspectionId)
    {
        var filePath = await InspectionService.DeletePhotoAsync(photoId);
        if (filePath is not null)
            await PhotoStorage.DeletePhotoAsync(filePath);

        _photos[equipmentInspectionId] = await InspectionService.GetPhotosAsync(equipmentInspectionId);
        var idx = _inspections.FindIndex(i => i.Id == equipmentInspectionId);
        if (idx >= 0)
            _inspections[idx] = _inspections[idx] with { PhotoCount = _photos[equipmentInspectionId].Count };
    }

    private void OpenLightbox(int equipmentInspectionId, int index)
    {
        _lightboxPhotos = _photos.GetValueOrDefault(equipmentInspectionId);
        _lightboxIndex  = index;
    }

    private void CloseLightbox() => _lightboxPhotos = null;

    private void LightboxPrev()
    {
        if (_lightboxPhotos is null) return;
        _lightboxIndex = (_lightboxIndex - 1 + _lightboxPhotos.Count) % _lightboxPhotos.Count;
    }

    private void LightboxNext()
    {
        if (_lightboxPhotos is null) return;
        _lightboxIndex = (_lightboxIndex + 1) % _lightboxPhotos.Count;
    }

    private static string PriorityIcon(IssuePriority p) => p switch
    {
        IssuePriority.Critical => "fa-siren-on",
        IssuePriority.High => "fa-arrow-up",
        IssuePriority.Medium => "fa-minus",
        _ => "fa-arrow-down"
    };

    // Alias for use in modal lambda context
    private static string PriorityIconStatic(IssuePriority p) => PriorityIcon(p);

    private void GoBack() => Navigation.NavigateTo("/inspections");
}
