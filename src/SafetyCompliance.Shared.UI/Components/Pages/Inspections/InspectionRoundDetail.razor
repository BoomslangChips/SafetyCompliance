@page "/inspections/{RoundId:int}"
@inject IInspectionService InspectionService
@inject IPhotoStorageService PhotoStorage
@inject IIssueService IssueService
@inject IServiceBookingService ServiceBookingService
@inject ICompanyService CompanyService
@inject IPlantService PlantService
@inject ISectionService SectionService
@inject IEquipmentService EquipmentService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="chk-page">
    @* ── Header ── *@
    <div class="chk-header ov-fadeIn">
        <button class="chk-back" @onclick="GoBack">
            <i class="fa-sharp fa-light fa-arrow-left"></i>
        </button>
        <div class="chk-header-info">
            <h1>Inspection Checklist</h1>
            <span class="chk-header-sub">Round #@RoundId</span>
        </div>
        <button class="chk-delete-btn" title="Delete this inspection round"
                @onclick="() => _showDeleteConfirm = true">
            <i class="fa-sharp fa-light fa-trash"></i>
        </button>
        @if (!_loading && _inspections.Any())
        {
            <div class="chk-header-ring">
                <svg class="insp-ring" viewBox="0 0 52 52">
                    <circle class="insp-ring-bg" cx="26" cy="26" r="22" />
                    <circle class="insp-ring-fill status-ring-inprogress" cx="26" cy="26" r="22"
                            stroke-dasharray="@(138.2)" stroke-dashoffset="@(138.2 - 138.2 * _progress / 100)" />
                </svg>
                <span class="chk-ring-pct">@((int)_progress)%</span>
            </div>
            <div class="chk-header-stats">
                <span class="chk-stat done"><i class="fa-sharp fa-light fa-circle-check"></i> @_completedCount done</span>
                @if (_incompleteCount > 0)
                {
                    <span class="chk-stat pending"><i class="fa-sharp fa-light fa-circle-half-stroke"></i> @_incompleteCount remaining</span>
                }
                @if (_outForServiceCount > 0)
                {
                    <span class="chk-stat service"><i class="fa-sharp fa-light fa-wrench"></i> @_outForServiceCount service</span>
                }
            </div>
        }
    </div>

    @if (_loading)
    {
        <div class="ov-loading"><div class="ov-spinner"></div><p>Loading checklist&hellip;</p></div>
    }
    else if (!_inspections.Any())
    {
        <div class="ov-empty ov-fadeIn">
            <div class="ov-empty-icon"><i class="fa-sharp fa-light fa-clipboard-list"></i></div>
            <h2>No equipment found</h2>
            <p>Make sure the plant has active equipment with checklist templates configured.</p>
            <button class="btn btn-primary" @onclick="GoBack"><i class="fa-sharp fa-light fa-arrow-left"></i> Back to Inspections</button>
        </div>
    }
    else
    {
        @* ── Section navigation pills ── *@
        <div class="chk-section-nav ov-fadeIn">
            @foreach (var sg in _sectionGroups)
            {
                var s = sg;
                var sectionDone = sg.Items.Count(i => i.IsComplete);
                var sectionTotal = sg.Items.Count;
                <button class="chk-section-pill @(_activeSectionId == sg.SectionId ? "active" : "") @(sectionDone == sectionTotal ? "complete" : "")"
                        @onclick="() => SetActiveSection(sg.SectionId)">
                    <span class="chk-pill-name">@sg.SectionName</span>
                    <span class="chk-pill-count">@sectionDone/@sectionTotal</span>
                </button>
            }
        </div>

        @* ── Active section content ── *@
        @if (ActiveSection is not null)
        {
            <div class="chk-section ov-fadeIn" @key="_activeSectionId">
                @foreach (var typeGroup in ActiveSection.Items.GroupBy(i => new { i.EquipmentTypeId, i.EquipmentTypeName }))
                {
                    var typeInspections = typeGroup.ToList();
                    var checklistHeaders = typeInspections
                        .Where(i => i.Responses.Any())
                        .SelectMany(i => i.Responses)
                        .Select(r => new { r.ChecklistItemTemplateId, r.ItemName, r.SortOrder })
                        .DistinctBy(r => r.ChecklistItemTemplateId)
                        .OrderBy(r => r.SortOrder)
                        .ToList();

                    <div class="chk-type-group ov-staggerUp">
                        <div class="chk-type-header">
                            <div class="chk-type-icon">
                                <i class="fa-sharp fa-light fa-gear"></i>
                            </div>
                            <h3>@typeGroup.Key.EquipmentTypeName</h3>
                            <span class="chk-type-count">@typeInspections.Count items</span>
                            <span class="chk-type-progress">
                                @typeInspections.Count(i => i.IsComplete)/@typeInspections.Count complete
                            </span>
                        </div>

                        @if (checklistHeaders.Any())
                        {
                            @foreach (var inspection in typeInspections)
                            {
                                var insp = inspection;
                                var isOutForService = insp.ActiveServiceBooking is not null;
                                var failedItems = insp.Responses.Where(r => r.Response == false).ToList();
                                var answeredCount = insp.Responses.Count(r => r.Response.HasValue);
                                var isUploadingPhoto = _uploadingPhoto.Contains(insp.Id);
                                var isLoadingPhotos  = _loadingPhotos.Contains(insp.Id);
                                var equipPhotos      = _photos.GetValueOrDefault(insp.Id) ?? [];

                                <div class="chk-equip-card @(insp.IsComplete ? "complete" : "") @(isOutForService ? "out-for-service" : "") @(failedItems.Any() ? "has-failures" : "")">
                                    @* Equipment header row *@
                                    <div class="chk-equip-header">
                                        <div class="chk-equip-status-dot @(insp.IsComplete ? "done" : answeredCount > 0 ? "partial" : "")"></div>
                                        <div class="chk-equip-name">
                                            <strong>@insp.EquipmentIdentifier</strong>
                                            @if (insp.SubTypeName is not null || insp.Size is not null)
                                            {
                                                <span class="chk-equip-detail">
                                                    @if (insp.SubTypeName is not null) { @insp.SubTypeName }
                                                    @if (insp.Size is not null) { <text> &middot; @insp.Size</text> }
                                                </span>
                                            }
                                            @if (isOutForService)
                                            {
                                                <span class="chk-service-tag">
                                                    <i class="fa-sharp fa-light fa-wrench"></i> @insp.ActiveServiceBooking!.ServiceProvider
                                                </span>
                                            }
                                        </div>
                                        <div class="chk-equip-right">
                                            @if (failedItems.Any())
                                            {
                                                <span class="chk-fail-count"><i class="fa-sharp fa-light fa-circle-exclamation"></i> @failedItems.Count</span>
                                            }
                                            @if (insp.PhotoCount > 0)
                                            {
                                                <span class="chk-photo-badge"><i class="fa-sharp fa-light fa-camera"></i> @insp.PhotoCount</span>
                                            }
                                            <span class="chk-equip-progress-pill @(insp.IsComplete ? "done" : "")">
                                                @if (insp.IsComplete)
                                                {
                                                    <i class="fa-sharp fa-light fa-check"></i> <text>Done</text>
                                                }
                                                else
                                                {
                                                    @answeredCount<text>/</text>@insp.Responses.Count
                                                }
                                            </span>
                                            <div class="chk-equip-actions chk-equip-actions-visible">
                                                <button class="chk-action-btn flag" @onclick="() => ShowFlagIssue(insp)" title="Flag Issue">
                                                    <i class="fa-sharp fa-light fa-flag"></i>
                                                </button>
                                                <button class="chk-action-btn service" @onclick="() => ShowServiceModal(insp)" title="Send for Service">
                                                    <i class="fa-sharp fa-light fa-truck"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>

                                    @* Checklist items *@
                                    <div class="chk-items">
                                        @foreach (var header in checklistHeaders)
                                        {
                                            var response = insp.Responses
                                                .FirstOrDefault(r => r.ChecklistItemTemplateId == header.ChecklistItemTemplateId);
                                            @if (response is not null)
                                            {
                                                <div class="chk-item @(response.Response == true ? "pass" : response.Response == false ? "fail" : "")">
                                                    <span class="chk-item-name">@header.ItemName</span>
                                                    <div class="chk-toggle">
                                                        <button class="chk-toggle-pass @(response.Response == true ? "active" : "")"
                                                                @onclick="() => SubmitResponse(insp.Id, header.ChecklistItemTemplateId, true)">
                                                            <i class="fa-sharp fa-light fa-check"></i> Pass
                                                        </button>
                                                        <button class="chk-toggle-fail @(response.Response == false ? "active" : "")"
                                                                @onclick="() => SubmitResponse(insp.Id, header.ChecklistItemTemplateId, false)">
                                                            <i class="fa-sharp fa-light fa-xmark"></i> Fail
                                                        </button>
                                                    </div>
                                                </div>
                                            }
                                        }
                                    </div>

                                    @* Failed items summary *@
                                    @if (failedItems.Any())
                                    {
                                        <div class="chk-failed-bar">
                                            <i class="fa-sharp fa-light fa-triangle-exclamation"></i>
                                            <span>Failed:</span>
                                            @foreach (var f in failedItems)
                                            {
                                                <span class="chk-failed-tag">@f.ItemName</span>
                                            }
                                        </div>
                                    }

                                    @* Notes + Photos — always visible *@
                                    <div class="chk-equip-expand">
                                        <div class="chk-comment-input">
                                            <i class="fa-sharp fa-light fa-message"></i>
                                            <textarea rows="1"
                                                      placeholder="Add a note for @insp.EquipmentIdentifier..."
                                                      value="@(_equipmentComments.GetValueOrDefault(insp.Id))"
                                                      @onchange="(e) => OnCommentChanged(insp.Id, e)" />
                                        </div>

                                        @* ── Photo section ── *@
                                        <div class="chk-photo-section">
                                            <div class="chk-photo-header">
                                                <span class="chk-photo-title">
                                                    <i class="fa-sharp fa-light fa-camera"></i> Photos
                                                    @if (equipPhotos.Count > 0)
                                                    {
                                                        <span class="chk-photo-count-badge">@equipPhotos.Count</span>
                                                    }
                                                </span>
                                                <div class="chk-photo-actions">
                                                    <InputFile id="@($"photo-input-{insp.Id}")"
                                                               OnChange="async (e) => await HandlePhotoUpload(insp.Id, e)"
                                                               accept="image/jpeg,image/png,image/webp,image/heic,image/*"
                                                               style="position:absolute;width:1px;height:1px;opacity:0;overflow:hidden;pointer-events:none" />
                                                    <button class="chk-photo-add-btn @(isUploadingPhoto ? "uploading" : "")"
                                                            @onclick="async () => await TriggerPhotoInput(insp.Id)"
                                                            disabled="@isUploadingPhoto">
                                                        @if (isUploadingPhoto)
                                                        {
                                                            <i class="fa-sharp fa-light fa-spinner-third fa-spin"></i><span>Uploading&hellip;</span>
                                                        }
                                                        else
                                                        {
                                                            <i class="fa-sharp fa-light fa-camera-plus"></i><span>Add Photo</span>
                                                        }
                                                    </button>
                                                </div>
                                            </div>
                                            @if (isLoadingPhotos)
                                            {
                                                <div class="chk-photo-loading">
                                                    <div class="ov-spinner" style="width:20px;height:20px;border-width:2px"></div>
                                                    <span>Loading photos&hellip;</span>
                                                </div>
                                            }
                                            else if (equipPhotos.Count == 0)
                                            {
                                                <div class="chk-photo-empty">
                                                    <i class="fa-sharp fa-light fa-image-slash"></i>
                                                    <span>No photos yet — tap <strong>Add Photo</strong> to capture or upload one.</span>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="chk-photo-grid">
                                                    @for (int _pi = 0; _pi < equipPhotos.Count; _pi++)
                                                    {
                                                        var _photo    = equipPhotos[_pi];
                                                        var _photoIdx = _pi;
                                                        <div class="chk-photo-thumb">
                                                            <img src="@_photo.FilePath"
                                                                 alt="Inspection photo"
                                                                 class="chk-photo-img"
                                                                 @onclick="() => OpenLightbox(insp.Id, _photoIdx)"
                                                                 loading="lazy" />
                                                            <button class="chk-photo-delete"
                                                                    title="Delete photo"
                                                                    @onclick="async () => await DeletePhoto(_photo.Id, insp.Id)">
                                                                <i class="fa-sharp fa-light fa-trash"></i>
                                                            </button>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="chk-no-items">
                                <i class="fa-sharp fa-light fa-clipboard-question"></i>
                                <span>No checklist items configured for this equipment type.</span>
                            </div>
                        }
                    </div>
                }
            </div>
        }

        @* ── Incidents section ── *@
        <div class="chk-incidents-section ov-fadeIn">
            <div class="chk-section-heading">
                <h2><i class="fa-sharp fa-light fa-triangle-exclamation"></i> Incidents (@_roundIssues.Count)</h2>
                <button class="svc-action-btn inservice" style="font-size:0.82rem;padding:0.4rem 1rem;" @onclick="OpenLogIncident">
                    <i class="fa-sharp fa-light fa-plus"></i> Log Incident
                </button>
            </div>

            @if (_roundIssues.Any())
            {
                <div class="chk-incidents-list">
                    @foreach (var issue in _roundIssues)
                    {
                        var iss = issue;
                        var isOverdue = iss.DueDate.HasValue
                            && iss.DueDate.Value < DateOnly.FromDateTime(DateTime.UtcNow)
                            && iss.Status is IssueStatus.Open or IssueStatus.InProgress;
                        <div class="inc-card" style="margin-bottom:0.6rem;">
                            <div class="inc-card-strip priority-@iss.Priority.ToString().ToLower()"></div>
                            <div class="inc-card-main" @onclick="() => GoToIncident(iss.Id)" style="cursor:pointer;">
                                <div class="inc-card-top">
                                    <div class="inc-card-title-row">
                                        <span class="inc-priority-badge priority-@iss.Priority.ToString().ToLower()">
                                            <i class="fa-sharp fa-light @PriorityIcon(iss.Priority)"></i> @iss.Priority
                                        </span>
                                        <h3>@iss.Title</h3>
                                    </div>
                                    <span class="inc-status-pill inc-status-@iss.Status.ToString().ToLower()">@iss.Status</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(iss.Description))
                                {
                                    <p class="inc-card-desc">@(iss.Description.Length > 100 ? iss.Description[..100] + "…" : iss.Description)</p>
                                }
                                <div class="inc-card-meta">
                                    @if (iss.EquipmentIdentifier is not null)
                                    {
                                        <span class="inc-meta-tag equip"><i class="fa-sharp fa-light fa-gear"></i> @iss.EquipmentIdentifier</span>
                                    }
                                    @if (iss.AssignedTo is not null)
                                    {
                                        <span class="inc-meta-tag"><i class="fa-sharp fa-light fa-user"></i> @iss.AssignedTo</span>
                                    }
                                    @if (isOverdue)
                                    {
                                        <span class="inc-meta-tag overdue"><i class="fa-sharp fa-light fa-calendar-exclamation"></i> Overdue</span>
                                    }
                                </div>
                            </div>
                            <div class="inc-card-actions" @onclick:stopPropagation="true">
                                @if (iss.Status is IssueStatus.Open or IssueStatus.InProgress)
                                {
                                    <button class="inc-action-btn resolve" @onclick="() => QuickResolveIssue(iss.Id)" title="Resolve">
                                        <i class="fa-sharp fa-light fa-check"></i>
                                        <span>Resolve</span>
                                    </button>
                                }
                                <button class="inc-action-btn view" @onclick="() => GoToIncident(iss.Id)" title="View">
                                    <i class="fa-sharp fa-light fa-chevron-right"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="chk-incidents-empty">
                    <i class="fa-sharp fa-light fa-shield-check"></i>
                    <span>No incidents logged for this inspection round.</span>
                </div>
            }
        </div>

        @* ── Comments section ── *@
        <div class="chk-comments-section ov-fadeIn">
            <h2><i class="fa-sharp fa-light fa-messages"></i> Comments (@_comments.Count)</h2>

            @if (_comments.Any())
            {
                <div class="chk-comments-list">
                    @foreach (var comment in _comments)
                    {
                        <div class="chk-comment">
                            <div class="chk-comment-avatar">
                                <i class="fa-sharp fa-light fa-user"></i>
                            </div>
                            <div class="chk-comment-body">
                                <div class="chk-comment-header">
                                    <strong>@comment.CreatedByName</strong>
                                    <span>@comment.CreatedAt.ToString("MMM dd, yyyy HH:mm")</span>
                                </div>
                                <p>@comment.Text</p>
                            </div>
                        </div>
                    }
                </div>
            }

            <div class="chk-add-comment">
                <InputTextArea @bind-Value="_newCommentText" class="form-control" rows="2"
                               placeholder="Add a comment about this inspection..." />
                <button class="btn btn-primary btn-sm" @onclick="AddComment"
                        disabled="@(string.IsNullOrWhiteSpace(_newCommentText))">
                    <i class="fa-sharp fa-light fa-paper-plane"></i> Post
                </button>
            </div>
        </div>

        @* ── Sticky footer ── *@
        <div class="chk-footer">
            <div class="chk-footer-inner">
                <div class="chk-footer-stats">
                    <span class="chk-footer-stat done"><i class="fa-sharp fa-light fa-circle-check"></i> @_completedCount inspected</span>
                    @if (_incompleteCount > 0)
                    {
                        <span class="chk-footer-stat warn"><i class="fa-sharp fa-light fa-circle-half-stroke"></i> @_incompleteCount incomplete</span>
                    }
                    @if (_failedItemCount > 0)
                    {
                        <span class="chk-footer-stat fail"><i class="fa-sharp fa-light fa-circle-exclamation"></i> @_failedItemCount failed</span>
                    }
                    @if (_outForServiceCount > 0)
                    {
                        <span class="chk-footer-stat svc"><i class="fa-sharp fa-light fa-wrench"></i> @_outForServiceCount service</span>
                    }
                </div>
                <button class="btn btn-success btn-lg" @onclick="ShowCompleteConfirmation">
                    <i class="fa-sharp fa-light fa-badge-check"></i> Complete Round
                </button>
            </div>
        </div>
    }
</div>

@* ── Flag Issue Modal ── *@
@if (_showFlagIssue)
{
    <div class="chk-modal-overlay" @onclick="() => _showFlagIssue = false">
        <div class="chk-modal ov-scaleIn" @onclick:stopPropagation>
            <div class="chk-modal-header">
                <div class="chk-modal-icon warning"><i class="fa-sharp fa-light fa-flag"></i></div>
                <div>
                    <h2>Flag Issue</h2>
                    <span class="chk-modal-sub">@_flagEquipmentIdentifier</span>
                </div>
                <button class="chk-modal-close" @onclick="() => _showFlagIssue = false"><i class="fa-sharp fa-light fa-xmark"></i></button>
            </div>
            <div class="chk-modal-body">
                <div class="form-group">
                    <label>Title</label>
                    <InputText @bind-Value="_flagIssueTitle" class="form-control" placeholder="Brief description of the issue" />
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <InputTextArea @bind-Value="_flagIssueDescription" class="form-control" rows="3" placeholder="Provide details about the issue..." />
                </div>
                <div class="form-group">
                    <label>Priority</label>
                    <div class="chk-priority-select">
                        @foreach (var p in new[] { IssuePriority.Low, IssuePriority.Medium, IssuePriority.High, IssuePriority.Critical })
                        {
                            var pv = p;
                            <button class="chk-priority-btn priority-@p.ToString().ToLower() @(_flagIssuePriority == p ? "active" : "")"
                                    @onclick="() => _flagIssuePriority = pv">
                                @p
                            </button>
                        }
                    </div>
                </div>
            </div>
            <div class="chk-modal-footer">
                <button class="btn btn-ghost" @onclick="() => _showFlagIssue = false">Cancel</button>
                <button class="btn btn-warning" @onclick="CreateFlaggedIssue">
                    <i class="fa-sharp fa-light fa-flag"></i> Create Issue
                </button>
            </div>
        </div>
    </div>
}

@* ── Service Modal ── *@
@if (_showServiceModal)
{
    <div class="chk-modal-overlay" @onclick="() => _showServiceModal = false">
        <div class="chk-modal ov-scaleIn" @onclick:stopPropagation>
            <div class="chk-modal-header">
                <div class="chk-modal-icon info"><i class="fa-sharp fa-light fa-truck"></i></div>
                <div>
                    <h2>Send for Service</h2>
                    <span class="chk-modal-sub">@_serviceEquipmentIdentifier</span>
                </div>
                <button class="chk-modal-close" @onclick="() => _showServiceModal = false"><i class="fa-sharp fa-light fa-xmark"></i></button>
            </div>
            <div class="chk-modal-body">
                <div class="form-group">
                    <label>Service Provider</label>
                    <InputText @bind-Value="_serviceProvider" class="form-control" placeholder="Service company name" />
                </div>
                <div class="form-group">
                    <label>Reason</label>
                    <InputTextArea @bind-Value="_serviceReason" class="form-control" rows="2" placeholder="Why is this equipment being sent?" />
                </div>
                <div class="form-group">
                    <label>Expected Return Date</label>
                    <InputDate @bind-Value="_serviceExpectedReturn" class="form-control" />
                </div>
                <div class="form-group">
                    <label>Notes <span class="form-hint">(optional)</span></label>
                    <InputTextArea @bind-Value="_serviceNotes" class="form-control" rows="2" />
                </div>
            </div>
            <div class="chk-modal-footer">
                <button class="btn btn-ghost" @onclick="() => _showServiceModal = false">Cancel</button>
                <button class="btn btn-primary" @onclick="CreateServiceBooking"
                        disabled="@(string.IsNullOrWhiteSpace(_serviceProvider) || string.IsNullOrWhiteSpace(_serviceReason))">
                    <i class="fa-sharp fa-light fa-truck"></i> Send for Service
                </button>
            </div>
        </div>
    </div>
}

@* ── Complete Confirmation Modal ── *@
@if (_showCompleteConfirmation)
{
    var hasIssues = _incompleteCount > 0 || _failedItemCount > 0;
    <div class="chk-modal-overlay" @onclick="() => _showCompleteConfirmation = false">
        <div class="chk-modal ov-scaleIn" @onclick:stopPropagation>
            <div class="chk-modal-header">
                <div class="chk-modal-icon @(hasIssues ? "warning" : "success")">
                    <i class="fa-sharp fa-light @(hasIssues ? "fa-triangle-exclamation" : "fa-badge-check")"></i>
                </div>
                <div>
                    <h2>@(hasIssues ? "Close with Issues" : "Complete Inspection")</h2>
                    <span class="chk-modal-sub">Round #@RoundId</span>
                </div>
                <button class="chk-modal-close" @onclick="() => _showCompleteConfirmation = false"><i class="fa-sharp fa-light fa-xmark"></i></button>
            </div>
            <div class="chk-modal-body">
                @if (hasIssues || _outForServiceCount > 0)
                {
                    <div class="chk-complete-warnings">
                        @if (_incompleteCount > 0)
                        {
                            <div class="chk-warn-item orange">
                                <i class="fa-sharp fa-light fa-circle-half-stroke"></i>
                                <span>@_incompleteCount equipment not fully inspected</span>
                            </div>
                        }
                        @if (_failedItemCount > 0)
                        {
                            <div class="chk-warn-item red">
                                <i class="fa-sharp fa-light fa-circle-exclamation"></i>
                                <span>@_failedItemCount checklist items marked as failed</span>
                            </div>
                        }
                        @if (_outForServiceCount > 0)
                        {
                            <div class="chk-warn-item blue">
                                <i class="fa-sharp fa-light fa-wrench"></i>
                                <span>@_outForServiceCount equipment out for service</span>
                            </div>
                        }
                        @if (hasIssues)
                        {
                            <p class="chk-warn-note">
                                This round will be marked as <strong>Completed with Issues</strong>
                                and remain visible in the overview until all items are resolved.
                            </p>
                        }
                    </div>
                }
                else
                {
                    <div class="chk-complete-ready">
                        <i class="fa-sharp fa-light fa-circle-check"></i>
                        <p>All equipment has been inspected and passed. Ready to complete!</p>
                    </div>
                }
            </div>
            <div class="chk-modal-footer">
                <button class="btn btn-ghost" @onclick="() => _showCompleteConfirmation = false">Cancel</button>
                <button class="btn @(hasIssues ? "btn-warning" : "btn-success")" @onclick="ConfirmCompleteRound">
                    <i class="fa-sharp fa-light @(hasIssues ? "fa-triangle-exclamation" : "fa-badge-check")"></i>
                    @(hasIssues ? "Close with Issues" : "Confirm Complete")
                </button>
            </div>
        </div>
    </div>
}

@* ── Delete Round Confirmation Modal ── *@
@if (_showDeleteConfirm)
{
    <div class="chk-modal-overlay" @onclick="() => _showDeleteConfirm = false">
        <div class="chk-modal ov-scaleIn" @onclick:stopPropagation>
            <div class="chk-modal-header">
                <div class="chk-modal-icon warning">
                    <i class="fa-sharp fa-light fa-trash"></i>
                </div>
                <div>
                    <h2>Delete Inspection Round</h2>
                    <span class="chk-modal-sub">Round #@RoundId</span>
                </div>
                <button class="chk-modal-close" @onclick="() => _showDeleteConfirm = false"><i class="fa-sharp fa-light fa-xmark"></i></button>
            </div>
            <div class="chk-modal-body">
                <div class="chk-complete-warnings">
                    <div class="chk-warning-item">
                        <i class="fa-sharp fa-light fa-triangle-exclamation"></i>
                        <span>This will permanently delete this inspection round and all its responses and photos.</span>
                    </div>
                    @if (_completedCount > 0)
                    {
                        <div class="chk-warning-item">
                            <i class="fa-sharp fa-light fa-clipboard-check"></i>
