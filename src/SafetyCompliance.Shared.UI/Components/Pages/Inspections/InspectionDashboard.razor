@page "/inspection-dashboard"
@inject IScheduleService ScheduleService
@inject NavigationManager Navigation

<div class="cal-page">
    @* ── Tab bar (matches inspections style) ── *@
    <div class="insp-tab-bar ov-fadeIn">
        <div class="insp-tabs">
            <button class="insp-tab @(_view == "calendar" ? "active" : "")" @onclick='() => _view = "calendar"'>
                <i class="fa-light fa-calendar-days"></i> Calendar
            </button>
            <button class="insp-tab @(_view == "timeline" ? "active" : "")" @onclick='() => _view = "timeline"'>
                <i class="fa-light fa-list-timeline"></i> Timeline
            </button>
        </div>
    </div>

    @if (_loading)
    {
        <div class="ov-loading"><div class="ov-spinner"></div><p>Loading&hellip;</p></div>
    }
    else
    {
        @* ── Stats row ── *@
        <div class="cal-stats ov-fadeIn">
            <div class="cal-stat">
                <div class="cal-stat-icon blue"><i class="fa-light fa-clipboard-list"></i></div>
                <div class="cal-stat-info">
                    <span class="cal-stat-value">@_stats.ScheduledThisMonth</span>
                    <span class="cal-stat-label">Scheduled</span>
                </div>
            </div>
            <div class="cal-stat">
                <div class="cal-stat-icon green"><i class="fa-light fa-circle-check"></i></div>
                <div class="cal-stat-info">
                    <span class="cal-stat-value">@_stats.CompletedThisMonth</span>
                    <span class="cal-stat-label">Completed</span>
                </div>
            </div>
            <div class="cal-stat @(_stats.OverdueInspections > 0 ? "alert" : "")">
                <div class="cal-stat-icon @(_stats.OverdueInspections > 0 ? "red" : "gray")"><i class="fa-light fa-clock"></i></div>
                <div class="cal-stat-info">
                    <span class="cal-stat-value">@_stats.OverdueInspections</span>
                    <span class="cal-stat-label">Overdue</span>
                </div>
            </div>
            <div class="cal-stat @(_stats.OpenIssues > 0 ? "alert" : "")">
                <div class="cal-stat-icon @(_stats.OpenIssues > 0 ? "amber" : "gray")"><i class="fa-light fa-triangle-exclamation"></i></div>
                <div class="cal-stat-info">
                    <span class="cal-stat-value">@_stats.OpenIssues</span>
                    <span class="cal-stat-label">Open Issues</span>
                </div>
            </div>
            <div class="cal-stat @(_stats.CriticalIssues > 0 ? "alert" : "")">
                <div class="cal-stat-icon @(_stats.CriticalIssues > 0 ? "red" : "gray")"><i class="fa-light fa-siren-on"></i></div>
                <div class="cal-stat-info">
                    <span class="cal-stat-value">@_stats.CriticalIssues</span>
                    <span class="cal-stat-label">Critical</span>
                </div>
            </div>
            <div class="cal-stat">
                <div class="cal-stat-icon green"><i class="fa-light fa-check-double"></i></div>
                <div class="cal-stat-info">
                    <span class="cal-stat-value">@_stats.ResolvedThisMonth</span>
                    <span class="cal-stat-label">Resolved</span>
                </div>
            </div>
        </div>

        @* ════════ CALENDAR VIEW ════════ *@
        @if (_view == "calendar")
        {
            <div class="cal-container ov-fadeIn">
                <div class="cal-nav">
                    <button class="cal-nav-btn" @onclick="PrevMonth">
                        <i class="fa-light fa-chevron-left"></i>
                    </button>
                    <h2 class="cal-nav-title">@_calendarMonth.ToString("MMMM yyyy")</h2>
                    <button class="cal-nav-btn" @onclick="NextMonth">
                        <i class="fa-light fa-chevron-right"></i>
                    </button>
                    <button class="cal-today-btn" @onclick="GoToToday">Today</button>
                </div>

                <div class="cal-grid">
                    @foreach (var dayName in new[] { "Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat" })
                    {
                        <div class="cal-weekday">@dayName</div>
                    }

                    @foreach (var day in _calendarDays)
                    {
                        var dayEvents = _calendarEvents.Where(e => e.Date == day.Date).ToList();
                        var isToday = day.Date == DateOnly.FromDateTime(DateTime.UtcNow);
                        <div class="cal-cell @(day.IsCurrentMonth ? "" : "other") @(isToday ? "today" : "")">
                            <span class="cal-day-num @(isToday ? "today-badge" : "")">@day.Date.Day</span>
                            <div class="cal-cell-events">
                                @foreach (var evt in dayEvents.Take(3))
                                {
                                    var e = evt;
                                    <div class="cal-evt @EventClass(e)" @onclick="() => OnCalendarEventClick(e)" title="@e.Title">
                                        <span class="cal-evt-dot"></span>
                                        <span class="cal-evt-text">@TruncateText(e.Title, 16)</span>
                                    </div>
                                }
                                @if (dayEvents.Count > 3)
                                {
                                    <div class="cal-evt-more">+@(dayEvents.Count - 3) more</div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @* ════════ TIMELINE VIEW ════════ *@
        else
        {
            <div class="cal-tl ov-fadeIn">
                @if (!_timelineItems.Any())
                {
                    <div class="ov-empty">
                        <div class="ov-empty-icon"><i class="fa-light fa-list-timeline"></i></div>
                        <h2>No upcoming items</h2>
                        <p>Create a schedule to get started.</p>
                    </div>
                }
                else
                {
                    var tlIdx = 0; DateOnly? lastDate = null;
                    @foreach (var item in _timelineItems)
                    {
                        var it = item;
                        var ti = tlIdx;
                        var isToday = it.Date == DateOnly.FromDateTime(DateTime.UtcNow);

                        @* Date separator *@
                        @if (lastDate == null || lastDate != it.Date)
                        {
                            <div class="cal-tl-date ov-fadeIn" style="animation-delay: @(ti * 0.03)s">
                                <span>@(isToday ? "Today" : it.Date.ToString("ddd, MMM dd yyyy"))</span>
                            </div>
                            lastDate = it.Date;
                        }

                        <div class="cal-tl-item @it.EventType @(it.IsOverdue ? "overdue" : "") @(isToday ? "today" : "") ov-staggerUp"
                             style="animation-delay: @(ti * 0.04)s"
                             @onclick="() => OnTimelineItemClick(it)">
                            <div class="cal-tl-marker @it.EventType">
                                @if (it.EventType == "inspection")
                                {
                                    <i class="fa-light fa-clipboard-list"></i>
                                }
                                else if (it.EventType == "issue")
                                {
                                    <i class="fa-light fa-triangle-exclamation"></i>
                                }
                                else
                                {
                                    <i class="fa-light fa-calendar-clock"></i>
                                }
                            </div>
                            <div class="cal-tl-body">
                                <div class="cal-tl-top">
                                    <h3>@it.Title</h3>
                                    <div class="cal-tl-badges">
                                        @if (it.InspectionStatus.HasValue)
                                        {
                                            <span class="status-badge status-@it.InspectionStatus.Value.ToString().ToLower()">@StatusLabel(it.InspectionStatus.Value)</span>
                                        }
                                        @if (it.IssueStatus.HasValue)
                                        {
                                            <span class="status-badge issue-@it.IssueStatus.Value.ToString().ToLower()">@it.IssueStatus</span>
                                        }
                                        @if (it.Priority.HasValue)
                                        {
                                            <span class="cal-tl-priority priority-@it.Priority.Value.ToString().ToLower()">@it.Priority</span>
                                        }
                                        @if (it.IsOverdue)
                                        {
                                            <span class="status-badge status-completedwithissues">Overdue</span>
                                        }
                                    </div>
                                </div>
                                <div class="cal-tl-meta">
                                    <span><i class="fa-light fa-industry"></i> @it.PlantName</span>
                                    @if (it.EquipmentIdentifier is not null)
                                    {
                                        <span><i class="fa-light fa-barcode"></i> @it.EquipmentIdentifier</span>
                                    }
                                </div>
                                @if (it.EventType == "inspection" && it.TotalItems > 0)
                                {
                                    var pct = (int)((double)it.CompletedItems / it.TotalItems * 100);
                                    <div class="cal-tl-progress">
                                        <div class="insp-round-bar">
                                            <div class="insp-round-bar-fill" style="width: @pct%"></div>
                                        </div>
                                        <span>@it.CompletedItems / @it.TotalItems equipment</span>
                                    </div>
                                }
                                @if (it.Description is not null)
                                {
                                    <p class="cal-tl-desc">@TruncateText(it.Description, 120)</p>
                                }
                            </div>
                        </div>
                        tlIdx++;
                    }
                }
            </div>
        }
    }
</div>

@code {
    private string _view = "calendar";
    private bool _loading = true;
    private DashboardStatsDto _stats = new(0, 0, 0, 0, 0, 0);
    private List<CalendarEventDto> _calendarEvents = [];
    private List<TimelineItemDto> _timelineItems = [];
    private List<CalendarDay> _calendarDays = [];
    private DateOnly _calendarMonth;

    protected override async Task OnInitializedAsync()
    {
        _calendarMonth = new DateOnly(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1);
        _stats = await ScheduleService.GetDashboardStatsAsync();
        await LoadCalendarEvents();
        _timelineItems = await ScheduleService.GetTimelineAsync(30);
        _loading = false;
    }

    private async Task LoadCalendarEvents()
    {
        var from = _calendarMonth.AddDays(-(int)_calendarMonth.DayOfWeek);
        var to = _calendarMonth.AddMonths(1).AddDays(-1);
        var endOfGrid = to.AddDays(6 - (int)to.DayOfWeek);
        _calendarEvents = await ScheduleService.GetCalendarEventsAsync(from, endOfGrid);
        BuildCalendarDays();
    }

    private void BuildCalendarDays()
    {
        _calendarDays = [];
        var firstOfMonth = _calendarMonth;
        var startDate = firstOfMonth.AddDays(-(int)firstOfMonth.DayOfWeek);
        var lastOfMonth = firstOfMonth.AddMonths(1).AddDays(-1);
        var endDate = lastOfMonth.AddDays(6 - (int)lastOfMonth.DayOfWeek);

        var current = startDate;
        while (current <= endDate)
        {
            _calendarDays.Add(new CalendarDay(current, current.Month == _calendarMonth.Month));
            current = current.AddDays(1);
        }
    }

    private async Task PrevMonth() { _calendarMonth = _calendarMonth.AddMonths(-1); await LoadCalendarEvents(); }
    private async Task NextMonth() { _calendarMonth = _calendarMonth.AddMonths(1); await LoadCalendarEvents(); }
    private async Task GoToToday()
    {
        _calendarMonth = new DateOnly(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1);
        await LoadCalendarEvents();
    }

    private void OnCalendarEventClick(CalendarEventDto evt)
    {
        if (evt.EventType == "inspection")
            Navigation.NavigateTo($"/inspections/{evt.Id}");
        else
            Navigation.NavigateTo("/schedules");
    }

    private void OnTimelineItemClick(TimelineItemDto item)
    {
        if (item.EventType == "inspection")
            Navigation.NavigateTo($"/inspections/{item.Id}");
        else if (item.EventType == "issue")
            Navigation.NavigateTo($"/issues/{item.Id}");
        else
            Navigation.NavigateTo("/schedules");
    }

    private static string EventClass(CalendarEventDto evt) => evt switch
    {
        { IsOverdue: true } => "overdue",
        { EventType: "inspection", InspectionStatus: InspectionStatus.Completed } => "completed",
        { EventType: "inspection", InspectionStatus: InspectionStatus.Reviewed } => "completed",
        { EventType: "inspection", InspectionStatus: InspectionStatus.CompletedWithIssues } => "has-issues",
        { EventType: "inspection" } => "inspection",
        { EventType: "scheduled" } => "scheduled",
        _ => ""
    };

    private static string StatusLabel(InspectionStatus s) => s switch
    {
        InspectionStatus.CompletedWithIssues => "Has Issues",
        _ => s.ToString()
    };

    private static string TruncateText(string text, int maxLen)
        => text.Length > maxLen ? text[..maxLen] + "…" : text;

    private record CalendarDay(DateOnly Date, bool IsCurrentMonth);
}
