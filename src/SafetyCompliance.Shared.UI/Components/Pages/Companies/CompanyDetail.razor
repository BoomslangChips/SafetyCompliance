    // ── Helpers ───────────────────────────────────────────────────────────────
    private static string GetInitials(string name)
    {
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            : name.Length >= 2 ? name[..2].ToUpper() : name.ToUpper();
    }

    private static string GetCategoryEmoji(string cat) => cat.ToLowerInvariant() switch
    {
        var c when c.Contains("fire")                             => "🔥",
        var c when c.Contains("manage") || c.Contains("admin")   => "👔",
        var c when c.Contains("medical") || c.Contains("health") => "🏥",
        var c when c.Contains("maint") || c.Contains("tech")     => "🔧",
        var c when c.Contains("secur") || c.Contains("guard")    => "🛡️",
        var c when c.Contains("contract") || c.Contains("vendor")=> "🤝",
        _ => "👤"
    };

    private static string GetCategoryColor(string cat) => cat.ToLowerInvariant() switch
    {
        var c when c.Contains("fire")                             => "#C03030",
        var c when c.Contains("manage") || c.Contains("admin")   => "#2C8880",
        var c when c.Contains("medical") || c.Contains("health") => "#1A8A50",
        var c when c.Contains("maint") || c.Contains("tech")     => "#B88A00",
        var c when c.Contains("secur") || c.Contains("guard")    => "#1A6B63",
        var c when c.Contains("contract") || c.Contains("vendor")=> "#40A8A0",
        _ => "#5A7068"
    };

