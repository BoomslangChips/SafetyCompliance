@page "/inventory"
@using SafetyCompliance.Domain.Entities
@inject IEquipmentService EquipmentService
@inject ICompanyService CompanyService
@inject IPlantService PlantService
@inject ISectionService SectionService
@inject IExcelExportService ExcelExportService
@inject IJSRuntime JS

<div class="page-header">
    <div class="page-header-left">
        <div class="page-header-icon"><i class="fa-light fa-warehouse"></i></div>
        <div class="page-header-info">
            <h1>Equipment Inventory</h1>
            <p class="page-header-sub">Manage equipment pool, assignments, and compliance</p>
        </div>
    </div>
    <div class="page-header-actions">
        @if (_selectedIds.Count > 0)
        {
            <button class="btn btn-secondary" @onclick="OpenBulkAssignModal">
                <i class="fa-light fa-link"></i> Assign Selected (@_selectedIds.Count)
            </button>
        }
        <button class="btn btn-secondary" @onclick="ExportInventoryExcel" disabled="@(_filteredEquipment is null || !_filteredEquipment.Any())">
            <i class="fa-light fa-file-excel"></i> Export
        </button>
        <button class="btn btn-primary" @onclick="OpenAddModal">
            <i class="fa-light fa-plus"></i> Add to Inventory
        </button>
    </div>
</div>

@if (!string.IsNullOrEmpty(_feedback))
{
    <div class="alert @_feedbackClass">@_feedback</div>
}

@* ── Stats Dashboard ── *@
@if (_stats is not null)
{
    <div class="cal-stats ov-fadeIn">
        <div class="cal-stat @(_activeStatCard == "total" ? "active active-blue" : "")"
             @onclick='() => ToggleStatFilter("total")'>
            <div class="cal-stat-icon blue"><i class="fa-light fa-boxes-stacked"></i></div>
            <div class="cal-stat-info">
                <span class="cal-stat-value">@_stats.TotalEquipment</span>
                <span class="cal-stat-label">Total</span>
            </div>
        </div>
        <div class="cal-stat @(_activeStatCard == "assigned" ? "active active-green" : "")"
             @onclick='() => ToggleStatFilter("assigned")'>
            <div class="cal-stat-icon green"><i class="fa-light fa-link"></i></div>
            <div class="cal-stat-info">
                <span class="cal-stat-value">@_stats.AssignedCount</span>
                <span class="cal-stat-label">Assigned</span>
            </div>
        </div>
        <div class="cal-stat @(_activeStatCard == "available" ? "active active-gray" : "")"
             @onclick='() => ToggleStatFilter("available")'>
            <div class="cal-stat-icon gray"><i class="fa-light fa-inbox"></i></div>
            <div class="cal-stat-info">
                <span class="cal-stat-value">@_stats.AvailableCount</span>
                <span class="cal-stat-label">Available</span>
            </div>
        </div>
        <div class="cal-stat @(_activeStatCard == "overdue" ? "active active-red" : "")"
             @onclick='() => ToggleStatFilter("overdue")'>
            <div class="cal-stat-icon @(_stats.OverdueComplianceCount > 0 ? "red" : "gray")">
                <i class="fa-light fa-calendar-exclamation"></i>
            </div>
            <div class="cal-stat-info">
                <span class="cal-stat-value">@_stats.OverdueComplianceCount</span>
                <span class="cal-stat-label">Overdue</span>
            </div>
        </div>
        <div class="cal-stat @(_activeStatCard == "damaged-missing" ? "active active-amber" : "")"
             @onclick='() => ToggleStatFilter("damaged-missing")'>
            <div class="cal-stat-icon @(_stats.DamagedCount + _stats.MissingCount > 0 ? "amber" : "gray")">
                <i class="fa-light fa-triangle-exclamation"></i>
            </div>
            <div class="cal-stat-info">
                <span class="cal-stat-value">@(_stats.DamagedCount + _stats.MissingCount)</span>
                <span class="cal-stat-label">Damaged / Missing</span>
            </div>
        </div>
    </div>
}

@* ── Filters ── *@
<div class="inv-filter-bar ov-fadeIn">
    <div class="form-group search-input">
        <input class="form-control" placeholder="Search identifier, serial, description..."
               @bind="_searchTerm" @bind:event="oninput" @bind:after="ApplyFilters" />
    </div>
    <div class="form-group">
        <select class="form-control" @bind="_filterStatusStr" @bind:after="ApplyFilters">
            <option value="">All Statuses</option>
            <option value="InService">In Service</option>
            <option value="OutOfService">Out of Service</option>
            <option value="Damaged">Damaged</option>
            <option value="Missing">Missing</option>
            <option value="NeedsReplacement">Needs Replacement</option>
            <option value="Retired">Retired</option>
        </select>
    </div>
    <div class="form-group">
        <select class="form-control" @bind="_filterCompliance" @bind:after="ApplyFilters">
            <option value="">All Compliance</option>
            <option value="Overdue">Overdue</option>
            <option value="DueSoon">Due Soon</option>
            <option value="OK">Up to Date</option>
        </select>
    </div>
    <div class="form-group">
        <select class="form-control" @bind="_filterAssignment" @bind:after="ApplyFilters">
            <option value="">All</option>
            <option value="assigned">Assigned@(_stats is not null ? $" ({_stats.AssignedCount})" : "")</option>
            <option value="available">Available@(_stats is not null ? $" ({_stats.AvailableCount})" : "")</option>
        </select>
    </div>
</div>
@* ── Location Filters ── *@
<div class="inv-filter-bar ov-fadeIn" style="margin-top: calc(var(--spacing-sm) * -1);">
    <div class="form-group">
        <select class="form-control" @onchange="OnFilterCompanyChanged">
            <option value="">All Companies</option>
            @foreach (var c in _filterCompanies)
            {
                <option value="@c.Id" selected="@(_filterCompanyId == c.Id)">@c.Name</option>
            }
        </select>
    </div>
    <div class="form-group">
        <select class="form-control" @onchange="OnFilterPlantChanged" disabled="@(!_filterPlants.Any())">
            <option value="">All Plants</option>
            @foreach (var p in _filterPlants)
            {
                <option value="@p.Id" selected="@(_filterPlantId == p.Id)">@p.Name</option>
            }
        </select>
    </div>
    <div class="form-group">
        <select class="form-control" @bind="_filterSectionId" @bind:after="ApplyFilters" disabled="@(!_filterSections.Any())">
            <option value="0">All Sections</option>
            @foreach (var s in _filterSections)
            {
                <option value="@s.Id">@s.Name</option>
            }
        </select>
    </div>
</div>

@* ── Type filter pills ── *@
<div class="sched-filter-pills" style="margin-bottom: var(--spacing-md);">
    <button class="sched-pill @(_filterTypeId == null ? "active" : "")"
            @onclick="() => { _filterTypeId = null; ApplyFilters(); }">
        All Types
    </button>
    @foreach (var t in _equipTypes)
    {
        var typeId = t.Id;
        <button class="sched-pill @(_filterTypeId == typeId ? "active" : "")"
                @onclick="() => { _filterTypeId = typeId; ApplyFilters(); }">
            @t.Name
        </button>
    }
</div>

@* ── Main Inventory Table ── *@
@if (_filteredEquipment is null)
{
    <p>Loading...</p>
}
else
{
    <div class="section-card ov-fadeIn">
        <div class="section-header">
            <h2>Equipment <span class="text-muted">(@_filteredEquipment.Count items)</span></h2>
        </div>

        @if (!_filteredEquipment.Any())
        {
            <div class="inv-empty-state">
                <i class="fa-light fa-box-open"></i>
                <p>No equipment matches your current filters</p>
                @if (_activeStatCard is not null || !string.IsNullOrEmpty(_searchTerm) || !string.IsNullOrEmpty(_filterStatusStr) || !string.IsNullOrEmpty(_filterCompliance) || !string.IsNullOrEmpty(_filterAssignment) || _filterTypeId.HasValue)
                {
                    <button class="btn btn-sm btn-secondary" @onclick="ClearAllFilters">
                        <i class="fa-light fa-filter-slash"></i> Clear Filters
                    </button>
                }
            </div>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width:40px;">
                            <input type="checkbox" @onchange="ToggleSelectAll"
                                   checked="@(_selectedIds.Count == _filteredEquipment.Count && _filteredEquipment.Any())" />
                        </th>
                        <th style="width:30px;" class="sortable @(_sortColumn == "Status" ? "sorted" : "")"
                            @onclick='() => SetSort("Status")'>
                            <i class="fa-light @SortIcon("Status") sort-icon @(_sortColumn == "Status" ? "active" : "")"></i>
                        </th>
                        <th class="sortable @(_sortColumn == "Identifier" ? "sorted" : "")"
                            @onclick='() => SetSort("Identifier")'>
                            Identifier
                            <i class="fa-light @SortIcon("Identifier") sort-icon @(_sortColumn == "Identifier" ? "active" : "")"></i>
                        </th>
                        <th class="sortable @(_sortColumn == "Type" ? "sorted" : "")"
                            @onclick='() => SetSort("Type")'>
                            Type
                            <i class="fa-light @SortIcon("Type") sort-icon @(_sortColumn == "Type" ? "active" : "")"></i>
                        </th>
                        <th class="sortable @(_sortColumn == "Size" ? "sorted" : "")"
                            @onclick='() => SetSort("Size")'>
                            Size
                            <i class="fa-light @SortIcon("Size") sort-icon @(_sortColumn == "Size" ? "active" : "")"></i>
                        </th>
                        <th>Serial</th>
                        <th class="sortable @(_sortColumn == "Location" ? "sorted" : "")"
                            @onclick='() => SetSort("Location")'>
                            Location
                            <i class="fa-light @SortIcon("Location") sort-icon @(_sortColumn == "Location" ? "active" : "")"></i>
                            @{ var unassignedCount = _filteredEquipment.Count(e => !e.SectionId.HasValue); }
                            @if (unassignedCount > 0)
                            {
                                <span class="th-count">@unassignedCount unassigned</span>
                            }
                        </th>
                        <th class="sortable @(_sortColumn == "Compliance" ? "sorted" : "")"
                            @onclick='() => SetSort("Compliance")'>
                            Compliance
                            <i class="fa-light @SortIcon("Compliance") sort-icon @(_sortColumn == "Compliance" ? "active" : "")"></i>
                        </th>
                        <th style="width:120px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var eq in _filteredEquipment)
                    {
                        <tr class="@(eq.OverdueChecks > 0 ? "row-alert" : "")"
                            style="cursor:pointer;" @onclick="() => OpenDetail(eq.Id)">
                            <td @onclick:stopPropagation>
                                <input type="checkbox" checked="@_selectedIds.Contains(eq.Id)"
                                       @onchange="() => ToggleSelect(eq.Id)" />
                            </td>
                            <td>
                                <span class="inv-status-dot @StatusDotClass(eq.Status)"
                                      title="@FormatStatus(eq.Status)"></span>
                            </td>
                            <td><strong>@eq.Identifier</strong></td>
                            <td>
                                @eq.EquipmentTypeName
                                @if (eq.SubTypeName != null)
                                {
                                    <span class="text-muted"> / @eq.SubTypeName</span>
                                }
                            </td>
                            <td>@(eq.Size ?? "-")</td>
                            <td>@(eq.SerialNumber ?? "-")</td>
                            <td>
                                @if (eq.SectionId.HasValue)
                                {
                                    <div class="inv-location">
                                        <span class="inv-loc-plant">@eq.PlantName</span>
                                        <i class="fa-light fa-chevron-right inv-loc-sep"></i>
                                        <span class="inv-loc-section">@eq.SectionName</span>
                                    </div>
                                }
                                else
                                {
                                    <span class="inv-loc-unassigned">
                                        <i class="fa-light fa-inbox"></i> Unassigned
                                    </span>
                                }
                            </td>
                            <td>
                                @if (eq.TotalChecks == 0)
                                {
                                    <span class="text-muted">-</span>
                                }
                                else if (eq.OverdueChecks > 0)
                                {
                                    <span class="status-badge status-completedwithissues">@eq.OverdueChecks Overdue</span>
                                }
                                else if (eq.DueSoonChecks > 0)
                                {
                                    <span class="status-badge status-inprogress">@eq.DueSoonChecks Due Soon</span>
                                }
                                else
                                {
                                    <span class="status-badge status-completed">OK</span>
                                }
                            </td>
                            <td @onclick:stopPropagation>
                                @if (eq.SectionId.HasValue)
                                {
                                    <button class="btn btn-xs btn-secondary" @onclick="() => StartUnassign(eq)" title="Unassign">
                                        <i class="fa-light fa-link-slash"></i>
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-xs btn-primary" @onclick="() => StartAssign(eq)" title="Assign">
                                        <i class="fa-light fa-link"></i>
                                    </button>
                                }
                                <button class="btn btn-xs btn-secondary" @onclick="() => OpenDetail(eq.Id)" title="Details">
                                    <i class="fa-light fa-eye"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
}

@* ── Add to Inventory Modal ── *@
@if (_showAdd)
{
    <div class="modal-overlay" @onclick="() => _showAdd = false">
        <div class="modal modal-wide" @onclick:stopPropagation>
            <h2><i class="fa-light fa-plus-circle"></i> Add Equipment to Inventory</h2>
            <EditForm Model="_addModel" OnValidSubmit="AddEquipment">
                <div class="form-row">
                    <div class="form-group">
                        <label>Equipment Type</label>
                        <select class="form-control" @onchange="OnAddTypeChanged">
                            <option value="">-- Select type --</option>
                            @foreach (var t in _equipTypes)
                            {
                                <option value="@t.Id">@t.Name</option>
                            }
                        </select>
                    </div>
                    @if (_addSubTypes.Any())
                    {
                        <div class="form-group">
                            <label>Sub-Type</label>
                            <select class="form-control" @bind="_addModel.EquipmentSubTypeId" @bind:after="OnAddSubTypeChanged">
                                <option value="">-- None --</option>
                                @foreach (var st in _addSubTypes)
                                {
                                    <option value="@st.Id">@st.Name</option>
                                }
                            </select>
                        </div>
                    }
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Quantity</label>
                        <InputNumber @bind-Value="_addModel.Quantity" class="form-control" min="1" max="100" />
                    </div>
                    @if (_addModel.Quantity <= 1)
                    {
                        <div class="form-group">
                            <label>Identifier</label>
                            <InputText @bind-Value="_addModel.IdentifierPrefix" class="form-control" placeholder="e.g. FE-001" />
                            <small class="text-muted">Unique identifier for this item</small>
                        </div>
                    }
                    else
                    {
                        <div class="form-group">
                            <label>Identifier Prefix</label>
                            <InputText @bind-Value="_addModel.IdentifierPrefix" class="form-control" placeholder="e.g. FE" />
                            <small class="text-muted">Items will be numbered: @(_addModel.IdentifierPrefix ?? "FE")-001, @(_addModel.IdentifierPrefix ?? "FE")-002, &hellip;</small>
                        </div>
                    }
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <InputText @bind-Value="_addModel.Description" class="form-control" />
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Size</label>
                        <InputText @bind-Value="_addModel.Size" class="form-control" placeholder="e.g. 9Kg" />
                    </div>
                    @if (_addModel.Quantity <= 1)
                    {
                        <div class="form-group">
                            <label>Serial Number</label>
                            <InputText @bind-Value="_addModel.SerialNumber" class="form-control" />
                        </div>
                    }
                </div>
                <div class="form-group">
                    <label>Initial Status</label>
                    <select class="form-control" @bind="_addModel.StatusStr">
                        <option value="InService">In Service</option>
                        <option value="OutOfService">Out of Service</option>
                        <option value="Damaged">Damaged</option>
                        <option value="Missing">Missing</option>
                        <option value="NeedsReplacement">Needs Replacement</option>
                        <option value="Retired">Retired</option>
                    </select>
                </div>

                @* Compliance checks section — only for single items *@
                @if (_addModel.Quantity <= 1 && _addApplicableChecks.Any())
                {
                    <div class="section-card" style="margin-top: var(--spacing-md); padding: var(--spacing-md);">
                        <h3 style="margin-bottom: var(--spacing-sm);">
                            <i class="fa-light fa-calendar-check"></i> Compliance Check Dates
                        </h3>
                        <p class="text-muted" style="font-size: 0.8rem; margin-bottom: var(--spacing-sm);">
                            Set initial dates for compliance checks. Leave blank to set later.
                        </p>
                        <table class="data-table" style="margin-top:var(--spacing-xs);">
                            <thead>
                                <tr>
                                    <th>Check</th>
                                    <th>Interval</th>
                                    <th style="width:180px;">Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var check in _addApplicableChecks)
                                {
                                    <tr>
                                        <td><strong>@check.Name</strong>@if (check.EquipmentSubTypeName != null) { <span class="text-muted"> (@check.EquipmentSubTypeName)</span> }</td>
                                        <td>@(check.IntervalMonths.HasValue ? $"{check.IntervalMonths} months" : "One-time")</td>
                                        <td>
                                            <input type="date" class="form-control" style="font-size:0.85rem;"
                                                   value="@(_addCheckDates.GetValueOrDefault(check.Id)?.ToString("yyyy-MM-dd") ?? "")"
                                                   @onchange="e => SetAddCheckDate(check.Id, e)" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                @if (_addModel.Quantity > 1 && _addApplicableChecks.Any())
                {
                    <div class="section-card" style="margin-top: var(--spacing-md); padding: var(--spacing-md); opacity: 0.7;">
                        <p class="text-muted" style="font-size: 0.82rem; margin: 0;">
                            <i class="fa-light fa-info-circle"></i>
                            Compliance check dates, serial numbers, and individual identifiers can be set per item after creation — open each item from the inventory table.
                        </p>
                    </div>
                }

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary"
                            disabled="@(_addModel.EquipmentTypeId == 0 || string.IsNullOrWhiteSpace(_addModel.IdentifierPrefix))">
                        <i class="fa-light fa-plus"></i> Add @(_addModel.Quantity > 1 ? $"{_addModel.Quantity} Items" : "Item")
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="() => _showAdd = false">Cancel</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@* ── Equipment Detail Modal ── *@
@if (_detailEquipment is not null)
{
    <div class="modal-overlay" @onclick="CloseDetail">
        <div class="modal modal-xl" @onclick:stopPropagation>
            <h2><i class="fa-light fa-clipboard-list"></i> Equipment Details</h2>

            <div class="form-row">
                <div class="form-group">
                    <label>Identifier</label>
                    <input class="form-control" @bind="_detailEditIdentifier" />
                </div>
                <div class="form-group">
                    <label>Type</label>
                    <p style="padding-top:6px;">@_detailEquipment.EquipmentTypeName@(_detailEquipment.SubTypeName != null ? $" / {_detailEquipment.SubTypeName}" : "")</p>
                </div>
                <div class="form-group">
                    <label>Status</label>
                    <select class="form-control" value="@_detailEquipment.Status" @onchange="OnDetailStatusChanged">
                        <option value="InService">In Service</option>
                        <option value="OutOfService">Out of Service</option>
                        <option value="Damaged">Damaged</option>
                        <option value="Missing">Missing</option>
                        <option value="NeedsReplacement">Needs Replacement</option>
                        <option value="Retired">Retired</option>
                    </select>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Size</label>
                    <input class="form-control" @bind="_detailEditSize" placeholder="e.g. 9Kg" />
                </div>
                <div class="form-group">
                    <label>Serial Number</label>
                    <input class="form-control" @bind="_detailEditSerial" placeholder="Enter serial number" />
                </div>
            </div>
            <div class="form-group">
                <label>Description</label>
                <input class="form-control" @bind="_detailEditDescription" placeholder="Equipment description" />
            </div>

            @if (_detailHasChanges)
            {
                <div class="form-actions" style="margin-top: var(--spacing-sm);">
                    <button class="btn btn-sm btn-primary" @onclick="SaveDetailEquipment">
                        <i class="fa-light fa-floppy-disk"></i> Save Changes
                    </button>
                    <button class="btn btn-sm btn-secondary" @onclick="ResetDetailEdits">Discard</button>
                </div>
            }

            <div class="form-group" style="margin-top: var(--spacing-md);">
                <label><i class="fa-light fa-location-dot"></i> Location</label>
                @if (_detailEquipment.SectionId.HasValue)
                {
                    <div class="inv-detail-location">
                        <i class="fa-light fa-map-pin inv-loc-icon"></i>
                        <div class="inv-location">
                            <span class="inv-loc-company">@_detailEquipment.CompanyName</span>
                            <i class="fa-light fa-chevron-right inv-loc-sep"></i>
                            <span class="inv-loc-plant">@_detailEquipment.PlantName</span>
                            <i class="fa-light fa-chevron-right inv-loc-sep"></i>
                            <span class="inv-loc-section">@_detailEquipment.SectionName</span>
                        </div>
                        <button class="btn btn-xs btn-secondary" @onclick="DetailUnassign">
                            <i class="fa-light fa-link-slash"></i> Unassign
                        </button>
                    </div>
                }
                else
                {
                    <div class="inv-detail-location">
                        <i class="fa-light fa-inbox inv-loc-icon" style="opacity:0.5;"></i>
                        <span class="inv-loc-unassigned" style="border:none; background:transparent; padding:0;">
                            <i class="fa-light fa-inbox"></i> Available in pool
                        </span>
                        <button class="btn btn-xs btn-primary" @onclick="DetailAssign">
                            <i class="fa-light fa-link"></i> Assign
                        </button>
                    </div>
                }
            </div>

            @* Compliance Checks *@
            <div class="section-card" style="margin-top: var(--spacing-md); padding: var(--spacing-md);">
                <h3><i class="fa-light fa-calendar-check"></i> Compliance Checks</h3>
                @if (!_detailEquipment.ComplianceChecks.Any())
                {
                    <p class="text-muted" style="margin-top:var(--spacing-sm);">No compliance checks configured for this equipment type.</p>
                }
                else
                {
                    <table class="data-table" style="margin-top: var(--spacing-sm);">
                        <thead>
                            <tr>
                                <th>Check</th>
                                <th>Interval</th>
                                <th>Date Set</th>
                                <th>Expiry / Due</th>
                                <th>Status</th>
                                <th style="width:220px;">Update</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var check in _detailEquipment.ComplianceChecks)
                            {
                                <tr>
                                    <td><strong>@check.CheckName</strong></td>
                                    <td>
                                        @if (check.IntervalMonths.HasValue)
                                        {
                                            <span class="eqt-check-type recurring">
                                                <i class="fa-light fa-repeat"></i> @FormatCheckInterval(check.IntervalMonths.Value)
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="eqt-check-type onetime">
                                                <i class="fa-light fa-calendar-day"></i> One-time
                                            </span>
                                        }
                                    </td>
                                    <td>@(check.DateValue?.ToString("dd MMM yyyy") ?? "-")</td>
                                    <td>@(check.ExpiryDate?.ToString("dd MMM yyyy") ?? "-")</td>
                                    <td>
                                        <span class="status-badge @ComplianceStatusClass(check.ComplianceStatus)">
                                            @check.ComplianceStatus
                                        </span>
                                    </td>
                                    <td>
                                        <div style="display:flex; gap:4px; align-items:center;">
                                            <input type="date" class="form-control" style="font-size:0.8rem; padding:2px 6px;"
                                                   value="@(_detailCheckDates.GetValueOrDefault(check.CheckId)?.ToString("yyyy-MM-dd") ?? check.DateValue?.ToString("yyyy-MM-dd") ?? "")"
                                                   @onchange="e => SetDetailCheckDate(check.CheckId, e)" />
                                            <button class="btn btn-xs btn-primary" @onclick="() => SaveDetailCheckRecord(check.CheckId)"
                                                    disabled="@(!_detailCheckDates.ContainsKey(check.CheckId))">
                                                Save
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>

            <div class="form-actions" style="margin-top: var(--spacing-lg);">
                <button type="button" class="btn btn-secondary" @onclick="CloseDetail">Close</button>
            </div>
        </div>
    </div>
}

@* ── Assign Modal (single or bulk) ── *@
@if (_showAssignModal)
{
    <div class="modal-overlay" @onclick="() => _showAssignModal = false">
        <div class="modal" @onclick:stopPropagation>
            <h2>
                @if (_bulkAssignMode)
                {
                    <text>Assign @_selectedIds.Count Items</text>
                }
                else
                {
                    <text>Assign Equipment</text>
                }
            </h2>
            @if (!_bulkAssignMode)
            {
                <p>Assigning <strong>@_assignEquipmentName</strong></p>
            }

            <div class="form-group">
                <label>Company</label>
                <select class="form-control" @onchange="OnAssignCompanyChanged">
                    <option value="">-- Select company --</option>
                    @foreach (var c in _assignCompanies)
                    {
                        <option value="@c.Id">@c.Name</option>
                    }
                </select>
            </div>

            @if (_assignPlants.Any())
            {
                <div class="form-group">
                    <label>Plant</label>
                    <select class="form-control" @onchange="OnAssignPlantChanged">
                        <option value="">-- Select plant --</option>
                        @foreach (var p in _assignPlants)
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    </select>
                </div>
            }

            @if (_assignSections.Any())
            {
                <div class="form-group">
                    <label>Section</label>
                    <select class="form-control" @bind="_assignSectionId">
                        <option value="0">-- Select section --</option>
                        @foreach (var s in _assignSections)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                </div>
            }

            <div class="form-actions">
                <button class="btn btn-primary" disabled="@(_assignSectionId == 0)" @onclick="ConfirmAssign">Assign</button>
                <button class="btn btn-secondary" @onclick="() => _showAssignModal = false">Cancel</button>
            </div>
        </div>
    </div>
}

@* ── Unassign Confirm ── *@
@if (_unassignEquipmentId.HasValue)
{
    <div class="modal-overlay" @onclick="() => _unassignEquipmentId = null">
        <div class="modal" @onclick:stopPropagation>
            <h2>Unassign Equipment</h2>
            <p>Return <strong>@_unassignEquipmentName</strong> to the inventory pool?</p>
            <div class="form-actions">
                <button class="btn btn-danger" @onclick="ConfirmUnassign">Yes, unassign</button>
                <button class="btn btn-secondary" @onclick="() => _unassignEquipmentId = null">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }
    private string _userId = string.Empty;

    // Data
    private List<InventoryEquipmentDto>? _allEquipment;
    private List<InventoryEquipmentDto>? _filteredEquipment;
    private InventoryStatsDto? _stats;
    private List<EquipmentTypeDto> _equipTypes = [];

    // Selection
    private HashSet<int> _selectedIds = [];

    // Filters
    private int? _filterTypeId;
    private string _filterStatusStr = string.Empty;
    private string _filterCompliance = string.Empty;
    private string _filterAssignment = string.Empty;
    private string _searchTerm = string.Empty;
    private string? _activeStatCard;

    // Location filters
    private List<CompanyDto> _filterCompanies = [];
    private List<PlantDto> _filterPlants = [];
    private List<SectionDto> _filterSections = [];
    private int? _filterCompanyId;
    private int? _filterPlantId;
    private int _filterSectionId;

    // Sorting
    private string _sortColumn = "Identifier";
    private bool _sortAscending = true;

    // Feedback
    private string _feedback = string.Empty;
    private string _feedbackClass = "alert-success";

    // Add modal
    private bool _showAdd;
    private AddEquipmentModel _addModel = new();
    private List<EquipmentSubTypeDto> _addSubTypes = [];
    private List<EquipmentCheckDto> _addApplicableChecks = [];
    private Dictionary<int, DateOnly?> _addCheckDates = [];

    // Detail modal
    private EquipmentDetailDto? _detailEquipment;
    private Dictionary<int, DateOnly?> _detailCheckDates = [];
    private string _detailEditIdentifier = string.Empty;
    private string _detailEditDescription = string.Empty;
    private string _detailEditSize = string.Empty;
    private string _detailEditSerial = string.Empty;

    // Assign modal
    private bool _showAssignModal;
    private int? _assignEquipmentId;
    private string _assignEquipmentName = string.Empty;
    private bool _bulkAssignMode;
    private List<CompanyDto> _assignCompanies = [];
    private List<PlantDto> _assignPlants = [];
    private List<SectionDto> _assignSections = [];
    private int _assignSectionId;

    // Unassign
    private int? _unassignEquipmentId;
    private string _unassignEquipmentName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var state = await AuthState;
            _userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        }
        _equipTypes = await EquipmentService.GetEquipmentTypesAsync();
        _filterCompanies = await CompanyService.GetAllCompaniesAsync();
        await Reload();
    }

    private async Task Reload()
    {
        // Parse filters
        EquipmentStatus? statusFilter = null;
        if (Enum.TryParse<EquipmentStatus>(_filterStatusStr, out var parsed))
            statusFilter = parsed;

        bool? isAssigned = _filterAssignment switch
        {
            "assigned" => true,
            "available" => false,
            _ => null
        };

        _allEquipment = await EquipmentService.GetInventoryAsync(
            _filterTypeId, statusFilter,
            string.IsNullOrEmpty(_filterCompliance) ? null : _filterCompliance,
            string.IsNullOrEmpty(_searchTerm) ? null : _searchTerm,
            isAssigned);

        // Client-side filters
        IEnumerable<InventoryEquipmentDto> filtered = _allEquipment;

        // "Damaged + Missing" combined stat card
        if (_activeStatCard == "damaged-missing")
            filtered = filtered.Where(e => e.Status == EquipmentStatus.Damaged || e.Status == EquipmentStatus.Missing);

        // Location cascade filters (client-side)
        if (_filterCompanyId.HasValue)
            filtered = filtered.Where(e => e.CompanyId == _filterCompanyId.Value);
        if (_filterPlantId.HasValue)
            filtered = filtered.Where(e => e.PlantId == _filterPlantId.Value);
        if (_filterSectionId > 0)
            filtered = filtered.Where(e => e.SectionId == _filterSectionId);

        _filteredEquipment = filtered.ToList();

        ApplySort();
        _stats = await EquipmentService.GetInventoryStatsAsync();
        _selectedIds.Clear();
    }

    private async void ApplyFilters()
    {
        await Reload();
        StateHasChanged();
    }

    // ── Sorting ──

    private void SetSort(string column)
    {
        if (_sortColumn == column)
            _sortAscending = !_sortAscending;
        else
        {
            _sortColumn = column;
            _sortAscending = true;
        }
        ApplySort();
    }

    private void ApplySort()
    {
        if (_filteredEquipment is null) return;

        _filteredEquipment = _sortColumn switch
        {
            "Identifier" => _sortAscending
                ? _filteredEquipment.OrderBy(e => e.Identifier).ToList()
                : _filteredEquipment.OrderByDescending(e => e.Identifier).ToList(),
            "Type" => _sortAscending
                ? _filteredEquipment.OrderBy(e => e.EquipmentTypeName).ThenBy(e => e.SubTypeName).ToList()
                : _filteredEquipment.OrderByDescending(e => e.EquipmentTypeName).ThenByDescending(e => e.SubTypeName).ToList(),
            "Size" => _sortAscending
                ? _filteredEquipment.OrderBy(e => e.Size ?? "").ToList()
                : _filteredEquipment.OrderByDescending(e => e.Size ?? "").ToList(),
            "Status" => _sortAscending
                ? _filteredEquipment.OrderBy(e => e.Status).ToList()
                : _filteredEquipment.OrderByDescending(e => e.Status).ToList(),
            "Location" => _sortAscending
                ? _filteredEquipment.OrderBy(e => e.SectionId.HasValue ? 0 : 1).ThenBy(e => e.CompanyName).ThenBy(e => e.PlantName).ThenBy(e => e.SectionName).ToList()
                : _filteredEquipment.OrderBy(e => e.SectionId.HasValue ? 1 : 0).ThenByDescending(e => e.CompanyName).ThenByDescending(e => e.PlantName).ThenByDescending(e => e.SectionName).ToList(),
            "Compliance" => _sortAscending
                ? _filteredEquipment.OrderByDescending(e => e.OverdueChecks).ThenByDescending(e => e.DueSoonChecks).ToList()
                : _filteredEquipment.OrderBy(e => e.OverdueChecks).ThenBy(e => e.DueSoonChecks).ToList(),
            _ => _filteredEquipment
        };
    }

    private string SortIcon(string column)
    {
        if (_sortColumn != column) return "fa-sort";
        return _sortAscending ? "fa-sort-up" : "fa-sort-down";
    }

    // ── Stat Card Filters ──

    private void ToggleStatFilter(string card)
    {
        if (_activeStatCard == card)
        {
            // Deactivate — clear all filters
            ClearAllFilters();
            return;
        }

        // Reset filters first
        _filterStatusStr = string.Empty;
        _filterCompliance = string.Empty;
        _filterAssignment = string.Empty;
        _searchTerm = string.Empty;
        _filterTypeId = null;
        _activeStatCard = card;

        switch (card)
        {
            case "total":
                break; // Show all — filters already cleared
            case "assigned":
                _filterAssignment = "assigned";
                break;
            case "available":
                _filterAssignment = "available";
                break;
            case "overdue":
                _filterCompliance = "Overdue";
                break;
            case "damaged-missing":
                break; // Handled in Reload with client-side filter
        }

        ApplyFilters();
    }

    private void ClearAllFilters()
    {
        _activeStatCard = null;
        _filterStatusStr = string.Empty;
        _filterCompliance = string.Empty;
        _filterAssignment = string.Empty;
        _searchTerm = string.Empty;
        _filterTypeId = null;
        _filterCompanyId = null;
        _filterPlantId = null;
        _filterSectionId = 0;
        _filterPlants = [];
        _filterSections = [];
        ApplyFilters();
    }

    // ── Location Cascade Filters ──

    private async Task OnFilterCompanyChanged(ChangeEventArgs e)
    {
        _filterCompanyId = int.TryParse(e.Value?.ToString(), out var id) && id > 0 ? id : null;
        _filterPlants = _filterCompanyId.HasValue
            ? await PlantService.GetPlantsByCompanyAsync(_filterCompanyId.Value) : [];
        _filterPlantId = null;
        _filterSections = [];
        _filterSectionId = 0;
        ApplyFilters();
    }

    private async Task OnFilterPlantChanged(ChangeEventArgs e)
    {
        _filterPlantId = int.TryParse(e.Value?.ToString(), out var id) && id > 0 ? id : null;
        _filterSections = _filterPlantId.HasValue
            ? await SectionService.GetSectionsByPlantAsync(_filterPlantId.Value) : [];
        _filterSectionId = 0;
        ApplyFilters();
    }

    // ── Excel Export ──

    private async Task ExportInventoryExcel()
    {
        if (_filteredEquipment is null || !_filteredEquipment.Any()) return;

        var bytes = ExcelExportService.ExportInventory(_filteredEquipment);
        var base64 = Convert.ToBase64String(bytes);
        var name = $"Equipment-Inventory-{DateTime.Today:yyyy-MM-dd}.xlsx";
        await JS.InvokeVoidAsync("downloadExcel", name, base64);
    }

    // ── Selection ──

    private void ToggleSelect(int id)
    {
        if (!_selectedIds.Remove(id))
            _selectedIds.Add(id);
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        if (_filteredEquipment is null) return;
        if (e.Value is true)
            _selectedIds = _filteredEquipment.Select(eq => eq.Id).ToHashSet();
        else
            _selectedIds.Clear();
    }

    // ── Add to Inventory ──

    private void OpenAddModal()
    {
        _showAdd = true;
        _addModel = new();
        _addSubTypes = [];
        _addApplicableChecks = [];
        _addCheckDates = [];
    }

    private async Task OnAddTypeChanged(ChangeEventArgs e)
    {
        _addModel.EquipmentTypeId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        _addModel.EquipmentSubTypeId = null;
        _addSubTypes = _addModel.EquipmentTypeId > 0
            ? await EquipmentService.GetSubTypesByTypeAsync(_addModel.EquipmentTypeId)
            : [];
        await LoadAddApplicableChecks();
    }

    private async Task OnAddSubTypeChanged()
    {
        await LoadAddApplicableChecks();
    }

    private async Task LoadAddApplicableChecks()
    {
        if (_addModel.EquipmentTypeId > 0)
        {
            _addApplicableChecks = await EquipmentService.GetApplicableChecksAsync(
                _addModel.EquipmentTypeId, _addModel.EquipmentSubTypeId);
            _addCheckDates = [];
        }
        else
        {
            _addApplicableChecks = [];
            _addCheckDates = [];
        }
    }

    private void SetAddCheckDate(int checkId, ChangeEventArgs e)
    {
        if (DateOnly.TryParse(e.Value?.ToString(), out var date))
            _addCheckDates[checkId] = date;
        else
            _addCheckDates.Remove(checkId);
    }

    private async Task AddEquipment()
    {
        var status = Enum.TryParse<EquipmentStatus>(_addModel.StatusStr, out var s) ? s : EquipmentStatus.InService;

        var created = await EquipmentService.CreateInventoryEquipmentBulkAsync(
            new EquipmentInventoryCreateDto(
                _addModel.EquipmentTypeId, _addModel.EquipmentSubTypeId,
                _addModel.IdentifierPrefix, _addModel.Quantity,
                _addModel.Description, _addModel.Size, _addModel.SerialNumber,
                status),
            _userId);

        // Save compliance check dates for each created item
        var checkDatesToSave = _addCheckDates
            .Where(kv => kv.Value.HasValue)
            .Select(kv => new EquipmentCheckRecordUpsertDto(0, kv.Key, kv.Value!.Value, null))
            .ToList();

        if (checkDatesToSave.Any())
        {
            foreach (var eq in created)
            {
                await EquipmentService.BulkUpsertCheckRecordsAsync(eq.Id, checkDatesToSave, _userId);
            }
        }

        _showAdd = false;
        await Reload();
        ShowFeedback($"{created.Count} item{(created.Count > 1 ? "s" : "")} added to inventory.", true);
    }

    // ── Detail Modal ──

    private async Task OpenDetail(int equipmentId)
    {
        _detailEquipment = await EquipmentService.GetEquipmentDetailAsync(equipmentId);
        _detailCheckDates = [];
        InitDetailEdits();
    }

    private void CloseDetail() => _detailEquipment = null;

    private void InitDetailEdits()
    {
        if (_detailEquipment is null) return;
        _detailEditIdentifier  = _detailEquipment.Identifier;
        _detailEditDescription = _detailEquipment.Description ?? string.Empty;
        _detailEditSize        = _detailEquipment.Size ?? string.Empty;
        _detailEditSerial      = _detailEquipment.SerialNumber ?? string.Empty;
    }

    private bool _detailHasChanges =>
        _detailEquipment is not null && (
            _detailEditIdentifier != _detailEquipment.Identifier ||
            _detailEditDescription != (_detailEquipment.Description ?? string.Empty) ||
            _detailEditSize != (_detailEquipment.Size ?? string.Empty) ||
            _detailEditSerial != (_detailEquipment.SerialNumber ?? string.Empty));

    private void ResetDetailEdits() => InitDetailEdits();

    private async Task SaveDetailEquipment()
    {
        if (_detailEquipment is null) return;
        await EquipmentService.UpdateEquipmentAsync(new EquipmentUpdateDto(
            _detailEquipment.Id,
            _detailEquipment.EquipmentTypeId,
            _detailEquipment.EquipmentSubTypeId,
            _detailEditIdentifier,
            string.IsNullOrWhiteSpace(_detailEditDescription) ? null : _detailEditDescription,
            string.IsNullOrWhiteSpace(_detailEditSize) ? null : _detailEditSize,
            string.IsNullOrWhiteSpace(_detailEditSerial) ? null : _detailEditSerial,
            _detailEquipment.NextServiceDate,
            0,
            _detailEquipment.IsActive), _userId);

        _detailEquipment = await EquipmentService.GetEquipmentDetailAsync(_detailEquipment.Id);
        InitDetailEdits();
        await Reload();
        ShowFeedback("Equipment updated.", true);
    }

    private async Task OnDetailStatusChanged(ChangeEventArgs e)
    {
        if (_detailEquipment is null) return;
        if (Enum.TryParse<EquipmentStatus>(e.Value?.ToString(), out var newStatus))
        {
            await EquipmentService.UpdateEquipmentStatusAsync(
                new EquipmentStatusUpdateDto(_detailEquipment.Id, newStatus, null), _userId);
            _detailEquipment = await EquipmentService.GetEquipmentDetailAsync(_detailEquipment.Id);
            await Reload();
        }
    }

    private void SetDetailCheckDate(int checkId, ChangeEventArgs e)
    {
        if (DateOnly.TryParse(e.Value?.ToString(), out var date))
            _detailCheckDates[checkId] = date;
        else
            _detailCheckDates.Remove(checkId);
    }

    private async Task SaveDetailCheckRecord(int checkId)
    {
        if (_detailEquipment is null || !_detailCheckDates.TryGetValue(checkId, out var date) || !date.HasValue) return;

        await EquipmentService.UpsertCheckRecordAsync(
            new EquipmentCheckRecordUpsertDto(_detailEquipment.Id, checkId, date.Value, null), _userId);

        _detailCheckDates.Remove(checkId);
        _detailEquipment = await EquipmentService.GetEquipmentDetailAsync(_detailEquipment.Id);
        await Reload();
    }

    private async Task DetailAssign()
    {
        if (_detailEquipment is null) return;
        _assignEquipmentId = _detailEquipment.Id;
        _assignEquipmentName = _detailEquipment.Identifier;
        _bulkAssignMode = false;
        _assignCompanies = await CompanyService.GetAllCompaniesAsync();
        _assignPlants = [];
        _assignSections = [];
        _assignSectionId = 0;
        _showAssignModal = true;
        CloseDetail();
    }

    private async Task DetailUnassign()
    {
        if (_detailEquipment is null) return;
        await EquipmentService.UnassignEquipmentAsync(
            new UnassignEquipmentDto(_detailEquipment.Id), _userId);
        _detailEquipment = await EquipmentService.GetEquipmentDetailAsync(_detailEquipment.Id);
        await Reload();
        ShowFeedback("Equipment returned to inventory pool.", true);
    }

    // ── Assign ──

    private async Task StartAssign(InventoryEquipmentDto eq)
    {
        _assignEquipmentId = eq.Id;
        _assignEquipmentName = eq.Identifier;
        _bulkAssignMode = false;
        _assignCompanies = await CompanyService.GetAllCompaniesAsync();
        _assignPlants = [];
        _assignSections = [];
        _assignSectionId = 0;
        _showAssignModal = true;
    }

    private async Task OpenBulkAssignModal()
    {
        _bulkAssignMode = true;
        _assignEquipmentId = null;
        _assignCompanies = await CompanyService.GetAllCompaniesAsync();
        _assignPlants = [];
        _assignSections = [];
        _assignSectionId = 0;
        _showAssignModal = true;
    }

    private async Task OnAssignCompanyChanged(ChangeEventArgs e)
    {
        var companyId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        _assignPlants = companyId > 0 ? await PlantService.GetPlantsByCompanyAsync(companyId) : [];
        _assignSections = [];
        _assignSectionId = 0;
    }

    private async Task OnAssignPlantChanged(ChangeEventArgs e)
    {
        var plantId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        _assignSections = plantId > 0 ? await SectionService.GetSectionsByPlantAsync(plantId) : [];
        _assignSectionId = 0;
    }

    private async Task ConfirmAssign()
    {
        if (_assignSectionId == 0) return;

        if (_bulkAssignMode)
        {
            await EquipmentService.BulkAssignEquipmentAsync(_selectedIds.ToList(), _assignSectionId, _userId);
            ShowFeedback($"{_selectedIds.Count} items assigned.", true);
        }
        else if (_assignEquipmentId.HasValue)
        {
            await EquipmentService.AssignEquipmentAsync(
                new AssignEquipmentDto(_assignEquipmentId.Value, _assignSectionId), _userId);
            ShowFeedback("Equipment assigned.", true);
        }

        _showAssignModal = false;
        await Reload();
    }

    // ── Unassign ──

    private void StartUnassign(InventoryEquipmentDto eq)
    {
        _unassignEquipmentId = eq.Id;
        _unassignEquipmentName = eq.Identifier;
    }

    private async Task ConfirmUnassign()
    {
        if (!_unassignEquipmentId.HasValue) return;
        await EquipmentService.UnassignEquipmentAsync(
            new UnassignEquipmentDto(_unassignEquipmentId.Value), _userId);
        _unassignEquipmentId = null;
        await Reload();
        ShowFeedback("Equipment returned to inventory pool.", true);
    }

    // ── Helpers ──

    private void ShowFeedback(string msg, bool success)
    {
        _feedback = msg;
        _feedbackClass = success ? "alert-success" : "alert-danger";
    }

    private static string FormatStatus(EquipmentStatus s) => s switch
    {
        EquipmentStatus.InService => "In Service",
        EquipmentStatus.OutOfService => "Out of Service",
        EquipmentStatus.Damaged => "Damaged",
        EquipmentStatus.Missing => "Missing",
        EquipmentStatus.NeedsReplacement => "Needs Replacement",
        EquipmentStatus.Retired => "Retired",
        _ => s.ToString()
    };

    private static string StatusDotClass(EquipmentStatus s) => s switch
    {
        EquipmentStatus.InService => "dot-green",
        EquipmentStatus.Damaged => "dot-red",
        EquipmentStatus.Missing => "dot-orange",
        EquipmentStatus.NeedsReplacement => "dot-amber",
        EquipmentStatus.OutOfService => "dot-gray",
        EquipmentStatus.Retired => "dot-gray",
        _ => "dot-gray"
    };

    private static string FormatCheckInterval(int months) => months switch
    {
        1  => "Monthly",
        2  => "Every 2 months",
        3  => "Quarterly",
        6  => "Every 6 months",
        12 => "Annually",
        24 => "Every 2 years",
        36 => "Every 3 years",
        48 => "Every 4 years",
        60 => "Every 5 years",
        _ when months % 12 == 0 => $"Every {months / 12} years",
        _ => $"Every {months} months"
    };

    private static string ComplianceStatusClass(string status) => status switch
    {
        "OK" => "status-completed",
        "Due Soon" => "status-inprogress",
        "Overdue" => "status-completedwithissues",
        "Not Set" => "status-draft",
        _ => "status-draft"
    };

    private class AddEquipmentModel
    {
        public int EquipmentTypeId { get; set; }
        public int? EquipmentSubTypeId { get; set; }
        public string IdentifierPrefix { get; set; } = string.Empty;
        public int Quantity { get; set; } = 1;
        public string? Description { get; set; }
        public string? Size { get; set; }
        public string? SerialNumber { get; set; }
        public string StatusStr { get; set; } = "InService";
    }
}
