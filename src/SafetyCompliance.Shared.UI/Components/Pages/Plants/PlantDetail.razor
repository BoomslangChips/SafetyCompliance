    protected override async Task OnInitializedAsync()
    {
        _equipmentTypes = await EquipmentService.GetEquipmentTypesAsync();
        await LoadData();
    }

    private async Task LoadData()
    {
        _plant    = await PlantService.GetPlantByIdAsync(PlantId);
        _sections = await SectionService.GetSectionsByPlantAsync(PlantId);
        _contacts = await PlantService.GetContactsAsync(PlantId);

        _equipmentBySection.Clear();
        foreach (var sect in _sections)
            _equipmentBySection[sect.Id] = await EquipmentService.GetEquipmentBySectionAsync(sect.Id, includeInactive: true);
    }

    // ═══════════════════════════════════════════════════════
    // Contacts CRUD
    // ═══════════════════════════════════════════════════════
    private void ShowAddContact()
    {
        _contactCreate = new();
        _showAddContact = true;
    }

    private async Task CreateContact()
    {
        if (string.IsNullOrWhiteSpace(_contactCreate.Name) || string.IsNullOrWhiteSpace(_contactCreate.Category)) return;

        var dto = new PlantContactCreateDto(
            PlantId,
            _contactCreate.Category,
            _contactCreate.Name,
            _contactCreate.Role,
            _contactCreate.Phone,
            _contactCreate.Email,
            _contactCreate.Notes,
            _contactCreate.IsPrimary);

        await PlantService.AddContactAsync(dto, "current-user");
        _contacts = await PlantService.GetContactsAsync(PlantId);
        _showAddContact = false;
        _contactCreate  = new();
    }

    private void StartEditContact(PlantContactDto c)
    {
        _editContactId = c.Id;
        _contactEdit   = new ContactModel
        {
            Category  = c.Category,
            Name      = c.Name,
            Role      = c.Role,
            Phone     = c.Phone,
            Email     = c.Email,
            Notes     = c.Notes,
            IsPrimary = c.IsPrimary
        };
        _showEditContact = true;
    }

    private async Task UpdateContact()
    {
        if (string.IsNullOrWhiteSpace(_contactEdit.Name) || string.IsNullOrWhiteSpace(_contactEdit.Category)) return;

        var dto = new PlantContactUpdateDto(
            _editContactId,
            _contactEdit.Category,
            _contactEdit.Name,
            _contactEdit.Role,
            _contactEdit.Phone,
            _contactEdit.Email,
            _contactEdit.Notes,
            _contactEdit.IsPrimary);

        await PlantService.UpdateContactAsync(dto, "current-user");
        _contacts        = await PlantService.GetContactsAsync(PlantId);
        _showEditContact = false;
        _contactEdit     = new();
    }

    private async Task ConfirmDeleteContact()
    {
        if (_deleteContactId.HasValue)
        {
            await PlantService.DeleteContactAsync(_deleteContactId.Value);
            _contacts      = await PlantService.GetContactsAsync(PlantId);
            _deleteContactId = null;
        }
    }

    // ═══════════════════════════════════════════════════════
    // Section CRUD
    // ═══════════════════════════════════════════════════════
    private async Task CreateSection()
    {
        var maxOrder = _sections.Any() ? _sections.Max(s => s.SortOrder) + 1 : 1;
        var dto = new SectionCreateDto(PlantId, _sectionCreate.Name, _sectionCreate.Description, maxOrder, _sectionCreate.PhotoBase64, _sectionCreate.PhotoFileName);
        await SectionService.CreateSectionAsync(dto, "current-user");
        await LoadData();
        _showCreateSection = false;
        _sectionCreate     = new();
    }

    private void StartEditSection(SectionDto sect)
    {
        _editSectionId        = sect.Id;
        _editSectionSortOrder = sect.SortOrder;
        _sectionEdit = new SectionEditModel
        {
            Name        = sect.Name,
            Description = sect.Description,
            IsActive    = sect.IsActive,
            PhotoBase64 = sect.PhotoBase64,
            PhotoFileName = sect.PhotoFileName
        };
        _showEditSection = true;
    }

    private async Task UpdateSection()
    {
        var dto = new SectionUpdateDto(_editSectionId, _sectionEdit.Name, _sectionEdit.Description, _editSectionSortOrder, _sectionEdit.IsActive, _sectionEdit.PhotoBase64, _sectionEdit.PhotoFileName);
        await SectionService.UpdateSectionAsync(dto, "current-user");
        await LoadData();
        _showEditSection = false;
        _sectionEdit     = new();
    }

    private async Task OnCreateSectionPhotoSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        var buffer = new byte[file.Size];
        await file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024).ReadAsync(buffer);
        _sectionCreate.PhotoBase64  = Convert.ToBase64String(buffer);
        _sectionCreate.PhotoFileName = file.Name;
    }

    private async Task OnEditSectionPhotoSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        var buffer = new byte[file.Size];
        await file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024).ReadAsync(buffer);
        _sectionEdit.PhotoBase64  = Convert.ToBase64String(buffer);
        _sectionEdit.PhotoFileName = file.Name;
    }

