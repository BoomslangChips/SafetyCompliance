    private static string GetInitials(string name)
    {
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            : name.Length >= 2 ? name[..2].ToUpper() : name.ToUpper();
    }

    private static string GetCategoryEmoji(string category) => category.ToLowerInvariant() switch
    {
        var c when c.Contains("fire")                                => "🔥",
        var c when c.Contains("manage") || c.Contains("exec")
                || c.Contains("director") || c.Contains("admin")    => "👔",
        var c when c.Contains("medical") || c.Contains("health")
                || c.Contains("nurse") || c.Contains("doctor")      => "🏥",
        var c when c.Contains("maint") || c.Contains("tech")
                || c.Contains("engin") || c.Contains("mechanic")    => "🔧",
        var c when c.Contains("secur") || c.Contains("guard")
                || c.Contains("police")                             => "🛡️",
        var c when c.Contains("contract") || c.Contains("vendor")
                || c.Contains("supplier")                           => "🤝",
        _ => "👤"
    };

    private static string GetCategoryColor(string category) => category.ToLowerInvariant() switch
    {
        var c when c.Contains("fire")                                => "#ef4444",
        var c when c.Contains("manage") || c.Contains("exec")
                || c.Contains("director") || c.Contains("admin")    => "#4f46e5",
        var c when c.Contains("medical") || c.Contains("health")
                || c.Contains("nurse") || c.Contains("doctor")      => "#059669",
        var c when c.Contains("maint") || c.Contains("tech")
                || c.Contains("engin") || c.Contains("mechanic")    => "#d97706",
        var c when c.Contains("secur") || c.Contains("guard")
                || c.Contains("police")                             => "#7c3aed",
        var c when c.Contains("contract") || c.Contains("vendor")
                || c.Contains("supplier")                           => "#0891b2",
        _ => "#6b7280"
    };

