@page "/plants/{PlantId:int}"
@inject IPlantService PlantService
@inject ISectionService SectionService
@inject IEquipmentService EquipmentService
@inject NavigationManager Navigation

@if (_plant is null)
{
    <p>Loading...</p>
}
else
{
    <div class="page-header">
        <div>
            <button class="btn btn-link" @onclick="GoBack">&larr; Back</button>
            <h1>@_plant.Name</h1>
            @if (_plant.Description is not null)
            {
                <p class="card-subtitle">@_plant.Description</p>
            }
            @if (_plant.ContactName is not null)
            {
                <p class="card-subtitle">Contact: @_plant.ContactName @(_plant.ContactPhone is not null ? $"- {_plant.ContactPhone}" : "") @(_plant.ContactEmail is not null ? $"- {_plant.ContactEmail}" : "")</p>
            }
        </div>
        <button class="btn btn-primary" @onclick="() => _showCreateSection = true">Add Section</button>
    </div>

    @if (_plant.PhotoBase64 is not null)
    {
        <div class="entity-photo">
            <img src="@($"data:image/jpeg;base64,{_plant.PhotoBase64}")" alt="@_plant.Name" />
        </div>
    }

    @* Create Section Modal *@
    @if (_showCreateSection)
    {
        <div class="modal-overlay" @onclick="() => _showCreateSection = false">
            <div class="modal" @onclick:stopPropagation>
                <h2>Add Section</h2>
                <EditForm Model="_sectionCreate" OnValidSubmit="CreateSection">
                    <div class="form-group">
                        <label>Name</label>
                        <InputText @bind-Value="_sectionCreate.Name" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Description</label>
                        <InputText @bind-Value="_sectionCreate.Description" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Photo</label>
                        <InputFile OnChange="OnCreateSectionPhotoSelected" class="form-control" accept="image/*" />
                        @if (_sectionCreate.PhotoBase64 is not null)
                        {
                            <div class="photo-preview">
                                <img src="@($"data:image/jpeg;base64,{_sectionCreate.PhotoBase64}")" alt="Preview" />
                                <button type="button" class="btn btn-sm btn-secondary" @onclick="() => { _sectionCreate.PhotoBase64 = null; _sectionCreate.PhotoFileName = null; }">Remove</button>
                            </div>
                        }
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Save</button>
                        <button type="button" class="btn btn-secondary" @onclick="() => _showCreateSection = false">Cancel</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    @* Edit Section Modal *@
    @if (_showEditSection)
    {
        <div class="modal-overlay" @onclick="() => _showEditSection = false">
            <div class="modal" @onclick:stopPropagation>
                <h2>Edit Section</h2>
                <EditForm Model="_sectionEdit" OnValidSubmit="UpdateSection">
                    <div class="form-group">
                        <label>Name</label>
                        <InputText @bind-Value="_sectionEdit.Name" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Description</label>
                        <InputText @bind-Value="_sectionEdit.Description" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Photo</label>
                        <InputFile OnChange="OnEditSectionPhotoSelected" class="form-control" accept="image/*" />
                        @if (_sectionEdit.PhotoBase64 is not null)
                        {
                            <div class="photo-preview">
                                <img src="@($"data:image/jpeg;base64,{_sectionEdit.PhotoBase64}")" alt="Preview" />
                                <button type="button" class="btn btn-sm btn-secondary" @onclick="() => { _sectionEdit.PhotoBase64 = null; _sectionEdit.PhotoFileName = null; }">Remove</button>
                            </div>
                        }
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Update</button>
                        <button type="button" class="btn btn-secondary" @onclick="() => _showEditSection = false">Cancel</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    @* Add Equipment Modal *@
    @if (_showAddEquipment)
    {
        <div class="modal-overlay" @onclick="CloseAddEquipmentModal">
            <div class="modal modal-wide" @onclick:stopPropagation>
                <h2>Add Equipment to @(_addEquipmentSectionName)</h2>
                <EditForm Model="_equipmentCreate" OnValidSubmit="CreateEquipment">
                    <div class="form-row">
                        <div class="form-group">
                            <label>Identifier (e.g. FE-01)</label>
                            <InputText @bind-Value="_equipmentCreate.Identifier" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Equipment Type</label>
                            <select class="form-control" @onchange="OnCreateEquipmentTypeChanged">
                                <option value="">-- Select Type --</option>
                                @foreach (var eqType in _equipmentTypes)
                                {
                                    <option value="@eqType.Id">@eqType.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    @if (_createSubTypes.Any())
                    {
                        <div class="form-group">
                            <label>Sub-Type</label>
                            <select class="form-control" @onchange="OnCreateSubTypeChanged">
                                <option value="">-- Select Sub-Type (optional) --</option>
                                @foreach (var st in _createSubTypes)
                                {
                                    <option value="@st.Id">@st.Name</option>
                                }
                            </select>
                        </div>
                    }
                    <div class="form-row">
                        <div class="form-group">
                            <label>Size / Spec</label>
                            @if (_equipmentCreate.EquipmentSubTypeId.HasValue)
                            {
                                <input type="text" class="form-control form-control-muted" readonly value="@_equipmentCreate.Size" />
                                <small class="form-hint">Auto-set from sub-type</small>
                            }
                            else
                            {
                                <InputText @bind-Value="_equipmentCreate.Size" class="form-control" placeholder="e.g. 9kg, 30m, 500ml" />
                            }
                        </div>
                        <div class="form-group">
                            <label>Serial Number</label>
                            <InputText @bind-Value="_equipmentCreate.SerialNumber" class="form-control" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Notes <span class="text-muted">(optional)</span></label>
                        <InputText @bind-Value="_equipmentCreate.Description" class="form-control" placeholder="e.g. Main entrance, Left wall" />
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Save Equipment</button>
                        <button type="button" class="btn btn-secondary" @onclick="CloseAddEquipmentModal">Cancel</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    @* Compliance Checks Modal *@
    @if (_showChecksModal)
    {
        <div class="modal-overlay" @onclick="() => _showChecksModal = false">
            <div class="modal modal-wide" @onclick:stopPropagation>
                <h2>Compliance Checks — @_checksEquipmentName</h2>
                @if (_checkRecords.Any() || _applicableChecks.Any())
                {
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Check</th>
                                <th>Interval</th>
                                <th>Date</th>
                                <th>Expiry</th>
                                <th>Status</th>
                                <th>Notes</th>
                                <th style="width:80px"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var check in _applicableChecks)
                            {
                                var record = _checkRecords.FirstOrDefault(r => r.EquipmentCheckId == check.Id);
                                <tr>
                                    <td><strong>@check.Name</strong></td>
                                    <td>@(check.IntervalMonths.HasValue ? $"Every {check.IntervalMonths}mo" : "One-time")</td>
                                    <td>
                                        <input type="date" class="form-control form-control-sm"
                                               value="@(_checkDateValues.GetValueOrDefault(check.Id))"
                                               @onchange="e => OnCheckDateChanged(check.Id, e)" />
                                    </td>
                                    <td>@(record?.ExpiryDate?.ToString("dd MMM yyyy") ?? "—")</td>
                                    <td>
                                        @if (record != null)
                                        {
                                            var cls = record.ComplianceStatus switch
                                            {
                                                "Overdue" => "badge-danger",
                                                "Due Soon" => "badge-warning",
                                                _ => "badge-success"
                                            };
                                            <span class="badge @cls">@record.ComplianceStatus</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Not set</span>
                                        }
                                    </td>
                                    <td>
                                        <input class="form-control form-control-sm" placeholder="Notes..."
                                               value="@(_checkNoteValues.GetValueOrDefault(check.Id))"
                                               @onchange="e => _checkNoteValues[check.Id] = e.Value?.ToString()" />
                                    </td>
                                    <td>
                                        <button class="btn btn-xs btn-primary"
                                                disabled="@(!_checkDateValues.ContainsKey(check.Id) || string.IsNullOrEmpty(_checkDateValues[check.Id]))"
                                                @onclick="() => SaveCheckRecord(check.Id)">Save</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="empty-state">No compliance checks defined for this equipment type.</p>
                }
                <div class="form-actions">
                    <button class="btn btn-secondary" @onclick="() => _showChecksModal = false">Close</button>
                </div>
            </div>
        </div>
    }

    @* Unassign confirm *@
    @if (_unassignId.HasValue)
    {
        <div class="modal-overlay" @onclick="() => _unassignId = null">
            <div class="modal" @onclick:stopPropagation>
                <h2>Unassign Equipment</h2>
                <p>Return <strong>@_unassignName</strong> to the inventory pool?</p>
                <div class="form-actions">
                    <button class="btn btn-danger" @onclick="ConfirmUnassign">Yes, unassign</button>
                    <button class="btn btn-secondary" @onclick="() => _unassignId = null">Cancel</button>
                </div>
            </div>
        </div>
    }

    @* Edit Equipment Modal *@
    @if (_showEditEquipment)
    {
        <div class="modal-overlay" @onclick="() => _showEditEquipment = false">
            <div class="modal modal-wide" @onclick:stopPropagation>
                <h2>Edit Equipment</h2>
                <EditForm Model="_equipmentEdit" OnValidSubmit="UpdateEquipment">
                    <div class="form-row">
                        <div class="form-group">
                            <label>Identifier</label>
                            <InputText @bind-Value="_equipmentEdit.Identifier" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Equipment Type</label>
                            <select class="form-control" value="@_equipmentEdit.EquipmentTypeId" @onchange="OnEditEquipmentTypeChanged">
                                <option value="">-- Select Type --</option>
                                @foreach (var eqType in _equipmentTypes)
                                {
                                    <option value="@eqType.Id" selected="@(eqType.Id == _equipmentEdit.EquipmentTypeId)">@eqType.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    @if (_editSubTypes.Any())
                    {
                        <div class="form-group">
                            <label>Sub-Type</label>
                            <select class="form-control" value="@_equipmentEdit.EquipmentSubTypeId" @onchange="OnEditSubTypeChanged">
                                <option value="">-- None --</option>
                                @foreach (var st in _editSubTypes)
                                {
                                    <option value="@st.Id" selected="@(st.Id == _equipmentEdit.EquipmentSubTypeId)">@st.Name</option>
                                }
                            </select>
                        </div>
                    }
                    <div class="form-row">
                        <div class="form-group">
                            <label>Size / Spec</label>
                            @if (_equipmentEdit.EquipmentSubTypeId.HasValue)
                            {
                                <input type="text" class="form-control form-control-muted" readonly value="@_equipmentEdit.Size" />
                                <small class="form-hint">Auto-set from sub-type</small>
                            }
                            else
                            {
                                <InputText @bind-Value="_equipmentEdit.Size" class="form-control" placeholder="e.g. 9kg, 30m, 500ml" />
                            }
                        </div>
                        <div class="form-group">
                            <label>Serial Number</label>
                            <InputText @bind-Value="_equipmentEdit.SerialNumber" class="form-control" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Notes <span class="text-muted">(optional)</span></label>
                        <InputText @bind-Value="_equipmentEdit.Description" class="form-control" placeholder="e.g. Main entrance, Left wall" />
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Update</button>
                        <button type="button" class="btn btn-secondary" @onclick="() => _showEditEquipment = false">Cancel</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    @if (!_sections.Any())
    {
        <p class="empty-state">No sections yet. Add a section to organize your equipment.</p>
    }

    @foreach (var sect in _sections)
    {
        <div class="section-card">
            <div class="section-header">
                <div>
                    <h2>@sect.Name</h2>
                    @if (sect.Description is not null)
                    {
                        <p class="section-desc">@sect.Description</p>
                    }
                </div>
                <div class="header-actions">
                    <button class="btn btn-sm btn-secondary" @onclick="() => StartEditSection(sect)">Edit</button>
                    <button class="btn btn-sm btn-primary" @onclick="() => ShowAddEquipment(sect.Id, sect.Name)">Add Equipment</button>
                </div>
            </div>

            @if (sect.PhotoBase64 is not null)
            {
                <div class="section-photo">
                    <img src="@($"data:image/jpeg;base64,{sect.PhotoBase64}")" alt="@sect.Name" />
                </div>
            }

            @if (_equipmentBySection.TryGetValue(sect.Id, out var equipment) && equipment.Any())
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Type</th>
                            <th>Spec</th>
                            <th>Notes</th>
                            <th>Serial</th>
                            <th>Next Service</th>
                            <th>Compliance</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var eq in equipment)
                        {
                            var compStatus = GetComplianceStatus(eq.Id);
                            <tr class="@(!eq.IsActive ? "row-inactive" : "")">
                                <td><strong>@eq.Identifier</strong></td>
                                <td>@eq.EquipmentTypeName</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(eq.SubTypeName))
                                    {
                                        <span class="badge-spec">@eq.SubTypeName</span>
                                    }
                                    else if (!string.IsNullOrEmpty(eq.Size))
                                    {
                                        @eq.Size
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="col-notes">@(string.IsNullOrEmpty(eq.Description) ? "—" : eq.Description)</td>
                                <td>@(eq.SerialNumber ?? "—")</td>
                                <td>@(eq.NextServiceDate?.ToString("dd MMM yyyy") ?? "—")</td>
                                <td>
                                    @{
                                        var cls = compStatus switch
                                        {
                                            "Overdue" => "badge-danger",
                                            "Due Soon" => "badge-warning",
                                            "OK" => "badge-success",
                                            _ => ""
                                        };
                                    }
                                    @if (!string.IsNullOrEmpty(compStatus))
                                    {
                                        <span class="badge @cls">@compStatus</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>
                                    @if (eq.IsActive)
                                    {
                                        <span class="active-badge">Active</span>
                                    }
                                    else
                                    {
                                        <span class="inactive-badge">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <div class="action-buttons">
                                        <button class="btn btn-xs btn-secondary" @onclick="() => OpenChecksModal(eq)" title="Compliance Checks">
                                            <i class="fa-light fa-calendar-check"></i>
                                        </button>
                                        <button class="btn btn-xs btn-secondary" @onclick="() => StartEditEquipment(eq)">Edit</button>
                                        <button class="btn btn-xs btn-secondary" @onclick="() => { _unassignId = eq.Id; _unassignName = eq.Identifier; }" title="Unassign">
                                            <i class="fa-light fa-link-slash"></i>
                                        </button>
                                        @if (eq.IsActive)
                                        {
                                            <button class="btn btn-xs btn-warning" @onclick="() => ToggleEquipmentActive(eq)">Deactivate</button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-xs btn-success" @onclick="() => ToggleEquipmentActive(eq)">Activate</button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="empty-state">No equipment in this section yet.</p>
            }
        </div>
    }
}

@code {
    [Parameter] public int PlantId { get; set; }

    private PlantDto? _plant;
    private List<SectionDto> _sections = [];
    private Dictionary<int, List<EquipmentDto>> _equipmentBySection = [];
    private List<EquipmentTypeDto> _equipmentTypes = [];
    private List<EquipmentSubTypeDto> _createSubTypes = [];
    private List<EquipmentSubTypeDto> _editSubTypes = [];

    // Create Section
    private bool _showCreateSection;
    private SectionCreateModel _sectionCreate = new();

    // Edit Section
    private bool _showEditSection;
    private int _editSectionId;
    private int _editSectionSortOrder;
    private SectionEditModel _sectionEdit = new();

    // Add Equipment
    private bool _showAddEquipment;
    private int _addEquipmentSectionId;
    private string _addEquipmentSectionName = "";
    private EquipmentCreateModel _equipmentCreate = new();

    // Edit Equipment
    private bool _showEditEquipment;
    private int _editEquipmentId;
    private int _editEquipmentSortOrder;
    private EquipmentEditModel _equipmentEdit = new();

    // Compliance Checks Modal
    private bool _showChecksModal;
    private int _checksEquipmentId;
    private string _checksEquipmentName = string.Empty;
    private List<EquipmentCheckDto> _applicableChecks = [];
    private List<EquipmentCheckRecordDto> _checkRecords = [];
    private Dictionary<int, string> _checkDateValues = [];
    private Dictionary<int, string?> _checkNoteValues = [];

    // Compliance status per equipment
    private Dictionary<int, List<EquipmentCheckRecordDto>> _complianceByEquipment = [];

    // Unassign
    private int? _unassignId;
    private string _unassignName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _equipmentTypes = await EquipmentService.GetEquipmentTypesAsync();
        await LoadData();
    }

    private async Task LoadData()
    {
        _plant = await PlantService.GetPlantByIdAsync(PlantId);
        _sections = await SectionService.GetSectionsByPlantAsync(PlantId);

        _equipmentBySection.Clear();
        _complianceByEquipment.Clear();
        foreach (var sect in _sections)
        {
            var equipment = await EquipmentService.GetEquipmentBySectionAsync(sect.Id, includeInactive: true);
            _equipmentBySection[sect.Id] = equipment;
            foreach (var eq in equipment)
            {
                _complianceByEquipment[eq.Id] = await EquipmentService.GetCheckRecordsAsync(eq.Id);
            }
        }
    }

    private string? GetComplianceStatus(int equipmentId)
    {
        if (!_complianceByEquipment.TryGetValue(equipmentId, out var records) || !records.Any())
            return null;
        if (records.Any(r => r.ComplianceStatus == "Overdue")) return "Overdue";
        if (records.Any(r => r.ComplianceStatus == "Due Soon")) return "Due Soon";
        return "OK";
    }

    private async Task OpenChecksModal(EquipmentDto eq)
    {
        _checksEquipmentId   = eq.Id;
        _checksEquipmentName = eq.Identifier;
        _applicableChecks    = await EquipmentService.GetEquipmentChecksAsync(eq.EquipmentTypeId);
        _checkRecords        = await EquipmentService.GetCheckRecordsAsync(eq.Id);

        _checkDateValues = [];
        _checkNoteValues = [];
        foreach (var check in _applicableChecks)
        {
            var record = _checkRecords.FirstOrDefault(r => r.EquipmentCheckId == check.Id);
            if (record != null)
            {
                _checkDateValues[check.Id] = record.DateValue.ToString("yyyy-MM-dd");
                _checkNoteValues[check.Id] = record.Notes;
            }
        }

        _showChecksModal = true;
    }

    private void OnCheckDateChanged(int checkId, ChangeEventArgs e)
    {
        _checkDateValues[checkId] = e.Value?.ToString() ?? "";
    }

    private async Task SaveCheckRecord(int checkId)
    {
        if (!_checkDateValues.TryGetValue(checkId, out var dateStr) || !DateOnly.TryParse(dateStr, out var dateValue))
            return;

        var result = await EquipmentService.UpsertCheckRecordAsync(
            new EquipmentCheckRecordUpsertDto(_checksEquipmentId, checkId, dateValue,
                _checkNoteValues.GetValueOrDefault(checkId)), "current-user");

        _checkRecords = await EquipmentService.GetCheckRecordsAsync(_checksEquipmentId);
        _complianceByEquipment[_checksEquipmentId] = _checkRecords;
    }

    private async Task ConfirmUnassign()
    {
        if (!_unassignId.HasValue) return;
        await EquipmentService.UnassignEquipmentAsync(new UnassignEquipmentDto(_unassignId.Value), "current-user");
        _unassignId = null;
        await LoadData();
    }

    // ===== Section CRUD =====
    private async Task CreateSection()
    {
        var maxOrder = _sections.Any() ? _sections.Max(s => s.SortOrder) + 1 : 1;
        var dto = new SectionCreateDto(PlantId, _sectionCreate.Name, _sectionCreate.Description, maxOrder, _sectionCreate.PhotoBase64, _sectionCreate.PhotoFileName);
        await SectionService.CreateSectionAsync(dto, "current-user");
        await LoadData();
        _showCreateSection = false;
        _sectionCreate = new();
    }

    private void StartEditSection(SectionDto sect)
    {
        _editSectionId = sect.Id;
        _editSectionSortOrder = sect.SortOrder;
        _sectionEdit = new SectionEditModel
        {
            Name = sect.Name,
            Description = sect.Description,
            IsActive = sect.IsActive,
            PhotoBase64 = sect.PhotoBase64,
            PhotoFileName = sect.PhotoFileName
        };
        _showEditSection = true;
    }

    private async Task UpdateSection()
    {
        var dto = new SectionUpdateDto(_editSectionId, _sectionEdit.Name, _sectionEdit.Description, _editSectionSortOrder, _sectionEdit.IsActive, _sectionEdit.PhotoBase64, _sectionEdit.PhotoFileName);
        await SectionService.UpdateSectionAsync(dto, "current-user");
        await LoadData();
        _showEditSection = false;
        _sectionEdit = new();
    }

    private async Task OnCreateSectionPhotoSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        var buffer = new byte[file.Size];
        await file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024).ReadAsync(buffer);
        _sectionCreate.PhotoBase64 = Convert.ToBase64String(buffer);
        _sectionCreate.PhotoFileName = file.Name;
    }

    private async Task OnEditSectionPhotoSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        var buffer = new byte[file.Size];
        await file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024).ReadAsync(buffer);
        _sectionEdit.PhotoBase64 = Convert.ToBase64String(buffer);
        _sectionEdit.PhotoFileName = file.Name;
    }

    // ===== Equipment CRUD =====
    private void ShowAddEquipment(int sectionId, string sectionName)
    {
        _addEquipmentSectionId = sectionId;
        _addEquipmentSectionName = sectionName;
        _equipmentCreate = new();
        _createSubTypes = [];
        _showAddEquipment = true;
    }

    private void CloseAddEquipmentModal()
    {
        _showAddEquipment = false;
        _equipmentCreate = new();
        _createSubTypes = [];
    }

    private async Task OnCreateEquipmentTypeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var typeId))
        {
            _equipmentCreate.EquipmentTypeId    = typeId;
            _equipmentCreate.EquipmentSubTypeId = null;
            _equipmentCreate.Size               = string.Empty;
            _createSubTypes = await EquipmentService.GetSubTypesByTypeAsync(typeId);
        }
    }

    private void OnCreateSubTypeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var subTypeId))
        {
            _equipmentCreate.EquipmentSubTypeId = subTypeId;
            var subType = _createSubTypes.FirstOrDefault(s => s.Id == subTypeId);
            if (subType != null) _equipmentCreate.Size = subType.Name;
        }
        else
        {
            _equipmentCreate.EquipmentSubTypeId = null;
        }
    }

    private async Task CreateEquipment()
    {
        var existingEquipment = _equipmentBySection.TryGetValue(_addEquipmentSectionId, out var eqs) ? eqs : [];
        var maxOrder = existingEquipment.Any() ? existingEquipment.Max(e => e.SortOrder) + 1 : 1;

        var dto = new EquipmentCreateDto(
            _addEquipmentSectionId,
            _equipmentCreate.EquipmentTypeId,
            _equipmentCreate.EquipmentSubTypeId,
            _equipmentCreate.Identifier,
            _equipmentCreate.Description,
            _equipmentCreate.Size,
            _equipmentCreate.SerialNumber,
            null, null, maxOrder);

        await EquipmentService.CreateEquipmentAsync(dto, "current-user");
        await LoadData();
        CloseAddEquipmentModal();
    }

    private async Task StartEditEquipment(EquipmentDto eq)
    {
        _editEquipmentId = eq.Id;
        _editEquipmentSortOrder = eq.SortOrder;
        _equipmentEdit = new EquipmentEditModel
        {
            Identifier = eq.Identifier,
            EquipmentTypeId = eq.EquipmentTypeId,
            EquipmentSubTypeId = eq.EquipmentSubTypeId,
            Description = eq.Description,
            Size = eq.Size,
            SerialNumber = eq.SerialNumber,
            IsActive = eq.IsActive
        };
        _editSubTypes = await EquipmentService.GetSubTypesByTypeAsync(eq.EquipmentTypeId);
        _showEditEquipment = true;
    }

    private async Task OnEditEquipmentTypeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var typeId))
        {
            _equipmentEdit.EquipmentTypeId    = typeId;
            _equipmentEdit.EquipmentSubTypeId = null;
            _equipmentEdit.Size               = string.Empty;
            _editSubTypes = await EquipmentService.GetSubTypesByTypeAsync(typeId);
        }
    }

    private void OnEditSubTypeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var subTypeId))
        {
            _equipmentEdit.EquipmentSubTypeId = subTypeId;
            var subType = _editSubTypes.FirstOrDefault(s => s.Id == subTypeId);
            if (subType != null) _equipmentEdit.Size = subType.Name;
        }
        else
        {
            _equipmentEdit.EquipmentSubTypeId = null;
        }
    }

    private async Task UpdateEquipment()
    {
        var dto = new EquipmentUpdateDto(
            _editEquipmentId, _equipmentEdit.EquipmentTypeId, _equipmentEdit.EquipmentSubTypeId,
            _equipmentEdit.Identifier, _equipmentEdit.Description, _equipmentEdit.Size,
            _equipmentEdit.SerialNumber, null, _editEquipmentSortOrder, _equipmentEdit.IsActive);
        await EquipmentService.UpdateEquipmentAsync(dto, "current-user");
        await LoadData();
        _showEditEquipment = false;
    }

    private async Task ToggleEquipmentActive(EquipmentDto eq)
    {
        var dto = new EquipmentUpdateDto(
            eq.Id, eq.EquipmentTypeId, eq.EquipmentSubTypeId,
            eq.Identifier, eq.Description, eq.Size,
            eq.SerialNumber, eq.NextServiceDate, eq.SortOrder, !eq.IsActive);
        await EquipmentService.UpdateEquipmentAsync(dto, "current-user");
        await LoadData();
    }

    private void GoBack() => Navigation.NavigateTo($"/companies/{_plant?.CompanyId}");

