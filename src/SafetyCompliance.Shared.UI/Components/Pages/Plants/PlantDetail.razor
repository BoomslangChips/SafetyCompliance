@page "/plants/{PlantId:int}"
@inject IPlantService PlantService
@inject ISectionService SectionService
@inject IEquipmentService EquipmentService
@inject NavigationManager Navigation

@if (_plant is null)
{
    <div class="plt-loading">
        <i class="fa-sharp fa-regular fa-spinner fa-spin"></i>
        <span>Loading plant details...</span>
    </div>
}
else
{
    <div class="page-header">
        <div>
            <button class="btn btn-link" @onclick="GoBack">
                <i class="fa-sharp fa-regular fa-arrow-left"></i> Back
            </button>
            <h1>@_plant.Name</h1>
            @if (_plant.Description is not null)
            {
                <p class="card-subtitle">@_plant.Description</p>
            }
        </div>
        <button class="btn btn-primary" @onclick="() => _showCreateSection = true">
            <i class="fa-sharp fa-solid fa-plus"></i> Add Section
        </button>
    </div>

    @if (_plant.PhotoBase64 is not null)
    {
        <div class="entity-photo">
            <img src="@($"data:image/jpeg;base64,{_plant.PhotoBase64}")" alt="@_plant.Name" />
        </div>
    }

    @* ═══════════════════════════════════════════════════════
       PLANT CONTACTS SECTION
       ═══════════════════════════════════════════════════════ *@
    <div class="plt-contacts-section">
        <div class="plt-contacts-header">
            <div class="plt-contacts-header-left">
                <div class="plt-contacts-title-wrap">
                    <span class="plt-contacts-icon"><i class="fa-sharp fa-solid fa-address-book"></i></span>
                    <h2 class="plt-contacts-title">Plant Contacts</h2>
                </div>
                @if (_contacts.Any())
                {
                    <span class="plt-contacts-badge">@_contacts.Count</span>
                }
            </div>
            <button class="btn btn-primary plt-add-contact-btn" @onclick="ShowAddContact">
                <i class="fa-sharp fa-solid fa-user-plus"></i>
                Add Contact
            </button>
        </div>

        @if (!_contacts.Any())
        {
            <div class="plt-empty-contacts">
                <div class="plt-empty-icon"><i class="fa-sharp fa-regular fa-address-book"></i></div>
                <p class="plt-empty-title">No contacts yet</p>
                <p class="plt-empty-sub">Add emergency contacts, management, firefighters or specialist contacts for this plant.</p>
                <button class="btn btn-primary" @onclick="ShowAddContact">
                    <i class="fa-sharp fa-solid fa-plus"></i> Add First Contact
                </button>
            </div>
        }
        else
        {
            <div class="plt-categories-wrap">
                @foreach (var group in _contacts.GroupBy(c => c.Category).OrderBy(g => g.Key))
                {
                    <div class="plt-category-group">
                        <div class="plt-category-header">
                            <div class="plt-category-header-left">
                                <span class="plt-cat-emoji">@GetCategoryEmoji(group.Key)</span>
                                <h3 class="plt-category-name">@group.Key</h3>
                            </div>
                            <span class="plt-category-count">@group.Count() @(group.Count() == 1 ? "contact" : "contacts")</span>
                        </div>
                        <div class="plt-contacts-grid">
                            @foreach (var c in group.OrderByDescending(x => x.IsPrimary).ThenBy(x => x.SortOrder))
                            {
                                <div class="plt-contact-card @(c.IsPrimary ? "plt-contact-card--primary" : "")">
                                    <div class="plt-contact-avatar" style="--plt-av-bg:@GetCategoryColor(group.Key)">
                                        @GetInitials(c.Name)
                                    </div>
                                    <div class="plt-contact-body">
                                        <div class="plt-contact-top">
                                            <span class="plt-contact-name">@c.Name</span>
                                            @if (c.IsPrimary)
                                            {
                                                <span class="plt-primary-badge">
                                                    <i class="fa-sharp fa-solid fa-star"></i> Primary
                                                </span>
                                            }
                                        </div>
                                        @if (c.Role is not null)
                                        {
                                            <p class="plt-contact-role">@c.Role</p>
                                        }
                                        <div class="plt-contact-details">
                                            @if (c.Phone is not null)
                                            {
                                                <a href="tel:@c.Phone" class="plt-contact-detail plt-detail-phone">
                                                    <i class="fa-sharp fa-regular fa-phone"></i>
                                                    <span>@c.Phone</span>
                                                </a>
                                            }
                                            @if (c.Email is not null)
                                            {
                                                <a href="mailto:@c.Email" class="plt-contact-detail plt-detail-email">
                                                    <i class="fa-sharp fa-regular fa-envelope"></i>
                                                    <span>@c.Email</span>
                                                </a>
                                            }
                                        </div>
                                        @if (c.Notes is not null)
                                        {
                                            <p class="plt-contact-notes">@c.Notes</p>
                                        }
                                    </div>
                                    <div class="plt-contact-actions">
                                        <button class="plt-action-btn" title="Edit contact" @onclick="() => StartEditContact(c)">
                                            <i class="fa-sharp fa-regular fa-pen"></i>
                                        </button>
                                        <button class="plt-action-btn plt-action-btn--danger" title="Delete contact" @onclick="() => _deleteContactId = c.Id">
                                            <i class="fa-sharp fa-regular fa-trash"></i>
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    @* ─── Add Contact Modal ─── *@
    @if (_showAddContact)
    {
        <div class="modal-overlay" @onclick="() => _showAddContact = false">
            <div class="modal plt-contact-modal" @onclick:stopPropagation>
                <div class="plt-modal-header">
                    <div class="plt-modal-title">
                        <span class="plt-modal-icon plt-modal-icon--add"><i class="fa-sharp fa-solid fa-user-plus"></i></span>
                        <h2>Add Contact</h2>
                    </div>
                    <button class="modal-close-btn" @onclick="() => _showAddContact = false">
                        <i class="fa-sharp fa-regular fa-xmark"></i>
                    </button>
                </div>

                <div class="plt-modal-body">
                    <div class="form-group">
                        <label class="form-label">Category <span class="form-required">*</span></label>
                        <div class="plt-category-chips">
                            @foreach (var cat in _predefinedCategories)
                            {
                                <button type="button"
                                        class="plt-chip @(_contactCreate.Category == cat ? "plt-chip--active" : "")"
                                        @onclick="() => _contactCreate.Category = cat">
                                    @GetCategoryEmoji(cat) @cat
                                </button>
                            }
                        </div>
                        <input class="form-control plt-category-custom"
                               placeholder="Or type a custom category…"
                               value="@_contactCreate.Category"
                               @oninput="e => _contactCreate.Category = e.Value?.ToString() ?? string.Empty" />
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Full Name <span class="form-required">*</span></label>
                            <input class="form-control"
                                   placeholder="e.g. John Smith"
                                   value="@_contactCreate.Name"
                                   @oninput="e => _contactCreate.Name = e.Value?.ToString() ?? string.Empty" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Role / Title</label>
                            <input class="form-control"
                                   placeholder="e.g. Fire Captain, Safety Officer"
                                   value="@_contactCreate.Role"
                                   @oninput="e => _contactCreate.Role = e.Value?.ToString()" />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Phone</label>
                            <input class="form-control" type="tel"
                                   placeholder="+27 82 000 0000"
                                   value="@_contactCreate.Phone"
                                   @oninput="e => _contactCreate.Phone = e.Value?.ToString()" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Email</label>
                            <input class="form-control" type="email"
                                   placeholder="name@company.com"
                                   value="@_contactCreate.Email"
                                   @oninput="e => _contactCreate.Email = e.Value?.ToString()" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Notes</label>
                        <textarea class="form-control" rows="2"
                                  placeholder="Additional information, availability hours, etc."
                                  value="@_contactCreate.Notes"
                                  @oninput="e => _contactCreate.Notes = e.Value?.ToString()"></textarea>
                    </div>

                    <label class="plt-toggle-label">
                        <input type="checkbox"
                               checked="@_contactCreate.IsPrimary"
                               @onchange="e => _contactCreate.IsPrimary = (bool)(e.Value ?? false)" />
                        <span class="plt-toggle-text">
                            <strong>Mark as primary contact</strong>
                            <small>This person is the first point of contact for their category</small>
                        </span>
                    </label>
                </div>

                <div class="plt-modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _showAddContact = false">Cancel</button>
                    <button class="btn btn-primary"
                            disabled="@(string.IsNullOrWhiteSpace(_contactCreate.Name) || string.IsNullOrWhiteSpace(_contactCreate.Category))"
                            @onclick="CreateContact">
                        <i class="fa-sharp fa-solid fa-check"></i> Save Contact
                    </button>
                </div>
            </div>
        </div>
    }

    @* ─── Edit Contact Modal ─── *@
    @if (_showEditContact)
    {
        <div class="modal-overlay" @onclick="() => _showEditContact = false">
            <div class="modal plt-contact-modal" @onclick:stopPropagation>
                <div class="plt-modal-header">
                    <div class="plt-modal-title">
                        <span class="plt-modal-icon plt-modal-icon--edit"><i class="fa-sharp fa-solid fa-pen"></i></span>
                        <h2>Edit Contact</h2>
                    </div>
                    <button class="modal-close-btn" @onclick="() => _showEditContact = false">
                        <i class="fa-sharp fa-regular fa-xmark"></i>
                    </button>
                </div>

                <div class="plt-modal-body">
                    <div class="form-group">
                        <label class="form-label">Category <span class="form-required">*</span></label>
                        <div class="plt-category-chips">
                            @foreach (var cat in _predefinedCategories)
                            {
                                <button type="button"
                                        class="plt-chip @(_contactEdit.Category == cat ? "plt-chip--active" : "")"
                                        @onclick="() => _contactEdit.Category = cat">
                                    @GetCategoryEmoji(cat) @cat
                                </button>
                            }
                        </div>
                        <input class="form-control plt-category-custom"
                               placeholder="Or type a custom category…"
                               value="@_contactEdit.Category"
                               @oninput="e => _contactEdit.Category = e.Value?.ToString() ?? string.Empty" />
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Full Name <span class="form-required">*</span></label>
                            <input class="form-control"
                                   value="@_contactEdit.Name"
                                   @oninput="e => _contactEdit.Name = e.Value?.ToString() ?? string.Empty" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Role / Title</label>
                            <input class="form-control"
                                   value="@_contactEdit.Role"
                                   @oninput="e => _contactEdit.Role = e.Value?.ToString()" />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Phone</label>
                            <input class="form-control" type="tel"
                                   value="@_contactEdit.Phone"
                                   @oninput="e => _contactEdit.Phone = e.Value?.ToString()" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Email</label>
                            <input class="form-control" type="email"
                                   value="@_contactEdit.Email"
                                   @oninput="e => _contactEdit.Email = e.Value?.ToString()" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Notes</label>
                        <textarea class="form-control" rows="2"
                                  value="@_contactEdit.Notes"
                                  @oninput="e => _contactEdit.Notes = e.Value?.ToString()"></textarea>
                    </div>

                    <label class="plt-toggle-label">
                        <input type="checkbox"
                               checked="@_contactEdit.IsPrimary"
                               @onchange="e => _contactEdit.IsPrimary = (bool)(e.Value ?? false)" />
                        <span class="plt-toggle-text">
                            <strong>Mark as primary contact</strong>
                            <small>This person is the first point of contact for their category</small>
                        </span>
                    </label>
                </div>

                <div class="plt-modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _showEditContact = false">Cancel</button>
                    <button class="btn btn-primary"
                            disabled="@(string.IsNullOrWhiteSpace(_contactEdit.Name) || string.IsNullOrWhiteSpace(_contactEdit.Category))"
                            @onclick="UpdateContact">
                        <i class="fa-sharp fa-solid fa-check"></i> Update Contact
                    </button>
                </div>
            </div>
        </div>
    }

    @* ─── Delete Confirm Modal ─── *@
    @if (_deleteContactId.HasValue)
    {
        var victim = _contacts.FirstOrDefault(c => c.Id == _deleteContactId.Value);
        <div class="modal-overlay" @onclick="() => _deleteContactId = null">
            <div class="modal modal-sm plt-delete-modal" @onclick:stopPropagation>
                <div class="plt-delete-icon"><i class="fa-sharp fa-solid fa-triangle-exclamation"></i></div>
                <h3>Delete Contact?</h3>
                <p>Are you sure you want to remove <strong>@victim?.Name</strong> from plant contacts? This cannot be undone.</p>
                <div class="form-actions">
                    <button class="btn btn-danger" @onclick="ConfirmDeleteContact">
                        <i class="fa-sharp fa-solid fa-trash"></i> Delete
                    </button>
                    <button class="btn btn-secondary" @onclick="() => _deleteContactId = null">Cancel</button>
                </div>
            </div>
        </div>
    }

    @* ═══════════════════════════════════════════════════════
       SECTIONS & EQUIPMENT
       ═══════════════════════════════════════════════════════ *@

    @* Create Section Modal *@
    @if (_showCreateSection)
    {
        <div class="modal-overlay" @onclick="() => _showCreateSection = false">
            <div class="modal" @onclick:stopPropagation>
                <h2>Add Section</h2>
                <EditForm Model="_sectionCreate" OnValidSubmit="CreateSection">
                    <div class="form-group">
                        <label>Name</label>
                        <InputText @bind-Value="_sectionCreate.Name" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Description</label>
                        <InputText @bind-Value="_sectionCreate.Description" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Photo</label>
                        <InputFile OnChange="OnCreateSectionPhotoSelected" class="form-control" accept="image/*" />
                        @if (_sectionCreate.PhotoBase64 is not null)
                        {
                            <div class="photo-preview">
                                <img src="@($"data:image/jpeg;base64,{_sectionCreate.PhotoBase64}")" alt="Preview" />
                                <button type="button" class="btn btn-sm btn-secondary" @onclick="() => { _sectionCreate.PhotoBase64 = null; _sectionCreate.PhotoFileName = null; }">Remove</button>
                            </div>
                        }
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Save</button>
                        <button type="button" class="btn btn-secondary" @onclick="() => _showCreateSection = false">Cancel</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    @* Edit Section Modal *@
    @if (_showEditSection)
    {
        <div class="modal-overlay" @onclick="() => _showEditSection = false">
            <div class="modal" @onclick:stopPropagation>
                <h2>Edit Section</h2>
                <EditForm Model="_sectionEdit" OnValidSubmit="UpdateSection">
                    <div class="form-group">
                        <label>Name</label>
                        <InputText @bind-Value="_sectionEdit.Name" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Description</label>
                        <InputText @bind-Value="_sectionEdit.Description" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Photo</label>
                        <InputFile OnChange="OnEditSectionPhotoSelected" class="form-control" accept="image/*" />
                        @if (_sectionEdit.PhotoBase64 is not null)
                        {
                            <div class="photo-preview">
                                <img src="@($"data:image/jpeg;base64,{_sectionEdit.PhotoBase64}")" alt="Preview" />
                                <button type="button" class="btn btn-sm btn-secondary" @onclick="() => { _sectionEdit.PhotoBase64 = null; _sectionEdit.PhotoFileName = null; }">Remove</button>
                            </div>
                        }
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Update</button>
                        <button type="button" class="btn btn-secondary" @onclick="() => _showEditSection = false">Cancel</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    @* Add Equipment Modal *@
    @if (_showAddEquipment)
    {
        <div class="modal-overlay" @onclick="CloseAddEquipmentModal">
            <div class="modal modal-wide" @onclick:stopPropagation>
                <h2>Add Equipment to @(_addEquipmentSectionName)</h2>
                <EditForm Model="_equipmentCreate" OnValidSubmit="CreateEquipment">
                    <div class="form-row">
                        <div class="form-group">
                            <label>Identifier (e.g. FE-01)</label>
                            <InputText @bind-Value="_equipmentCreate.Identifier" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Equipment Type</label>
                            <select class="form-control" @onchange="OnCreateEquipmentTypeChanged">
                                <option value="">-- Select Type --</option>
                                @foreach (var eqType in _equipmentTypes)
                                {
                                    <option value="@eqType.Id">@eqType.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    @if (_createSubTypes.Any())
                    {
                        <div class="form-group">
                            <label>Sub-Type</label>
                            <select class="form-control" @onchange="OnCreateSubTypeChanged">
                                <option value="">-- Select Sub-Type (optional) --</option>
                                @foreach (var st in _createSubTypes)
                                {
                                    <option value="@st.Id">@st.Name</option>
                                }
                            </select>
                        </div>
                    }
                    <div class="form-group">
                        <label>Description</label>
                        <InputText @bind-Value="_equipmentCreate.Description" class="form-control" />
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Size</label>
                            <InputText @bind-Value="_equipmentCreate.Size" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Serial Number</label>
                            <InputText @bind-Value="_equipmentCreate.SerialNumber" class="form-control" />
                        </div>
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Save Equipment</button>
                        <button type="button" class="btn btn-secondary" @onclick="CloseAddEquipmentModal">Cancel</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    @* Edit Equipment Modal *@
    @if (_showEditEquipment)
    {
        <div class="modal-overlay" @onclick="() => _showEditEquipment = false">
            <div class="modal modal-wide" @onclick:stopPropagation>
                <h2>Edit Equipment</h2>
                <EditForm Model="_equipmentEdit" OnValidSubmit="UpdateEquipment">
                    <div class="form-row">
                        <div class="form-group">
                            <label>Identifier</label>
                            <InputText @bind-Value="_equipmentEdit.Identifier" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Equipment Type</label>
                            <select class="form-control" value="@_equipmentEdit.EquipmentTypeId" @onchange="OnEditEquipmentTypeChanged">
                                <option value="">-- Select Type --</option>
                                @foreach (var eqType in _equipmentTypes)
                                {
                                    <option value="@eqType.Id" selected="@(eqType.Id == _equipmentEdit.EquipmentTypeId)">@eqType.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    @if (_editSubTypes.Any())
                    {
                        <div class="form-group">
                            <label>Sub-Type</label>
                            <select class="form-control" value="@_equipmentEdit.EquipmentSubTypeId" @onchange="OnEditSubTypeChanged">
                                <option value="">-- None --</option>
                                @foreach (var st in _editSubTypes)
                                {
                                    <option value="@st.Id" selected="@(st.Id == _equipmentEdit.EquipmentSubTypeId)">@st.Name</option>
                                }
                            </select>
                        </div>
                    }
                    <div class="form-group">
                        <label>Description</label>
                        <InputText @bind-Value="_equipmentEdit.Description" class="form-control" />
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Size</label>
                            <InputText @bind-Value="_equipmentEdit.Size" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Serial Number</label>
                            <InputText @bind-Value="_equipmentEdit.SerialNumber" class="form-control" />
                        </div>
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Update</button>
                        <button type="button" class="btn btn-secondary" @onclick="() => _showEditEquipment = false">Cancel</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    @if (!_sections.Any())
    {
        <p class="empty-state">No sections yet. Add a section to organise your equipment.</p>
    }

    @foreach (var sect in _sections)
    {
        <div class="section-card">
            <div class="section-header">
                <div>
                    <h2>@sect.Name</h2>
                    @if (sect.Description is not null)
                    {
                        <p class="section-desc">@sect.Description</p>
                    }
                </div>
                <div class="header-actions">
                    <button class="btn btn-sm btn-secondary" @onclick="() => StartEditSection(sect)">Edit</button>
                    <button class="btn btn-sm btn-primary" @onclick="() => ShowAddEquipment(sect.Id, sect.Name)">Add Equipment</button>
                </div>
            </div>

            @if (sect.PhotoBase64 is not null)
            {
                <div class="section-photo">
                    <img src="@($"data:image/jpeg;base64,{sect.PhotoBase64}")" alt="@sect.Name" />
                </div>
            }

            @if (_equipmentBySection.TryGetValue(sect.Id, out var equipment) && equipment.Any())
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Type</th>
                            <th>Sub-Type</th>
                            <th>Description</th>
                            <th>Size</th>
                            <th>Serial</th>
                            <th>Next Service</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var eq in equipment)
                        {
                            <tr class="@(!eq.IsActive ? "row-inactive" : "")">
                                <td><strong>@eq.Identifier</strong></td>
                                <td>@eq.EquipmentTypeName</td>
                                <td>@(eq.SubTypeName ?? "-")</td>
                                <td>@(eq.Description ?? "-")</td>
                                <td>@(eq.Size ?? "-")</td>
                                <td>@(eq.SerialNumber ?? "-")</td>
                                <td>@(eq.NextServiceDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                <td>
                                    @if (eq.IsActive)
                                    {
                                        <span class="active-badge">Active</span>
                                    }
                                    else
                                    {
                                        <span class="inactive-badge">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <div class="action-buttons">
                                        <button class="btn btn-xs btn-secondary" @onclick="() => StartEditEquipment(eq)">Edit</button>
                                        @if (eq.IsActive)
                                        {
                                            <button class="btn btn-xs btn-warning" @onclick="() => ToggleEquipmentActive(eq)">Deactivate</button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-xs btn-success" @onclick="() => ToggleEquipmentActive(eq)">Activate</button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="empty-state">No equipment in this section yet.</p>
            }
        </div>
    }
}

@code {
    [Parameter] public int PlantId { get; set; }

    private PlantDto? _plant;
    private List<SectionDto> _sections = [];
    private Dictionary<int, List<EquipmentDto>> _equipmentBySection = [];
    private List<EquipmentTypeDto> _equipmentTypes = [];
    private List<EquipmentSubTypeDto> _createSubTypes = [];
