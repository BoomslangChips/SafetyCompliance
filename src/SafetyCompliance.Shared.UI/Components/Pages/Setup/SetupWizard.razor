@page "/setup"
@page "/setup/{Step:int}"
@inject ICompanyService CompanyService
@inject IPlantService PlantService
@inject ISectionService SectionService
@inject IEquipmentService EquipmentService
@inject NavigationManager Navigation

<div class="page-header">
    <div>
        <h1>Setup Wizard</h1>
        <p class="card-subtitle">Build your organizational hierarchy step by step</p>
    </div>
</div>

<div class="wizard-progress">
    @for (int i = 0; i < _stepNames.Length; i++)
    {
        var stepIndex = i;
        <div class="wizard-step @(stepIndex == _currentStep ? "active" : "") @(stepIndex < _currentStep ? "completed" : "")"
             style="cursor: @(stepIndex < _currentStep ? "pointer" : "default")"
             @onclick="() => GoToStep(stepIndex)">
            <div class="step-number">
                @if (stepIndex < _currentStep)
                {
                    <i class="fa-sharp fa-light fa-check"></i>
                }
                else
                {
                    @((stepIndex + 1).ToString())
                }
            </div>
            <div class="step-label">@_stepNames[stepIndex]</div>
        </div>
        @if (i < _stepNames.Length - 1)
        {
            <div class="step-connector @(stepIndex < _currentStep ? "completed" : "")"></div>
        }
    }
</div>

@if (_errorMessage is not null)
{
    <div class="error-message">@_errorMessage</div>
}

@* ==================== Step 0: Company ==================== *@
@if (_currentStep == 0)
{
    <div class="wizard-card">
        <div class="step-intro">
            <div class="step-intro-icon">
                <i class="fa-sharp fa-light fa-building"></i>
            </div>
            <div class="step-intro-content">
                <h2>Select Your Company</h2>
                <p>Choose the company you want to set up. If your company isn't listed yet, create a new one. Each company can have multiple plants, sections, and equipment.</p>
            </div>
        </div>

        @if (!_companies.Any() && !_showCreateCompany)
        {
            <div class="empty-state">
                <i class="fa-sharp fa-light fa-building"></i>
                No companies yet. Create your first company to get started.
                <div style="margin-top: var(--spacing-md);">
                    <button class="btn btn-primary btn-lg" @onclick="() => { _showCreateCompany = true; _companyCreate = new(); }"><i class="fa-sharp fa-light fa-plus"></i> Create Your First Company</button>
                </div>
            </div>
        }
        else if (!_showCreateCompany)
        {
            <div style="display: flex; justify-content: flex-end; margin-bottom: var(--spacing-md);">
                <button class="btn btn-primary" @onclick="() => { _showCreateCompany = true; _companyCreate = new(); }"><i class="fa-sharp fa-light fa-plus"></i> New Company</button>
            </div>
        }

        @if (_showCreateCompany)
        {
            <div class="setup-item-card" style="margin-bottom: var(--spacing-lg);">
                <div class="setup-item-header">
                    <h3><i class="fa-sharp fa-light fa-plus" style="color: var(--color-primary);"></i> Create New Company</h3>
                    <button class="btn btn-sm btn-ghost" @onclick="() => _showCreateCompany = false"><i class="fa-sharp fa-light fa-xmark"></i> Cancel</button>
                </div>
                <EditForm Model="_companyCreate" OnValidSubmit="CreateCompany">
                    <div class="form-row">
                        <div class="form-group">
                            <label>Name *</label>
                            <InputText @bind-Value="_companyCreate.Name" class="form-control" placeholder="e.g. Acme Industries" />
                        </div>
                        <div class="form-group">
                            <label>Code</label>
                            <InputText @bind-Value="_companyCreate.Code" class="form-control" placeholder="e.g. ACME" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Address</label>
                        <InputText @bind-Value="_companyCreate.Address" class="form-control" placeholder="e.g. 123 Industrial Ave" />
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Contact Name</label>
                            <InputText @bind-Value="_companyCreate.ContactName" class="form-control" placeholder="Primary contact" />
                        </div>
                        <div class="form-group">
                            <label>Contact Email</label>
                            <InputText @bind-Value="_companyCreate.ContactEmail" class="form-control" placeholder="email@example.com" />
                        </div>
                        <div class="form-group">
                            <label>Contact Phone</label>
                            <InputText @bind-Value="_companyCreate.ContactPhone" class="form-control" placeholder="+1 (555) 000-0000" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Photo</label>
                        <InputFile OnChange="OnCreateCompanyPhotoSelected" class="form-control" accept="image/*" />
                        @if (!string.IsNullOrEmpty(_companyCreate.PhotoBase64))
                        {
                            <div class="photo-preview">
                                <img src="@GetPhotoDataUri(_companyCreate.PhotoBase64)" alt="Preview" />
                                <button type="button" class="btn btn-sm btn-secondary" @onclick="() => { _companyCreate.PhotoBase64 = null; _companyCreate.PhotoFileName = null; }"><i class="fa-sharp fa-light fa-trash"></i> Remove</button>
                            </div>
                        }
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary"><i class="fa-sharp fa-light fa-check"></i> Save Company</button>
                        <button type="button" class="btn btn-secondary" @onclick="() => _showCreateCompany = false">Cancel</button>
                    </div>
                </EditForm>
            </div>
        }

        @if (_companies.Any())
        {
            <div class="card-list">
                @foreach (var company in _companies)
                {
                    <div class="card clickable @(company.Id == _selectedCompanyId ? "setup-selected" : "")" @onclick="() => SelectCompany(company.Id)">
                        @if (!string.IsNullOrEmpty(company.PhotoBase64))
                        {
                            <div class="card-photo">
                                <img src="@GetPhotoDataUri(company.PhotoBase64)" alt="@company.Name" />
                            </div>
                        }
                        <h3>@company.Name</h3>
                        <p class="card-subtitle">@(company.Code ?? "No code") &middot; @(company.Address ?? "No address")</p>
                        <div class="card-stats">
                            <span><i class="fa-sharp fa-light fa-industry"></i> @company.PlantCount plants</span>
                            <span><i class="fa-sharp fa-light fa-gear"></i> @company.TotalEquipment equipment</span>
                        </div>
                        @if (company.Id == _selectedCompanyId)
                        {
                            <span class="active-badge" style="margin-top: var(--spacing-sm);"><i class="fa-sharp fa-light fa-check"></i> Selected</span>
                        }
                    </div>
                }
            </div>
        }
    </div>
}

@* ==================== Step 1: Plants ==================== *@
@if (_currentStep == 1)
{
    <div class="wizard-card">
        <div class="step-intro">
            <div class="step-intro-icon" style="background: var(--color-tint-blue); color: var(--color-primary);">
                <i class="fa-sharp fa-light fa-industry"></i>
            </div>
            <div class="step-intro-content">
                <h2>Add Plants for @_selectedCompanyName</h2>
                <p>Plants are physical locations or facilities within your company. Add each site where safety inspections will take place. You can add contact details and photos to help identify each plant.</p>
            </div>
        </div>

        <div style="display: flex; justify-content: flex-end; margin-bottom: var(--spacing-md);">
            <button class="btn btn-primary" @onclick="() => { _showCreatePlant = true; _showEditPlant = false; _plantCreate = new(); }"><i class="fa-sharp fa-light fa-plus"></i> Add Plant</button>
        </div>

        @if (_showCreatePlant)
        {
            <div class="setup-item-card">
                <div class="setup-item-header">
                    <h3><i class="fa-sharp fa-light fa-plus" style="color: var(--color-primary);"></i> New Plant</h3>
                    <button class="btn btn-sm btn-ghost" @onclick="() => _showCreatePlant = false"><i class="fa-sharp fa-light fa-xmark"></i> Cancel</button>
                </div>
                <EditForm Model="_plantCreate" OnValidSubmit="CreatePlant">
                    <div class="form-row">
                        <div class="form-group">
                            <label>Name *</label>
                            <InputText @bind-Value="_plantCreate.Name" class="form-control" placeholder="e.g. Main Manufacturing Plant" />
                        </div>
                        <div class="form-group">
                            <label>Description</label>
                            <InputText @bind-Value="_plantCreate.Description" class="form-control" placeholder="Brief description of this facility" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Contact Name</label>
                            <InputText @bind-Value="_plantCreate.ContactName" class="form-control" placeholder="Site manager" />
                        </div>
                        <div class="form-group">
                            <label>Contact Phone</label>
                            <InputText @bind-Value="_plantCreate.ContactPhone" class="form-control" placeholder="+1 (555) 000-0000" />
                        </div>
                        <div class="form-group">
                            <label>Contact Email</label>
                            <InputText @bind-Value="_plantCreate.ContactEmail" class="form-control" placeholder="manager@example.com" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Photo</label>
                        <InputFile OnChange="OnCreatePlantPhotoSelected" class="form-control" accept="image/*" />
                        @if (!string.IsNullOrEmpty(_plantCreate.PhotoBase64))
                        {
                            <div class="photo-preview">
                                <img src="@GetPhotoDataUri(_plantCreate.PhotoBase64)" alt="Preview" />
                                <button type="button" class="btn btn-sm btn-secondary" @onclick="() => { _plantCreate.PhotoBase64 = null; _plantCreate.PhotoFileName = null; }"><i class="fa-sharp fa-light fa-trash"></i> Remove</button>
                            </div>
                        }
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary"><i class="fa-sharp fa-light fa-check"></i> Save Plant</button>
                        <button type="button" class="btn btn-secondary" @onclick="() => _showCreatePlant = false">Cancel</button>
                    </div>
                </EditForm>
            </div>
        }

        @if (_showEditPlant)
        {
            <div class="setup-item-card">
                <div class="setup-item-header">
                    <h3><i class="fa-sharp fa-light fa-pen" style="color: var(--color-primary);"></i> Edit Plant</h3>
                    <button class="btn btn-sm btn-ghost" @onclick="() => _showEditPlant = false"><i class="fa-sharp fa-light fa-xmark"></i> Cancel</button>
                </div>
                <EditForm Model="_plantEdit" OnValidSubmit="UpdatePlant">
                    <div class="form-row">
                        <div class="form-group">
                            <label>Name *</label>
                            <InputText @bind-Value="_plantEdit.Name" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Description</label>
                            <InputText @bind-Value="_plantEdit.Description" class="form-control" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Contact Name</label>
                            <InputText @bind-Value="_plantEdit.ContactName" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Contact Phone</label>
                            <InputText @bind-Value="_plantEdit.ContactPhone" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Contact Email</label>
                            <InputText @bind-Value="_plantEdit.ContactEmail" class="form-control" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Photo</label>
                        <InputFile OnChange="OnEditPlantPhotoSelected" class="form-control" accept="image/*" />
                        @if (!string.IsNullOrEmpty(_plantEdit.PhotoBase64))
                        {
                            <div class="photo-preview">
                                <img src="@GetPhotoDataUri(_plantEdit.PhotoBase64)" alt="Preview" />
                                <button type="button" class="btn btn-sm btn-secondary" @onclick="() => { _plantEdit.PhotoBase64 = string.Empty; _plantEdit.PhotoFileName = null; }">Remove</button>
                            </div>
                        }
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Update Plant</button>
                        <button type="button" class="btn btn-secondary" @onclick="() => _showEditPlant = false">Cancel</button>
                    </div>
                </EditForm>
            </div>
        }

        <div class="card-list" style="margin-top: var(--spacing-md);">
            @foreach (var plant in _plants)
            {
                <div class="card">
                    @if (!string.IsNullOrEmpty(plant.PhotoBase64))
                    {
                        <div class="card-photo">
                            <img src="@GetPhotoDataUri(plant.PhotoBase64)" alt="@plant.Name" />
                        </div>
                    }
                    <div class="card-header-row">
                        <h3>@plant.Name</h3>
                        <div class="card-edit-btn">
                            <button class="btn btn-sm btn-secondary" @onclick="() => StartEditPlant(plant)">Edit</button>
                        </div>
                    </div>
                    <p class="card-subtitle">@(plant.Description ?? "No description")</p>
                    <p class="card-subtitle"><i class="fa-sharp fa-light fa-user"></i> @(plant.ContactName ?? "No contact")</p>
                    <div class="card-stats">
                        <span>@plant.SectionCount sections</span>
                        <span>@plant.EquipmentCount equipment</span>
                    </div>
                </div>
            }
        </div>

        @if (!_plants.Any() && !_showCreatePlant)
        {
            <div class="empty-state">
                <i class="fa-sharp fa-light fa-industry"></i>
                No plants yet. Click "Add Plant" above to create your first facility.
            </div>
        }
    </div>
}

@* ==================== Step 2: Sections ==================== *@
@if (_currentStep == 2)
{
    <div class="wizard-card">
        <div class="step-intro">
            <div class="step-intro-icon" style="background: var(--color-tint-blue); color: var(--color-primary);">
                <i class="fa-sharp fa-light fa-layer-group"></i>
            </div>
            <div class="step-intro-content">
                <h2>Define Sections</h2>
                <p>Sections are areas or zones within a plant where equipment is located. For example: "Boiler Room", "Workshop A", or "Warehouse". Group your equipment logically for easier inspection rounds.</p>
            </div>
        </div>

        @if (_plants.Any())
        {
            <div class="setup-plant-selector">
                <label><i class="fa-sharp fa-light fa-industry"></i> Plant:</label>
                <select class="form-control" value="@_selectedPlantId" @onchange="OnPlantChanged">
                    @foreach (var plant in _plants)
                    {
                        <option value="@plant.Id">@plant.Name (@plant.SectionCount sections)</option>
                    }
                </select>
                @if (_selectedPlantId > 0)
                {
                    <button class="btn btn-primary" @onclick="() => { _showCreateSection = true; _showEditSection = false; _sectionCreate = new(); }"><i class="fa-sharp fa-light fa-plus"></i> Add Section</button>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fa-sharp fa-light fa-arrow-left"></i>
                No plants available. Go back to the previous step and add plants first.
            </div>
        }

        @if (_showCreateSection)
        {
            <div class="setup-item-card">
                <div class="setup-item-header">
                    <h3><i class="fa-sharp fa-light fa-plus" style="color: var(--color-primary);"></i> New Section</h3>
                    <button class="btn btn-sm btn-ghost" @onclick="() => _showCreateSection = false"><i class="fa-sharp fa-light fa-xmark"></i> Cancel</button>
                </div>
                <EditForm Model="_sectionCreate" OnValidSubmit="CreateSection">
                    <div class="form-row">
                        <div class="form-group">
                            <label>Name *</label>
                            <InputText @bind-Value="_sectionCreate.Name" class="form-control" placeholder="e.g. Boiler Room" />
                        </div>
                        <div class="form-group">
                            <label>Description</label>
                            <InputText @bind-Value="_sectionCreate.Description" class="form-control" placeholder="Brief description of this area" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Photo</label>
                        <InputFile OnChange="OnCreateSectionPhotoSelected" class="form-control" accept="image/*" />
                        @if (!string.IsNullOrEmpty(_sectionCreate.PhotoBase64))
                        {
                            <div class="photo-preview">
                                <img src="@GetPhotoDataUri(_sectionCreate.PhotoBase64)" alt="Preview" />
                                <button type="button" class="btn btn-sm btn-secondary" @onclick="() => { _sectionCreate.PhotoBase64 = null; _sectionCreate.PhotoFileName = null; }"><i class="fa-sharp fa-light fa-trash"></i> Remove</button>
                            </div>
                        }
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary"><i class="fa-sharp fa-light fa-check"></i> Save Section</button>
                        <button type="button" class="btn btn-secondary" @onclick="() => _showCreateSection = false">Cancel</button>
                    </div>
                </EditForm>
            </div>
        }

        @if (_showEditSection)
        {
            <div class="setup-item-card">
                <div class="setup-item-header">
                    <h3><i class="fa-sharp fa-light fa-pen" style="color: var(--color-primary);"></i> Edit Section</h3>
                    <button class="btn btn-sm btn-ghost" @onclick="() => _showEditSection = false"><i class="fa-sharp fa-light fa-xmark"></i> Cancel</button>
                </div>
                <EditForm Model="_sectionEdit" OnValidSubmit="UpdateSection">
                    <div class="form-row">
                        <div class="form-group">
                            <label>Name *</label>
                            <InputText @bind-Value="_sectionEdit.Name" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Description</label>
                            <InputText @bind-Value="_sectionEdit.Description" class="form-control" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Photo</label>
                        <InputFile OnChange="OnEditSectionPhotoSelected" class="form-control" accept="image/*" />
                        @if (!string.IsNullOrEmpty(_sectionEdit.PhotoBase64))
                        {
                            <div class="photo-preview">
                                <img src="@GetPhotoDataUri(_sectionEdit.PhotoBase64)" alt="Preview" />
                                <button type="button" class="btn btn-sm btn-secondary" @onclick="() => { _sectionEdit.PhotoBase64 = string.Empty; _sectionEdit.PhotoFileName = null; }">Remove</button>
                            </div>
                        }
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Update Section</button>
                        <button type="button" class="btn btn-secondary" @onclick="() => _showEditSection = false">Cancel</button>
                    </div>
                </EditForm>
            </div>
        }

        @if (_selectedPlantId > 0)
        {
            <div class="card-list" style="margin-top: var(--spacing-md);">
                @foreach (var sec in _sections)
                {
                    <div class="card">
                        @if (!string.IsNullOrEmpty(sec.PhotoBase64))
                        {
                            <div class="card-photo">
                                <img src="@GetPhotoDataUri(sec.PhotoBase64)" alt="@sec.Name" />
                            </div>
                        }
                        <div class="card-header-row">
                            <h3>@sec.Name</h3>
                            <div class="card-edit-btn">
                                <button class="btn btn-sm btn-secondary" @onclick="() => StartEditSection(sec)">Edit</button>
                            </div>
                        </div>
                        <p class="card-subtitle">@(sec.Description ?? "No description")</p>
                        <div class="card-stats">
                            <span>@sec.EquipmentCount equipment</span>
                            <span>Sort: @sec.SortOrder</span>
                        </div>
                    </div>
                }
            </div>

            @if (!_sections.Any() && !_showCreateSection)
            {
                <div class="empty-state">
                    <i class="fa-sharp fa-light fa-layer-group"></i>
                    No sections for this plant yet. Click "Add Section" to create zones or areas.
                </div>
            }
        }
    </div>
}

@* ==================== Step 3: Equipment ==================== *@
@if (_currentStep == 3)
{
    <div class="wizard-card">
        <div class="step-intro">
            <div class="step-intro-icon" style="background: var(--color-tint-green); color: var(--color-success);">
                <i class="fa-sharp fa-light fa-gear"></i>
            </div>
            <div class="step-intro-content">
                <h2>Register Equipment</h2>
                <p>Add the equipment that needs to be inspected in each section. Each piece of equipment gets a unique identifier (e.g. "FE-01" for Fire Extinguisher 1) and is assigned a type. This equipment will appear on your inspection checklists.</p>
            </div>
        </div>

        @if (_plants.Any())
        {
            <div class="setup-plant-selector">
                <label><i class="fa-sharp fa-light fa-industry"></i> Plant:</label>
                <select class="form-control" value="@_selectedPlantId" @onchange="OnPlantChanged">
                    @foreach (var plant in _plants)
                    {
                        <option value="@plant.Id">@plant.Name</option>
                    }
                </select>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fa-sharp fa-light fa-arrow-left"></i>
                No plants available. Go back and add plants first.
            </div>
        }

        @if (_selectedPlantId > 0 && _sections.Any())
        {
            @foreach (var sec in _sections)
            {
                <div class="setup-section-group">
                    <div class="setup-item-header">
                        <h4><i class="fa-sharp fa-light fa-layer-group" style="color: var(--color-primary);"></i> @sec.Name</h4>
                        <button class="btn btn-sm btn-primary" @onclick="() => StartCreateEquipment(sec.Id)"><i class="fa-sharp fa-light fa-plus"></i> Add Equipment</button>
                    </div>

                    @if (GetEquipmentForSection(sec.Id).Any())
                    {
                        <div style="overflow-x: auto;">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>Identifier</th>
                                        <th>Type</th>
                                        <th>Spec</th>
                                        <th>Notes</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var eq in GetEquipmentForSection(sec.Id))
                                    {
                                        <tr class="@(!eq.IsActive ? "row-inactive" : "")">
                                            <td><strong>@eq.Identifier</strong></td>
                                            <td>@eq.EquipmentTypeName</td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(eq.SubTypeName))
                                                {
                                                    <span class="badge-spec">@eq.SubTypeName</span>
                                                }
                                                else if (!string.IsNullOrEmpty(eq.Size))
                                                {
                                                    @eq.Size
                                                }
                                                else
                                                {
                                                    <span class="text-muted">—</span>
                                                }
                                            </td>
                                            <td class="col-notes">@(string.IsNullOrEmpty(eq.Description) ? "—" : eq.Description)</td>
                                            <td>
                                                @if (eq.IsActive)
                                                {
                                                    <span class="active-badge">Active</span>
                                                }
                                                else
                                                {
                                                    <span class="inactive-badge">Inactive</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="action-buttons">
                                                    <button class="btn btn-xs btn-secondary" @onclick="() => StartEditEquipment(eq)">Edit</button>
                                                    <button class="btn btn-xs @(eq.IsActive ? "btn-secondary" : "btn-primary")" @onclick="() => ToggleEquipmentActive(eq)">
                                                        @(eq.IsActive ? "Deactivate" : "Activate")
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state" style="margin-top: var(--spacing-sm);">
                            <i class="fa-sharp fa-light fa-gear"></i>
                            No equipment in this section yet. Click "Add Equipment" to register items.
                        </div>
                    }
                </div>
            }
        }
        else if (_selectedPlantId > 0 && !_sections.Any())
        {
            <div class="empty-state">
                <i class="fa-sharp fa-light fa-arrow-left"></i>
                No sections for this plant. Go back to Step 3 to add sections first.
            </div>
        }
    </div>

    @* Equipment Create Modal *@
    @if (_showCreateEquipment)
    {
        <div class="modal-overlay" @onclick="() => _showCreateEquipment = false">
            <div class="modal" @onclick:stopPropagation>
                <h2>Add Equipment</h2>
                <EditForm Model="_equipmentCreate" OnValidSubmit="CreateEquipment">
                    <div class="form-row">
                        <div class="form-group">
                            <label>Identifier *</label>
                            <InputText @bind-Value="_equipmentCreate.Identifier" class="form-control" placeholder="e.g. FE-01" />
                        </div>
                        <div class="form-group">
                            <label>Equipment Type *</label>
                            <select class="form-control" value="@_equipmentCreate.EquipmentTypeId" @onchange="OnCreateEquipmentTypeChanged">
                                <option value="0">-- Select Type --</option>
                                @foreach (var t in _equipmentTypes)
                                {
                                    <option value="@t.Id">@t.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    @if (_createSubTypes.Any())
                    {
                        <div class="form-group">
                            <label>Sub-Type</label>
                            <select class="form-control" value="@_equipmentCreate.EquipmentSubTypeId" @onchange="OnCreateEquipmentSubTypeChanged">
                                <option value="">-- Optional --</option>
                                @foreach (var st in _createSubTypes)
                                {
                                    <option value="@st.Id">@st.Name</option>
                                }
                            </select>
                        </div>
                    }
                    <div class="form-row">
                        <div class="form-group">
                            <label>Size / Spec</label>
                            @if (_equipmentCreate.EquipmentSubTypeId.HasValue)
                            {
                                <input type="text" class="form-control form-control-muted" readonly value="@_equipmentCreate.Size" />
                                <small class="form-hint">Auto-set from sub-type</small>
                            }
                            else
                            {
                                <InputText @bind-Value="_equipmentCreate.Size" class="form-control" placeholder="e.g. 9kg, 30m, 500ml" />
                            }
                        </div>
                        <div class="form-group">
                            <label>Serial Number</label>
                            <InputText @bind-Value="_equipmentCreate.SerialNumber" class="form-control" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Notes <span class="text-muted">(optional)</span></label>
                        <InputText @bind-Value="_equipmentCreate.Description" class="form-control" placeholder="e.g. Main entrance, Left wall" />
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Save Equipment</button>
                        <button type="button" class="btn btn-secondary" @onclick="() => _showCreateEquipment = false">Cancel</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    @* Equipment Edit Modal *@
    @if (_showEditEquipment)
    {
        <div class="modal-overlay" @onclick="() => _showEditEquipment = false">
            <div class="modal" @onclick:stopPropagation>
                <h2>Edit Equipment</h2>
                <EditForm Model="_equipmentEdit" OnValidSubmit="UpdateEquipment">
                    <div class="form-row">
                        <div class="form-group">
                            <label>Identifier *</label>
                            <InputText @bind-Value="_equipmentEdit.Identifier" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Equipment Type *</label>
                            <select class="form-control" value="@_equipmentEdit.EquipmentTypeId" @onchange="OnEditEquipmentTypeChanged">
                                <option value="0">-- Select Type --</option>
                                @foreach (var t in _equipmentTypes)
                                {
                                    <option value="@t.Id">@t.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    @if (_editSubTypes.Any())
                    {
                        <div class="form-group">
                            <label>Sub-Type</label>
                            <select class="form-control" value="@_equipmentEdit.EquipmentSubTypeId" @onchange="OnEditEquipmentSubTypeChanged">
                                <option value="">-- None --</option>
                                @foreach (var st in _editSubTypes)
                                {
                                    <option value="@st.Id">@st.Name</option>
                                }
                            </select>
                        </div>
                    }
                    <div class="form-row">
                        <div class="form-group">
                            <label>Size / Spec</label>
                            @if (_equipmentEdit.EquipmentSubTypeId.HasValue)
                            {
                                <input type="text" class="form-control form-control-muted" readonly value="@_equipmentEdit.Size" />
                                <small class="form-hint">Auto-set from sub-type</small>
                            }
                            else
                            {
                                <InputText @bind-Value="_equipmentEdit.Size" class="form-control" placeholder="e.g. 9kg, 30m, 500ml" />
                            }
                        </div>
                        <div class="form-group">
                            <label>Serial Number</label>
                            <InputText @bind-Value="_equipmentEdit.SerialNumber" class="form-control" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Notes <span class="text-muted">(optional)</span></label>
                        <InputText @bind-Value="_equipmentEdit.Description" class="form-control" placeholder="e.g. Main entrance, Left wall" />
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Update Equipment</button>
                        <button type="button" class="btn btn-secondary" @onclick="() => _showEditEquipment = false">Cancel</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }
}

@* ==================== Step 4: Review ==================== *@
@if (_currentStep == 4)
{
    <div class="wizard-card">
        <div class="step-intro">
            <div class="step-intro-icon" style="background: var(--color-tint-orange); color: var(--color-warning);">
                <i class="fa-sharp fa-light fa-clipboard-check"></i>
            </div>
            <div class="step-intro-content">
                <h2>Review Your Setup</h2>
                <p>Review your complete organizational hierarchy below. If anything looks wrong, use the "Back" button to go to any previous step and make changes. When you're satisfied, click "Done" to finish.</p>
            </div>
        </div>

        @if (_reviewData is not null)
        {
            <div class="review-summary" style="margin-bottom: var(--spacing-lg);">
                <div class="stat-card">
                    <div class="stat-value">@_reviewData.Plants.Count</div>
                    <div class="stat-label">Plants</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">@_reviewData.Plants.Sum(p => p.Sections.Count)</div>
                    <div class="stat-label">Sections</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">@_reviewData.Plants.Sum(p => p.Sections.Sum(s => s.Equipment.Count))</div>
                    <div class="stat-label">Equipment</div>
                </div>
            </div>

            <div class="review-tree">
                <div class="tree-node tree-company">
                    <div class="tree-node-header">
                        <i class="fa-sharp fa-light fa-building tree-icon"></i>
                        <strong>@_reviewData.Company.Name</strong>
                        @if (_reviewData.Company.Code is not null)
                        {
                            <span class="card-subtitle">(@_reviewData.Company.Code)</span>
                        }
                    </div>

                    @foreach (var rp in _reviewData.Plants)
                    {
                        <div class="tree-node tree-plant">
                            <div class="tree-node-header">
                                <i class="fa-sharp fa-light fa-industry tree-icon"></i>
                                <strong>@rp.Plant.Name</strong>
                                <span class="card-subtitle">(@rp.Sections.Count sections, @rp.Sections.Sum(s => s.Equipment.Count) equipment)</span>
                            </div>

                            @foreach (var rs in rp.Sections)
                            {
                                <div class="tree-node tree-section">
                                    <div class="tree-node-header">
                                        <i class="fa-sharp fa-light fa-folder tree-icon"></i>
                                        <strong>@rs.Section.Name</strong>
                                        <span class="card-subtitle">(@rs.Equipment.Count equipment)</span>
                                    </div>

                                    @foreach (var eq in rs.Equipment)
                                    {
                                        <div class="tree-node tree-equipment">
                                            <i class="fa-sharp fa-light fa-gear tree-icon"></i>
                                            <span>@eq.Identifier</span>
                                            <span class="card-subtitle">@eq.EquipmentTypeName</span>
                                            @if (eq.SubTypeName is not null)
                                            {
                                                <span class="card-subtitle">/ @eq.SubTypeName</span>
                                            }
                                            @if (!eq.IsActive)
                                            {
                                                <span class="inactive-badge">Inactive</span>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <p>Loading review data...</p>
        }
    </div>
}

<div class="wizard-actions">
    @if (_currentStep > 0)
    {
        <button class="btn btn-secondary" @onclick="PreviousStep"><i class="fa-sharp fa-light fa-arrow-left"></i> Back</button>
    }
    <div style="flex: 1;"></div>
    @if (_currentStep < _stepNames.Length - 1)
    {
        <button class="btn btn-primary btn-lg" @onclick="NextStep">Continue to @_stepNames[_currentStep + 1] <i class="fa-sharp fa-light fa-arrow-right"></i></button>
    }
    else
    {
        <button class="btn btn-success btn-lg" @onclick="Finish"><i class="fa-sharp fa-light fa-check"></i> Complete Setup</button>
    }
</div>

@code {
    [Parameter] public int Step { get; set; }

    private readonly string[] _stepNames = ["Company", "Plants", "Sections", "Equipment", "Review"];
    private int _currentStep;
    private bool _initialized;
    private string? _errorMessage;

    // Step 0: Company
    private List<CompanyDto> _companies = [];
    private int _selectedCompanyId;
    private string _selectedCompanyName = "";
    private bool _showCreateCompany;
    private CompanyCreateModel _companyCreate = new();

    // Step 1: Plants
    private List<PlantDto> _plants = [];
    private bool _showCreatePlant;
    private bool _showEditPlant;
    private int _editPlantId;
    private PlantCreateModel _plantCreate = new();
    private PlantEditModel _plantEdit = new();

    // Step 2: Sections
    private int _selectedPlantId;
    private List<SectionDto> _sections = [];
    private bool _showCreateSection;
    private bool _showEditSection;
    private int _editSectionId;
    private SectionCreateModel _sectionCreate = new();
    private SectionEditModel _sectionEdit = new();

    // Step 3: Equipment
    private Dictionary<int, List<EquipmentDto>> _sectionEquipment = new();
    private List<EquipmentTypeDto> _equipmentTypes = [];
    private List<EquipmentSubTypeDto> _createSubTypes = [];
    private List<EquipmentSubTypeDto> _editSubTypes = [];
    private bool _showCreateEquipment;
    private bool _showEditEquipment;
    private int _createEquipmentSectionId;
    private int _editEquipmentId;
    private EquipmentCreateModel _equipmentCreate = new();
    private EquipmentEditModel _equipmentEdit = new();

    // Step 4: Review
    private ReviewData? _reviewData;

    protected override async Task OnInitializedAsync()
    {
        _currentStep = Math.Clamp(Step, 0, _stepNames.Length - 1);
        _companies   = await CompanyService.GetAllCompaniesAsync();
        _equipmentTypes = await EquipmentService.GetEquipmentTypesAsync();
        await OnStepEntered();
        _initialized = true;
    }

    protected override async Task OnParametersSetAsync()
    {
        // Respond to browser back/forward or direct URL navigation
        if (_initialized)
        {
            var target = Math.Clamp(Step, 0, _stepNames.Length - 1);
            if (target != _currentStep)
            {
                _currentStep  = target;
                _errorMessage = null;
                await OnStepEntered();
            }
        }
    }

    // ==================== Navigation ====================

    private void GoToStep(int step)
    {
        if (step >= _currentStep) return;   // can only jump backwards in UI
        Navigation.NavigateTo($"/setup/{step}");
    }

    private void NextStep()
    {
        if (!ValidateCurrentStep()) return;
        Navigation.NavigateTo($"/setup/{_currentStep + 1}");
    }

    private void PreviousStep()
    {
        Navigation.NavigateTo($"/setup/{Math.Max(0, _currentStep - 1)}");
    }

    private async Task OnStepEntered()
    {
        _showCreateCompany = false;
        _showCreatePlant = false;
        _showEditPlant = false;
        _showCreateSection = false;
        _showEditSection = false;
        _showCreateEquipment = false;
        _showEditEquipment = false;

        switch (_currentStep)
        {
            case 1:
                await LoadPlants();
                break;
            case 2:
                await LoadPlants();
                if (_plants.Any() && _selectedPlantId == 0)
                    _selectedPlantId = _plants.First().Id;
                if (_selectedPlantId > 0)
                    await LoadSections();
                break;
            case 3:
                await LoadPlants();
                if (_plants.Any() && _selectedPlantId == 0)
                    _selectedPlantId = _plants.First().Id;
                if (_selectedPlantId > 0)
                {
                    await LoadSections();
                    await LoadAllSectionEquipment();
                }
                break;
            case 4:
                await LoadReviewData();
                break;
        }
    }

    private bool ValidateCurrentStep()
    {
        _errorMessage = null;
        switch (_currentStep)
        {
            case 0:
                if (_selectedCompanyId == 0)
                {
                    _errorMessage = "Please select a company before continuing.";
                    return false;
                }
                break;
            case 1:
                if (!_plants.Any())
                {
                    _errorMessage = "Add at least one plant before continuing.";
                    return false;
                }
                break;
        }
        return true;
    }

    // ==================== Data Loading ====================

    private async Task LoadPlants()
    {
        if (_selectedCompanyId > 0)
            _plants = await PlantService.GetPlantsByCompanyAsync(_selectedCompanyId);
    }

    private async Task LoadSections()
    {
        if (_selectedPlantId > 0)
            _sections = await SectionService.GetSectionsByPlantAsync(_selectedPlantId);
        else
            _sections = [];
    }

    private async Task LoadAllSectionEquipment()
    {
        _sectionEquipment.Clear();
        foreach (var section in _sections)
        {
            var equipment = await EquipmentService.GetEquipmentBySectionAsync(section.Id, includeInactive: true);
            _sectionEquipment[section.Id] = equipment;
        }
    }

    private List<EquipmentDto> GetEquipmentForSection(int sectionId)
        => _sectionEquipment.TryGetValue(sectionId, out var list) ? list : [];

    private async Task LoadReviewData()
    {
        var company = await CompanyService.GetCompanyByIdAsync(_selectedCompanyId);
        if (company is null) return;

        _reviewData = new ReviewData { Company = company };
        var plants = await PlantService.GetPlantsByCompanyAsync(_selectedCompanyId);
        foreach (var plant in plants)
        {
            var rp = new ReviewPlantData { Plant = plant };
            var sections = await SectionService.GetSectionsByPlantAsync(plant.Id);
            foreach (var section in sections)
            {
                var equipment = await EquipmentService.GetEquipmentBySectionAsync(section.Id);
                rp.Sections.Add(new ReviewSectionData { Section = section, Equipment = equipment });
            }
            _reviewData.Plants.Add(rp);
        }
    }

    // ==================== Step 0: Company ====================

    private void SelectCompany(int id)
    {
        _selectedCompanyId = id;
        _selectedCompanyName = _companies.FirstOrDefault(c => c.Id == id)?.Name ?? "";
    }

    private async Task CreateCompany()
    {
        if (string.IsNullOrWhiteSpace(_companyCreate.Name))
        {
            _errorMessage = "Company name is required.";
            return;
        }
        var dto = new CompanyCreateDto(_companyCreate.Name, _companyCreate.Code, _companyCreate.Address,
            _companyCreate.ContactName, _companyCreate.ContactEmail, _companyCreate.ContactPhone,
            _companyCreate.PhotoBase64, _companyCreate.PhotoFileName);
        var created = await CompanyService.CreateCompanyAsync(dto, "current-user");
        _companies = await CompanyService.GetAllCompaniesAsync();
        SelectCompany(created.Id);
        _showCreateCompany = false;
        _companyCreate = new();
    }

    // ==================== Step 1: Plants ====================

    private void StartEditPlant(PlantDto plant)
    {
        _editPlantId = plant.Id;
        _plantEdit = new PlantEditModel
        {
            Name = plant.Name,
            Description = plant.Description,
            ContactName = plant.ContactName,
            ContactPhone = plant.ContactPhone,
            ContactEmail = plant.ContactEmail,
            IsActive = plant.IsActive,
            PhotoBase64 = plant.PhotoBase64,
            PhotoFileName = plant.PhotoFileName
        };
        _showEditPlant = true;
        _showCreatePlant = false;
    }

    private async Task CreatePlant()
    {
        if (string.IsNullOrWhiteSpace(_plantCreate.Name))
        {
            _errorMessage = "Plant name is required.";
            return;
        }
        var dto = new PlantCreateDto(_selectedCompanyId, _plantCreate.Name, _plantCreate.Description,
            _plantCreate.ContactName, _plantCreate.ContactPhone, _plantCreate.ContactEmail,
            _plantCreate.PhotoBase64, _plantCreate.PhotoFileName);
        await PlantService.CreatePlantAsync(dto, "current-user");
        await LoadPlants();
        _showCreatePlant = false;
        _plantCreate = new();
    }

    private async Task UpdatePlant()
    {
        var dto = new PlantUpdateDto(_editPlantId, _plantEdit.Name, _plantEdit.Description,
            _plantEdit.ContactName, _plantEdit.ContactPhone, _plantEdit.ContactEmail,
            _plantEdit.IsActive, _plantEdit.PhotoBase64, _plantEdit.PhotoFileName);
        await PlantService.UpdatePlantAsync(dto, "current-user");
        await LoadPlants();
        _showEditPlant = false;
        _plantEdit = new();
    }

    // ==================== Step 2: Sections ====================

    private async Task OnPlantChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id))
        {
            _selectedPlantId = id;
            _showCreateSection = false;
            _showEditSection = false;
            await LoadSections();
            if (_currentStep == 3)
                await LoadAllSectionEquipment();
        }
    }

    private void StartEditSection(SectionDto section)
    {
        _editSectionId = section.Id;
        _sectionEdit = new SectionEditModel
        {
            Name = section.Name,
            Description = section.Description,
            SortOrder = section.SortOrder,
            IsActive = section.IsActive,
            PhotoBase64 = section.PhotoBase64,
            PhotoFileName = section.PhotoFileName
        };
        _showEditSection = true;
        _showCreateSection = false;
    }

    private async Task CreateSection()
    {
        if (string.IsNullOrWhiteSpace(_sectionCreate.Name))
        {
            _errorMessage = "Section name is required.";
            return;
        }
        var sortOrder = _sections.Any() ? _sections.Max(s => s.SortOrder) + 1 : 1;
        var dto = new SectionCreateDto(_selectedPlantId, _sectionCreate.Name, _sectionCreate.Description,
            sortOrder, _sectionCreate.PhotoBase64, _sectionCreate.PhotoFileName);
        await SectionService.CreateSectionAsync(dto, "current-user");
        await LoadSections();
        _showCreateSection = false;
        _sectionCreate = new();
    }

    private async Task UpdateSection()
    {
        var dto = new SectionUpdateDto(_editSectionId, _sectionEdit.Name, _sectionEdit.Description,
            _sectionEdit.SortOrder, _sectionEdit.IsActive, _sectionEdit.PhotoBase64, _sectionEdit.PhotoFileName);
        await SectionService.UpdateSectionAsync(dto, "current-user");
        await LoadSections();
        _showEditSection = false;
        _sectionEdit = new();
    }

    // ==================== Step 3: Equipment ====================

    private void StartCreateEquipment(int sectionId)
    {
        _createEquipmentSectionId = sectionId;
        _equipmentCreate = new();
        _createSubTypes = [];
        _showCreateEquipment = true;
        _showEditEquipment = false;
    }

    private async Task StartEditEquipment(EquipmentDto eq)
    {
        _editEquipmentId = eq.Id;
        _equipmentEdit = new EquipmentEditModel
        {
            EquipmentTypeId = eq.EquipmentTypeId,
            EquipmentSubTypeId = eq.EquipmentSubTypeId,
            Identifier = eq.Identifier,
            Description = eq.Description,
            Size = eq.Size,
            SerialNumber = eq.SerialNumber,
            SortOrder = eq.SortOrder,
            IsActive = eq.IsActive
        };
        _editSubTypes = eq.EquipmentTypeId > 0
            ? await EquipmentService.GetSubTypesByTypeAsync(eq.EquipmentTypeId)
            : [];
        _showEditEquipment = true;
        _showCreateEquipment = false;
    }

    private async Task OnCreateEquipmentTypeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var typeId))
        {
            _equipmentCreate.EquipmentTypeId    = typeId;
            _equipmentCreate.EquipmentSubTypeId = null;
            _equipmentCreate.Size               = string.Empty;
            _createSubTypes = typeId > 0
                ? await EquipmentService.GetSubTypesByTypeAsync(typeId)
                : [];
        }
    }

    private async Task OnEditEquipmentTypeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var typeId))
        {
            _equipmentEdit.EquipmentTypeId    = typeId;
            _equipmentEdit.EquipmentSubTypeId = null;
            _equipmentEdit.Size               = string.Empty;
            _editSubTypes = typeId > 0
                ? await EquipmentService.GetSubTypesByTypeAsync(typeId)
                : [];
        }
    }

    private void OnCreateEquipmentSubTypeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id))
        {
            _equipmentCreate.EquipmentSubTypeId = id;
            var st = _createSubTypes.FirstOrDefault(s => s.Id == id);
            if (st != null) _equipmentCreate.Size = st.Name;
        }
        else
        {
            _equipmentCreate.EquipmentSubTypeId = null;
        }
    }

    private void OnEditEquipmentSubTypeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id))
        {
            _equipmentEdit.EquipmentSubTypeId = id;
            var st = _editSubTypes.FirstOrDefault(s => s.Id == id);
            if (st != null) _equipmentEdit.Size = st.Name;
        }
        else
        {
            _equipmentEdit.EquipmentSubTypeId = null;
        }
    }

    private async Task CreateEquipment()
    {
        if (string.IsNullOrWhiteSpace(_equipmentCreate.Identifier))
        {
            _errorMessage = "Equipment identifier is required.";
            return;
        }
        if (_equipmentCreate.EquipmentTypeId == 0)
        {
            _errorMessage = "Equipment type is required.";
            return;
        }
        var existing = GetEquipmentForSection(_createEquipmentSectionId);
        var sortOrder = existing.Any() ? existing.Max(e => e.SortOrder) + 1 : 1;
        var dto = new EquipmentCreateDto(_createEquipmentSectionId, _equipmentCreate.EquipmentTypeId,
            _equipmentCreate.EquipmentSubTypeId, _equipmentCreate.Identifier, _equipmentCreate.Description,
            _equipmentCreate.Size, _equipmentCreate.SerialNumber, null, null, sortOrder);
        await EquipmentService.CreateEquipmentAsync(dto, "current-user");
        await LoadAllSectionEquipment();
        _showCreateEquipment = false;
        _equipmentCreate = new();
        _createSubTypes = [];
    }

    private async Task UpdateEquipment()
    {
        var dto = new EquipmentUpdateDto(_editEquipmentId, _equipmentEdit.EquipmentTypeId,
            _equipmentEdit.EquipmentSubTypeId, _equipmentEdit.Identifier, _equipmentEdit.Description,
            _equipmentEdit.Size, _equipmentEdit.SerialNumber, null, _equipmentEdit.SortOrder, _equipmentEdit.IsActive);
        await EquipmentService.UpdateEquipmentAsync(dto, "current-user");
        await LoadAllSectionEquipment();
        _showEditEquipment = false;
        _equipmentEdit = new();
        _editSubTypes = [];
    }

    private async Task ToggleEquipmentActive(EquipmentDto eq)
    {
        var dto = new EquipmentUpdateDto(eq.Id, eq.EquipmentTypeId, eq.EquipmentSubTypeId,
            eq.Identifier, eq.Description, eq.Size, eq.SerialNumber, eq.NextServiceDate,
            eq.SortOrder, !eq.IsActive);
        await EquipmentService.UpdateEquipmentAsync(dto, "current-user");
        await LoadAllSectionEquipment();
    }

    // ==================== Photo Handlers ====================

    private async Task OnCreateCompanyPhotoSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            _companyCreate.PhotoBase64 = Convert.ToBase64String(ms.ToArray());
            _companyCreate.PhotoFileName = file.Name;
        }
        catch { /* file too large or read error */ }
    }

    private async Task OnCreatePlantPhotoSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            _plantCreate.PhotoBase64 = Convert.ToBase64String(ms.ToArray());
            _plantCreate.PhotoFileName = file.Name;
        }
        catch { /* file too large or read error */ }
    }

    private async Task OnEditPlantPhotoSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            _plantEdit.PhotoBase64 = Convert.ToBase64String(ms.ToArray());
            _plantEdit.PhotoFileName = file.Name;
        }
        catch { /* file too large or read error */ }
    }

    private async Task OnCreateSectionPhotoSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            _sectionCreate.PhotoBase64 = Convert.ToBase64String(ms.ToArray());
            _sectionCreate.PhotoFileName = file.Name;
        }
        catch { /* file too large or read error */ }
    }

    private async Task OnEditSectionPhotoSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            _sectionEdit.PhotoBase64 = Convert.ToBase64String(ms.ToArray());
            _sectionEdit.PhotoFileName = file.Name;
        }
        catch { /* file too large or read error */ }
    }

    private static string GetPhotoDataUri(string base64)
    {
        var mime = base64 switch
        {
            _ when base64.StartsWith("/9j/") => "image/jpeg",
            _ when base64.StartsWith("iVBOR") => "image/png",
            _ when base64.StartsWith("R0lG") => "image/gif",
            _ when base64.StartsWith("UklG") => "image/webp",
            _ => "image/png"
        };
        return $"data:{mime};base64,{base64}";
    }

