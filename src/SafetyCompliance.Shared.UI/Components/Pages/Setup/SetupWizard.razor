@page "/setup"
@inject ICompanyService CompanyService
@inject IPlantService PlantService
@inject ISectionService SectionService
@inject IEquipmentService EquipmentService
@inject NavigationManager Navigation

<div class="page-header">
    <div>
        <h1>Setup Wizard</h1>
        <p class="card-subtitle">Build your organizational hierarchy step by step</p>
    </div>
</div>

<div class="wizard-progress">
    @for (int i = 0; i < _stepNames.Length; i++)
    {
        var stepIndex = i;
        <div class="wizard-step @(stepIndex == _currentStep ? "active" : "") @(stepIndex < _currentStep ? "completed" : "")"
             style="cursor: @(stepIndex < _currentStep ? "pointer" : "default")"
             @onclick="() => GoToStep(stepIndex)">
            <div class="step-number">
                @if (stepIndex < _currentStep)
                {
                    <i class="fa-light fa-check"></i>
                }
                else
                {
                    @((stepIndex + 1).ToString())
                }
            </div>
            <div class="step-label">@_stepNames[stepIndex]</div>
        </div>
        @if (i < _stepNames.Length - 1)
        {
            <div class="step-connector @(stepIndex < _currentStep ? "completed" : "")"></div>
        }
    }
</div>

@if (_errorMessage is not null)
{
    <div class="error-message">@_errorMessage</div>
}

@* ==================== Step 0: Company ==================== *@
@if (_currentStep == 0)
{
    <div class="wizard-card">
        <div class="step-intro">
            <div class="step-intro-icon">
                <i class="fa-light fa-building"></i>
            </div>
            <div class="step-intro-content">
                <h2>Select Your Company</h2>
                <p>Choose the company you want to set up. If your company isn't listed yet, create a new one. Each company can have multiple plants, sections, and equipment.</p>
            </div>
        </div>

        @if (!_companies.Any() && !_showCreateCompany)
        {
            <div class="empty-state">
                <i class="fa-light fa-building"></i>
                No companies yet. Create your first company to get started.
                <div style="margin-top: var(--spacing-md);">
                    <button class="btn btn-primary btn-lg" @onclick="() => { _showCreateCompany = true; _companyCreate = new(); }"><i class="fa-light fa-plus"></i> Create Your First Company</button>
                </div>
            </div>
        }
        else if (!_showCreateCompany)
        {
            <div style="display: flex; justify-content: flex-end; margin-bottom: var(--spacing-md);">
                <button class="btn btn-primary" @onclick="() => { _showCreateCompany = true; _companyCreate = new(); }"><i class="fa-light fa-plus"></i> New Company</button>
            </div>
        }

        @if (_showCreateCompany)
        {
            <div class="setup-item-card" style="margin-bottom: var(--spacing-lg);">
                <div class="setup-item-header">
                    <h3><i class="fa-light fa-plus" style="color: var(--color-primary);"></i> Create New Company</h3>
                    <button class="btn btn-sm btn-ghost" @onclick="() => _showCreateCompany = false"><i class="fa-light fa-xmark"></i> Cancel</button>
                </div>
                <EditForm Model="_companyCreate" OnValidSubmit="CreateCompany">
                    <div class="form-row">
                        <div class="form-group">
                            <label>Name *</label>
                            <InputText @bind-Value="_companyCreate.Name" class="form-control" placeholder="e.g. Acme Industries" />
                        </div>
                        <div class="form-group">
                            <label>Code</label>
                            <InputText @bind-Value="_companyCreate.Code" class="form-control" placeholder="e.g. ACME" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Address</label>
                        <InputText @bind-Value="_companyCreate.Address" class="form-control" placeholder="e.g. 123 Industrial Ave" />
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Contact Name</label>
                            <InputText @bind-Value="_companyCreate.ContactName" class="form-control" placeholder="Primary contact" />
                        </div>
                        <div class="form-group">
                            <label>Contact Email</label>
                            <InputText @bind-Value="_companyCreate.ContactEmail" class="form-control" placeholder="email@example.com" />
                        </div>
                        <div class="form-group">
                            <label>Contact Phone</label>
                            <InputText @bind-Value="_companyCreate.ContactPhone" class="form-control" placeholder="+1 (555) 000-0000" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Photo</label>
                        <div class="upload-zone @(_companyCreate.PhotoBase64 is not null ? "upload-zone--has-file" : "")">
                            @if (_companyCreate.PhotoBase64 is not null)
                            {
                                <div class="upload-zone__preview">
                                    <img src="@($"data:image/jpeg;base64,{_companyCreate.PhotoBase64}")" alt="Preview" />
                                    <button type="button" class="upload-zone__remove" @onclick="() => { _companyCreate.PhotoBase64 = null; _companyCreate.PhotoFileName = null; }" @onclick:stopPropagation>
                                        <i class="fa-light fa-xmark"></i>
                                    </button>
                                </div>
                                <span class="upload-zone__preview-label">@_companyCreate.PhotoFileName</span>
                            }
                            else
                            {
                                <div class="upload-zone__empty">
                                    <i class="fa-light fa-camera"></i>
                                    <span>Click to upload photo</span>
                                    <small>JPG, PNG · max 5 MB</small>
                                </div>
                            }
                            <InputFile OnChange="OnCreateCompanyPhotoSelected" class="upload-zone__input" accept="image/*" />
                        </div>
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary"><i class="fa-light fa-check"></i> Save Company</button>
                        <button type="button" class="btn btn-secondary" @onclick="() => _showCreateCompany = false">Cancel</button>
                    </div>
                </EditForm>
            </div>
        }

        @if (_companies.Any())
        {
            <div class="card-list">
                @foreach (var company in _companies)
                {
                    <div class="card clickable @(company.Id == _selectedCompanyId ? "setup-selected" : "")" @onclick="() => SelectCompany(company.Id)">
                        @if (company.PhotoBase64 is not null)
                        {
                            <div class="card-photo">
                                <img src="@($"data:image/jpeg;base64,{company.PhotoBase64}")" alt="@company.Name" />
                            </div>
                        }
                        <h3>@company.Name</h3>
                        <p class="card-subtitle">@(company.Code ?? "No code") &middot; @(company.Address ?? "No address")</p>
                        <div class="card-stats">
                            <span><i class="fa-light fa-industry"></i> @company.PlantCount plants</span>
                            <span><i class="fa-light fa-gear"></i> @company.TotalEquipment equipment</span>
                        </div>
                        @if (company.Id == _selectedCompanyId)
                        {
                            <span class="active-badge" style="margin-top: var(--spacing-sm);"><i class="fa-light fa-check"></i> Selected</span>
                        }
                    </div>
                }
            </div>
        }
    </div>
}

@* ==================== Step 1: Plants ==================== *@
@if (_currentStep == 1)
{
    <div class="wizard-card">
        <div class="step-intro">
            <div class="step-intro-icon" style="background: var(--color-tint-blue); color: #3b82f6;">
                <i class="fa-light fa-industry"></i>
            </div>
            <div class="step-intro-content">
                <h2>Add Plants for @_selectedCompanyName</h2>
                <p>Plants are physical locations or facilities within your company. Add each site where safety inspections will take place. You can add contact details and photos to help identify each plant.</p>
            </div>
        </div>

        <div style="display: flex; justify-content: flex-end; margin-bottom: var(--spacing-md);">
            <button class="btn btn-primary" @onclick="() => { _showCreatePlant = true; _showEditPlant = false; _plantCreate = new(); }"><i class="fa-light fa-plus"></i> Add Plant</button>
        </div>

        @if (_showCreatePlant)
        {
            <div class="setup-item-card">
                <div class="setup-item-header">
                    <h3><i class="fa-light fa-plus" style="color: var(--color-primary);"></i> New Plant</h3>
                    <button class="btn btn-sm btn-ghost" @onclick="() => _showCreatePlant = false"><i class="fa-light fa-xmark"></i> Cancel</button>
                </div>
                <EditForm Model="_plantCreate" OnValidSubmit="CreatePlant">
                    <div class="form-row">
                        <div class="form-group">
                            <label>Name *</label>
                            <InputText @bind-Value="_plantCreate.Name" class="form-control" placeholder="e.g. Main Manufacturing Plant" />
                        </div>
                        <div class="form-group">
                            <label>Description</label>
                            <InputText @bind-Value="_plantCreate.Description" class="form-control" placeholder="Brief description of this facility" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Contact Name</label>
                            <InputText @bind-Value="_plantCreate.ContactName" class="form-control" placeholder="Site manager" />
                        </div>
                        <div class="form-group">
                            <label>Contact Phone</label>
                            <InputText @bind-Value="_plantCreate.ContactPhone" class="form-control" placeholder="+1 (555) 000-0000" />
                        </div>
                        <div class="form-group">
                            <label>Contact Email</label>
                            <InputText @bind-Value="_plantCreate.ContactEmail" class="form-control" placeholder="manager@example.com" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Photo</label>
                        <div class="upload-zone @(_plantCreate.PhotoBase64 is not null ? "upload-zone--has-file" : "")">
                            @if (_plantCreate.PhotoBase64 is not null)
                            {
                                <div class="upload-zone__preview">
                                    <img src="@($"data:image/jpeg;base64,{_plantCreate.PhotoBase64}")" alt="Preview" />
                                    <button type="button" class="upload-zone__remove" @onclick="() => { _plantCreate.PhotoBase64 = null; _plantCreate.PhotoFileName = null; }" @onclick:stopPropagation>
                                        <i class="fa-light fa-xmark"></i>
                                    </button>
                                </div>
                                <span class="upload-zone__preview-label">@_plantCreate.PhotoFileName</span>
                            }
                            else
                            {
                                <div class="upload-zone__empty">
                                    <i class="fa-light fa-camera"></i>
                                    <span>Click to upload photo</span>
                                    <small>JPG, PNG · max 5 MB</small>
                                </div>
                            }
                            <InputFile OnChange="OnCreatePlantPhotoSelected" class="upload-zone__input" accept="image/*" />
                        </div>
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary"><i class="fa-light fa-check"></i> Save Plant</button>
                        <button type="button" class="btn btn-secondary" @onclick="() => _showCreatePlant = false">Cancel</button>
                    </div>
                </EditForm>
            </div>
        }

        @if (_showEditPlant)
        {
            <div class="setup-item-card">
                <div class="setup-item-header">
                    <h3><i class="fa-light fa-pen" style="color: var(--color-primary);"></i> Edit Plant</h3>
                    <button class="btn btn-sm btn-ghost" @onclick="() => _showEditPlant = false"><i class="fa-light fa-xmark"></i> Cancel</button>
                </div>
                <EditForm Model="_plantEdit" OnValidSubmit="UpdatePlant">
                    <div class="form-row">
                        <div class="form-group">
                            <label>Name *</label>
                            <InputText @bind-Value="_plantEdit.Name" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Description</label>
                            <InputText @bind-Value="_plantEdit.Description" class="form-control" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Contact Name</label>
                            <InputText @bind-Value="_plantEdit.ContactName" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Contact Phone</label>
                            <InputText @bind-Value="_plantEdit.ContactPhone" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Contact Email</label>
                            <InputText @bind-Value="_plantEdit.ContactEmail" class="form-control" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Photo</label>
                        <div class="upload-zone @(_plantEdit.PhotoBase64 is not null ? "upload-zone--has-file" : "")">
                            @if (_plantEdit.PhotoBase64 is not null)
                            {
                                <div class="upload-zone__preview">
                                    <img src="@($"data:image/jpeg;base64,{_plantEdit.PhotoBase64}")" alt="Preview" />
                                    <button type="button" class="upload-zone__remove" @onclick="() => { _plantEdit.PhotoBase64 = null; _plantEdit.PhotoFileName = null; }" @onclick:stopPropagation>
                                        <i class="fa-light fa-xmark"></i>
                                    </button>
                                </div>
                                <span class="upload-zone__preview-label">@_plantEdit.PhotoFileName</span>
                            }
                            else
                            {
                                <div class="upload-zone__empty">
                                    <i class="fa-light fa-camera"></i>
                                    <span>Click to upload photo</span>
                                    <small>JPG, PNG · max 5 MB</small>
                                </div>
                            }
                            <InputFile OnChange="OnEditPlantPhotoSelected" class="upload-zone__input" accept="image/*" />
                        </div>
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Update Plant</button>
                        <button type="button" class="btn btn-secondary" @onclick="() => _showEditPlant = false">Cancel</button>
                    </div>
                </EditForm>
            </div>
        }

        <div class="card-list" style="margin-top: var(--spacing-md);">
            @foreach (var plant in _plants)
            {
                <div class="card">
                    @if (plant.PhotoBase64 is not null)
                    {
                        <div class="card-photo">
                            <img src="@($"data:image/jpeg;base64,{plant.PhotoBase64}")" alt="@plant.Name" />
                        </div>
                    }
                    <div class="card-header-row">
                        <h3>@plant.Name</h3>
                    </div>
                    <p class="card-subtitle">@(plant.Description ?? "No description")</p>
                    <p class="card-subtitle"><i class="fa-light fa-user"></i> @(plant.ContactName ?? "No contact")</p>
                    <div class="card-stats">
                        <span>@plant.SectionCount sections</span>
                        <span>@plant.EquipmentCount equipment</span>
                    </div>
                    <div class="sw-plant-actions">
                        <button class="btn btn-sm btn-secondary" @onclick="() => StartEditPlant(plant)">
                            <i class="fa-light fa-pen"></i> Edit
                        </button>
                        <button class="btn btn-sm btn-secondary" @onclick="() => OpenContactsModal(plant.Id, plant.Name)">
                            <i class="fa-light fa-address-book"></i> Contacts
                            @if (_contactCounts.TryGetValue(plant.Id, out var cnt) && cnt > 0)
                            {
                                <span class="sw-contact-badge">@cnt</span>
                            }
                        </button>
                    </div>
                </div>
            }
        </div>

        @if (!_plants.Any() && !_showCreatePlant)
        {
            <div class="empty-state">
                <i class="fa-light fa-industry"></i>
                No plants yet. Click "Add Plant" above to create your first facility.
            </div>
        }
    </div>
}

@* ==================== Step 2: Sections ==================== *@
@if (_currentStep == 2)
{
    <div class="wizard-card">
        <div class="step-intro">
            <div class="step-intro-icon" style="background: var(--color-tint-purple); color: #8b5cf6;">
                <i class="fa-light fa-layer-group"></i>
            </div>
            <div class="step-intro-content">
                <h2>Define Sections</h2>
                <p>Sections are areas or zones within a plant where equipment is located. For example: "Boiler Room", "Workshop A", or "Warehouse". Group your equipment logically for easier inspection rounds.</p>
            </div>
        </div>

        @if (_plants.Any())
        {
            <div class="setup-plant-selector">
                <label><i class="fa-light fa-industry"></i> Plant:</label>
                <select class="form-control" value="@_selectedPlantId" @onchange="OnPlantChanged">
                    @foreach (var plant in _plants)
                    {
                        <option value="@plant.Id">@plant.Name (@plant.SectionCount sections)</option>
                    }
                </select>
                @if (_selectedPlantId > 0)
                {
                    <button class="btn btn-primary" @onclick="() => { _showCreateSection = true; _showEditSection = false; _sectionCreate = new(); }"><i class="fa-light fa-plus"></i> Add Section</button>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fa-light fa-arrow-left"></i>
                No plants available. Go back to the previous step and add plants first.
            </div>
        }

        @if (_showCreateSection)
        {
            <div class="setup-item-card">
                <div class="setup-item-header">
                    <h3><i class="fa-light fa-plus" style="color: var(--color-primary);"></i> New Section</h3>
                    <button class="btn btn-sm btn-ghost" @onclick="() => _showCreateSection = false"><i class="fa-light fa-xmark"></i> Cancel</button>
                </div>
                <EditForm Model="_sectionCreate" OnValidSubmit="CreateSection">
                    <div class="form-row">
                        <div class="form-group">
                            <label>Name *</label>
                            <InputText @bind-Value="_sectionCreate.Name" class="form-control" placeholder="e.g. Boiler Room" />
                        </div>
                        <div class="form-group">
                            <label>Description</label>
                            <InputText @bind-Value="_sectionCreate.Description" class="form-control" placeholder="Brief description of this area" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Photo</label>
                        <div class="upload-zone @(_sectionCreate.PhotoBase64 is not null ? "upload-zone--has-file" : "")">
                            @if (_sectionCreate.PhotoBase64 is not null)
                            {
                                <div class="upload-zone__preview">
                                    <img src="@($"data:image/jpeg;base64,{_sectionCreate.PhotoBase64}")" alt="Preview" />
                                    <button type="button" class="upload-zone__remove" @onclick="() => { _sectionCreate.PhotoBase64 = null; _sectionCreate.PhotoFileName = null; }" @onclick:stopPropagation>
                                        <i class="fa-light fa-xmark"></i>
                                    </button>
                                </div>
                                <span class="upload-zone__preview-label">@_sectionCreate.PhotoFileName</span>
                            }
                            else
                            {
                                <div class="upload-zone__empty">
                                    <i class="fa-light fa-camera"></i>
                                    <span>Click to upload photo</span>
                                    <small>JPG, PNG · max 5 MB</small>
                                </div>
                            }
                            <InputFile OnChange="OnCreateSectionPhotoSelected" class="upload-zone__input" accept="image/*" />
                        </div>
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary"><i class="fa-light fa-check"></i> Save Section</button>
                        <button type="button" class="btn btn-secondary" @onclick="() => _showCreateSection = false">Cancel</button>
                    </div>
                </EditForm>
            </div>
        }

        @if (_showEditSection)
        {
            <div class="setup-item-card">
                <div class="setup-item-header">
                    <h3><i class="fa-light fa-pen" style="color: var(--color-primary);"></i> Edit Section</h3>
                    <button class="btn btn-sm btn-ghost" @onclick="() => _showEditSection = false"><i class="fa-light fa-xmark"></i> Cancel</button>
                </div>
                <EditForm Model="_sectionEdit" OnValidSubmit="UpdateSection">
                    <div class="form-row">
                        <div class="form-group">
                            <label>Name *</label>
                            <InputText @bind-Value="_sectionEdit.Name" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Description</label>
                            <InputText @bind-Value="_sectionEdit.Description" class="form-control" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Photo</label>
                        <div class="upload-zone @(_sectionEdit.PhotoBase64 is not null ? "upload-zone--has-file" : "")">
                            @if (_sectionEdit.PhotoBase64 is not null)
                            {
                                <div class="upload-zone__preview">
                                    <img src="@($"data:image/jpeg;base64,{_sectionEdit.PhotoBase64}")" alt="Preview" />
                                    <button type="button" class="upload-zone__remove" @onclick="() => { _sectionEdit.PhotoBase64 = null; _sectionEdit.PhotoFileName = null; }" @onclick:stopPropagation>
                                        <i class="fa-light fa-xmark"></i>
                                    </button>
                                </div>
                                <span class="upload-zone__preview-label">@_sectionEdit.PhotoFileName</span>
                            }
                            else
                            {
                                <div class="upload-zone__empty">
                                    <i class="fa-light fa-camera"></i>
                                    <span>Click to upload photo</span>
                                    <small>JPG, PNG · max 5 MB</small>
                                </div>
                            }
                            <InputFile OnChange="OnEditSectionPhotoSelected" class="upload-zone__input" accept="image/*" />
                        </div>
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Update Section</button>
                        <button type="button" class="btn btn-secondary" @onclick="() => _showEditSection = false">Cancel</button>
                    </div>
                </EditForm>
            </div>
        }

        @if (_selectedPlantId > 0)
        {
            <div class="card-list" style="margin-top: var(--spacing-md);">
                @foreach (var sec in _sections)
                {
                    <div class="card">
                        @if (sec.PhotoBase64 is not null)
                        {
                            <div class="card-photo">
                                <img src="@($"data:image/jpeg;base64,{sec.PhotoBase64}")" alt="@sec.Name" />
                            </div>
                        }
                        <div class="card-header-row">
                            <h3>@sec.Name</h3>
                            <div class="card-edit-btn">
                                <button class="btn btn-sm btn-secondary" @onclick="() => StartEditSection(sec)">Edit</button>
                            </div>
                        </div>
                        <p class="card-subtitle">@(sec.Description ?? "No description")</p>
                        <div class="card-stats">
                            <span>@sec.EquipmentCount equipment</span>
                            <span>Sort: @sec.SortOrder</span>
                        </div>
                    </div>
                }
            </div>

            @if (!_sections.Any() && !_showCreateSection)
            {
                <div class="empty-state">
                    <i class="fa-light fa-layer-group"></i>
                    No sections for this plant yet. Click "Add Section" to create zones or areas.
                </div>
            }
        }
    </div>
}

@* ==================== Step 3: Equipment ==================== *@
@if (_currentStep == 3)
{
    <div class="wizard-card">
        <div class="step-intro">
            <div class="step-intro-icon" style="background: var(--color-tint-green); color: var(--color-success);">
                <i class="fa-light fa-gear"></i>
            </div>
            <div class="step-intro-content">
                <h2>Register Equipment</h2>
                <p>Add the equipment that needs to be inspected in each section. Each piece of equipment gets a unique identifier (e.g. "FE-01" for Fire Extinguisher 1) and is assigned a type. This equipment will appear on your inspection checklists.</p>
            </div>
        </div>

        @if (_plants.Any())
        {
            <div class="setup-plant-selector">
                <label><i class="fa-light fa-industry"></i> Plant:</label>
                <select class="form-control" value="@_selectedPlantId" @onchange="OnPlantChanged">
                    @foreach (var plant in _plants)
                    {
                        <option value="@plant.Id">@plant.Name</option>
                    }
                </select>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fa-light fa-arrow-left"></i>
                No plants available. Go back and add plants first.
            </div>
        }

        @if (_selectedPlantId > 0 && _sections.Any())
        {
            @foreach (var sec in _sections)
            {
                <div class="setup-section-group">
                    <div class="setup-item-header">
                        <h4><i class="fa-light fa-layer-group" style="color: #8b5cf6;"></i> @sec.Name</h4>
                        <button class="btn btn-sm btn-primary" @onclick="() => StartCreateEquipment(sec.Id)"><i class="fa-light fa-plus"></i> Add Equipment</button>
                    </div>

                    @if (GetEquipmentForSection(sec.Id).Any())
                    {
                        <div style="overflow-x: auto;">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>Identifier</th>
                                        <th>Type</th>
                                        <th>Sub-Type</th>
                                        <th>Description</th>
                                        <th>Size</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var eq in GetEquipmentForSection(sec.Id))
                                    {
                                        <tr class="@(!eq.IsActive ? "row-inactive" : "")">
                                            <td><strong>@eq.Identifier</strong></td>
                                            <td>@eq.EquipmentTypeName</td>
                                            <td>@(eq.SubTypeName ?? "—")</td>
                                            <td>@(eq.Description ?? "—")</td>
                                            <td>@(eq.Size ?? "—")</td>
                                            <td>
                                                @if (eq.IsActive)
                                                {
                                                    <span class="active-badge">Active</span>
                                                }
                                                else
                                                {
                                                    <span class="inactive-badge">Inactive</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="action-buttons">
                                                    <button class="btn btn-xs btn-secondary" @onclick="() => StartEditEquipment(eq)">Edit</button>
                                                    <button class="btn btn-xs @(eq.IsActive ? "btn-secondary" : "btn-primary")" @onclick="() => ToggleEquipmentActive(eq)">
                                                        @(eq.IsActive ? "Deactivate" : "Activate")
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state" style="margin-top: var(--spacing-sm);">
                            <i class="fa-light fa-gear"></i>
                            No equipment in this section yet. Click "Add Equipment" to register items.
                        </div>
                    }
                </div>
            }
        }
        else if (_selectedPlantId > 0 && !_sections.Any())
        {
            <div class="empty-state">
                <i class="fa-light fa-arrow-left"></i>
                No sections for this plant. Go back to Step 3 to add sections first.
            </div>
        }
    </div>

    @* Equipment Create Modal *@
