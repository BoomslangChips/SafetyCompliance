    private async Task OpenContactsModal(int plantId, string plantName)
    {
        _contactsPlantId   = plantId;
        _contactsPlantName = plantName;
        _showContactForm   = false;
        _editingContactId  = 0;
        _contactForm       = new();
        _deleteContactId   = null;
        _showContactsModal = true;
        _loadingContacts   = true;
        StateHasChanged();
        _modalContacts = await PlantService.GetContactsAsync(plantId);
        _loadingContacts = false;
    }

    private void CloseContactsModal()
    {
        _showContactsModal = false;
        _showContactForm   = false;
        _deleteContactId   = null;
        _modalContacts     = [];
    }

    private void ShowAddContact()
    {
        _editingContactId = 0;
        _contactForm      = new();
        _showContactForm  = true;
    }

    private void StartEditContact(PlantContactDto c)
    {
        _editingContactId = c.Id;
        _contactForm = new ContactFormModel
        {
            Category  = c.Category,
            Name      = c.Name,
            Role      = c.Role,
            Phone     = c.Phone,
            Email     = c.Email,
            Notes     = c.Notes,
            IsPrimary = c.IsPrimary
        };
        _showContactForm = true;
    }

    private async Task SaveContact()
    {
        if (string.IsNullOrWhiteSpace(_contactForm.Name) || string.IsNullOrWhiteSpace(_contactForm.Category))
            return;

        if (_editingContactId == 0)
        {
            var dto = new PlantContactCreateDto(
                _contactsPlantId,
                _contactForm.Category,
                _contactForm.Name,
                _contactForm.Role,
                _contactForm.Phone,
                _contactForm.Email,
                _contactForm.Notes,
                _contactForm.IsPrimary);
            await PlantService.AddContactAsync(dto, "current-user");
        }
        else
        {
            var dto = new PlantContactUpdateDto(
                _editingContactId,
                _contactForm.Category,
                _contactForm.Name,
                _contactForm.Role,
                _contactForm.Phone,
                _contactForm.Email,
                _contactForm.Notes,
                _contactForm.IsPrimary);
            await PlantService.UpdateContactAsync(dto, "current-user");
        }

        _modalContacts    = await PlantService.GetContactsAsync(_contactsPlantId);
        _contactCounts[_contactsPlantId] = _modalContacts.Count;
        _showContactForm  = false;
        _editingContactId = 0;
        _contactForm      = new();
    }

    private async Task DeleteContact()
    {
        if (!_deleteContactId.HasValue) return;
        await PlantService.DeleteContactAsync(_deleteContactId.Value);
        _deleteContactId = null;
        _modalContacts = await PlantService.GetContactsAsync(_contactsPlantId);
        _contactCounts[_contactsPlantId] = _modalContacts.Count;
    }

    // ── Contact helper methods ──
    private static string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            : name.Length >= 2 ? name[..2].ToUpper() : name.ToUpper();
    }

    private static string GetCategoryEmoji(string category) => category switch
    {
        "Emergency"    => "🚨",
        "Management"   => "👔",
        "Maintenance"  => "🔧",
        "Fire & Safety"=> "🔥",
        "Specialist"   => "🎓",
        "Contractor"   => "🏗️",
        _              => "📋"
    };

    private static string GetCategoryColor(string category) => category switch
    {
        "Emergency"    => "#ef4444",
        "Management"   => "#3b82f6",
        "Maintenance"  => "#f59e0b",
        "Fire & Safety"=> "#f97316",
        "Specialist"   => "#8b5cf6",
        "Contractor"   => "#10b981",
        _              => "#6b7280"
    };

