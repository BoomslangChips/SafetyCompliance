        await EquipmentService.CreateEquipmentCheckAsync(new EquipmentCheckCreateDto(
            TypeId, _checkModel.Name, _checkModel.Description,
            _checkModel.IsRecurring ? _checkModel.IntervalMonths : null,
            _checkModel.IsRequired, maxOrder,
            _checkModel.EquipmentSubTypeId));

        await ReloadChecks();
