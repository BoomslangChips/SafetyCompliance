    // ── Helpers ──

    private void ShowFeedback(string msg, bool success)
    {
        _feedback      = msg;
        _feedbackClass = success ? "alert-success" : "alert-danger";
    }

    private void GoBack() => Navigation.NavigateTo("/equipment-types");

    private static string FormatInterval(int months) => months switch
    {
        1  => "Monthly",
        2  => "Every 2 months",
        3  => "Quarterly",
        6  => "Every 6 months",
        12 => "Annually",
        24 => "Every 2 years",
        36 => "Every 3 years",
        48 => "Every 4 years",
        60 => "Every 5 years",
        _ when months % 12 == 0 => $"Every {months / 12} years",
        _ => $"Every {months} months"
    };

