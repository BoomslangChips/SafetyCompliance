@page "/reports"
@using SafetyCompliance.Application.DTOs
@using SafetyCompliance.Application.Interfaces
@inject IReportService ReportService
@inject ICompanyService CompanyService
@inject IPlantService PlantService
@inject IExcelExportService ExcelExportService
@inject IPhotoStorageService PhotoStorage
@inject IJSRuntime JS

<div class="rpt-page">

    @* ── Tab bar ── *@
    <div class="insp-tab-bar ov-fadeIn">
        <div class="insp-tabs">
            <button class="insp-tab @(_tab == RptTab.Summary ? "active" : "")" @onclick="() => SetTab(RptTab.Summary)">
                <i class="fa-sharp fa-light fa-chart-pie"></i> Summary
            </button>
            <button class="insp-tab @(_tab == RptTab.Monthly ? "active" : "")" @onclick="() => SetTab(RptTab.Monthly)">
                <i class="fa-sharp fa-light fa-calendar-lines-pen"></i> Monthly Report
            </button>
        </div>
        <span class="rpt-header-label"><i class="fa-sharp fa-light fa-chart-line-up"></i> Reports</span>
    </div>

    @if (_loading)
    {
        <div class="ov-loading"><div class="ov-spinner"></div><p>Loading reports&hellip;</p></div>
    }
    else
    {
        @* ══════════════════════════════════════════
           SUMMARY TAB
           ══════════════════════════════════════════ *@
        @if (_tab == RptTab.Summary)
        {
            <div class="rpt-summary-header ov-fadeIn">
                <div>
                    <h2 class="rpt-summary-title">Plant Overview</h2>
                    <p class="rpt-summary-sub">Current month &mdash; @DateTime.Today.ToString("MMMM yyyy")</p>
                </div>
                <button class="rpt-excel-btn"
                        @onclick="ExportSummaryExcel"
                        disabled="@(_exportingAll || _summaries.Count == 0)">
                    @if (_exportingAll)
                    {
                        <i class="fa-sharp fa-light fa-spinner-third fa-spin"></i><span>Exporting&hellip;</span>
                    }
                    else
                    {
                        <i class="fa-sharp fa-light fa-file-excel"></i><span>Export Summary</span>
                    }
                </button>
            </div>

            @if (_summaries.Count == 0)
            {
                <div class="rpt-prompt ov-fadeIn">
                    <i class="fa-sharp fa-light fa-chart-pie-simple rpt-prompt-icon"></i>
                    <h3>No plants found</h3>
                    <p>Add companies and plants in the setup wizard to see report summaries here.</p>
                </div>
            }
            else
            {
                <div class="rpt-summary-grid ov-fadeIn">
                    @foreach (var s in _summaries)
                    {
                        <div class="rpt-plant-card @(s.CriticalIncidents > 0 ? "rpt-plant-card-alert" : "")">
                            <div class="rpt-plant-card-top">
                                <div class="rpt-plant-card-info">
                                    <span class="rpt-plant-company">@s.CompanyName</span>
                                    <h3 class="rpt-plant-name">@s.PlantName</h3>
                                    @if (s.LastInspectionDate.HasValue)
                                    {
                                        <span class="rpt-plant-last">Last inspection: @s.LastInspectionDate.Value.ToString("dd MMM yyyy")</span>
                                    }
                                    else
                                    {
                                        <span class="rpt-plant-last rpt-plant-never">No inspections yet</span>
                                    }
                                </div>
                                @{
                                    var _rc = 2 * Math.PI * 28;
                                    var _hi = s.InspectionsTotal > 0;
                                    var _ro = _hi ? _rc * (1.0 - s.CompliancePct / 100.0) : _rc;
                                    var _rk = _hi ? GetComplianceClass(s.CompliancePct) : "none";
                                    var _cs = _rc.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
                                    var _os = _ro.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
                                }
                                <div class="rpt-compliance-ring">
                                    <svg viewBox="0 0 72 72" width="72" height="72" aria-hidden="true">
                                        <circle cx="36" cy="36" r="28" class="rpt-ring-track"/>
                                        <circle cx="36" cy="36" r="28" class="rpt-ring-fill rpt-ring-fill-@_rk"
                                                style="stroke-dasharray:@_cs;stroke-dashoffset:@_os"/>
                                    </svg>
                                    <div class="rpt-ring-inner">
                                        @if (!_hi)
                                        {
                                            <span class="rpt-ring-na">N/A</span>
                                            <span class="rpt-ring-lbl">no data</span>
                                        }
                                        else
                                        {
                                            <span class="rpt-ring-pct">@s.CompliancePct<small>%</small></span>
                                            <span class="rpt-ring-lbl">compliance</span>
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="rpt-plant-stats">
                                <div class="rpt-mini-stat">
                                    <span class="rpt-mini-icon blue"><i class="fa-sharp fa-light fa-clipboard-check"></i></span>
                                    <div class="rpt-mini-text">
                                        <span class="rpt-mini-value">@s.InspectionsCompleted<small>/@s.InspectionsTotal</small></span>
                                        <span class="rpt-mini-label">Inspections</span>
                                    </div>
                                </div>
                                <div class="rpt-mini-stat">
                                    <span class="rpt-mini-icon @(s.EquipmentInspected < s.TotalEquipment && s.InspectionsTotal > 0 ? "amber" : "green")">
                                        <i class="fa-sharp fa-light fa-gears"></i>
                                    </span>
                                    <div class="rpt-mini-text">
                                        <span class="rpt-mini-value">@s.EquipmentInspected<small>/@s.TotalEquipment</small></span>
                                        <span class="rpt-mini-label">Equipment</span>
                                    </div>
                                </div>
                                <div class="rpt-mini-stat @(s.CriticalIncidents > 0 ? "rpt-mini-alert" : "")">
                                    <span class="rpt-mini-icon @(s.OpenIncidents > 0 ? "red" : "gray")">
                                        <i class="fa-sharp fa-light fa-triangle-exclamation"></i>
                                    </span>
                                    <div class="rpt-mini-text">
                                        <span class="rpt-mini-value">@s.OpenIncidents</span>
                                        <span class="rpt-mini-label">
                                            Open Incidents
                                            @if (s.CriticalIncidents > 0)
                                            {
                                                <span class="rpt-critical-chip">@s.CriticalIncidents critical</span>
                                            }
                                        </span>
                                    </div>
                                </div>
                                <div class="rpt-mini-stat">
                                    <span class="rpt-mini-icon @(s.ActiveServiceBookings > 0 ? "amber" : "gray")">
                                        <i class="fa-sharp fa-light fa-toolbox"></i>
                                    </span>
                                    <div class="rpt-mini-text">
                                        <span class="rpt-mini-value">@s.ActiveServiceBookings</span>
                                        <span class="rpt-mini-label">Active Service</span>
                                    </div>
                                </div>
                                <div class="rpt-mini-stat">
                                    <span class="rpt-mini-icon purple"><i class="fa-sharp fa-light fa-memo"></i></span>
                                    <div class="rpt-mini-text">
                                        <span class="rpt-mini-value">@s.NotesCount</span>
                                        <span class="rpt-mini-label">Notes</span>
                                    </div>
                                </div>
                            </div>

                            <div class="rpt-plant-card-footer">
                                <button class="btn btn-sm btn-outline rpt-view-btn" @onclick="() => ViewMonthlyReport(s.PlantId)">
                                    <i class="fa-sharp fa-light fa-chart-line"></i> View Monthly Report
                                </button>
                                <button class="rpt-export-card-btn"
                                        title="Export monthly report to Excel"
                                        @onclick="() => ExportCardExcel(s.PlantId)"
                                        disabled="@(_exportingCard && _exportingCardId == s.PlantId)">
                                    @if (_exportingCard && _exportingCardId == s.PlantId)
                                    {
                                        <i class="fa-sharp fa-light fa-spinner-third fa-spin"></i>
                                    }
                                    else
                                    {
                                        <i class="fa-sharp fa-light fa-file-excel"></i>
                                    }
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
        }

        @* ══════════════════════════════════════════
           MONTHLY REPORT TAB
           ══════════════════════════════════════════ *@
        @if (_tab == RptTab.Monthly)
        {
            @* Filter bar *@
            <div class="rpt-filter-bar ov-fadeIn">
                <div class="rpt-filter-group">
                    <label class="rpt-filter-label">Company</label>
                    <select class="rpt-filter-select" @onchange="OnFilterCompanyChanged">
                        <option value="">All Companies</option>
                        @foreach (var c in _companies)
                        {
                            <option value="@c.Id" selected="@(_filterCompanyId == c.Id)">@c.Name</option>
                        }
                    </select>
                </div>
                <div class="rpt-filter-group">
                    <label class="rpt-filter-label">Plant</label>
                    <select class="rpt-filter-select" @bind="_filterPlantId" disabled="@(_filterPlants.Count == 0)">
                        <option value="0">— Select Plant —</option>
                        @foreach (var p in _filterPlants)
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    </select>
                </div>
                <div class="rpt-filter-group">
                    <label class="rpt-filter-label">Month</label>
                    <select class="rpt-filter-select" @bind="_filterMonth">
                        @for (int m = 1; m <= 12; m++)
                        {
                            var monthNum = m;
                            <option value="@monthNum">@(new DateTime(2000, monthNum, 1).ToString("MMMM"))</option>
                        }
                    </select>
                </div>
                <div class="rpt-filter-group">
                    <label class="rpt-filter-label">Year</label>
                    <select class="rpt-filter-select" @bind="_filterYear">
                        @for (int y = DateTime.Today.Year; y >= DateTime.Today.Year - 4; y--)
                        {
                            var yr = y;
                            <option value="@yr">@yr</option>
                        }
                    </select>
                </div>
                <button class="btn btn-primary rpt-gen-btn" @onclick="GenerateReport"
                        disabled="@(_filterPlantId == 0 || _generatingReport)">
                    @if (_generatingReport)
                    {
                        <i class="fa-sharp fa-light fa-spinner-third fa-spin"></i><span>Generating&hellip;</span>
                    }
                    else
                    {
                        <i class="fa-sharp fa-light fa-chart-line"></i><span>Generate Report</span>
                    }
                </button>
                <button class="rpt-excel-btn" @onclick="ExportMonthlyExcel"
                        disabled="@(_report == null || _exportingMonthly)">
                    @if (_exportingMonthly)
                    {
                        <i class="fa-sharp fa-light fa-spinner-third fa-spin"></i><span>Exporting&hellip;</span>
                    }
                    else
                    {
                        <i class="fa-sharp fa-light fa-file-excel"></i><span>Export Excel</span>
                    }
                </button>
                <label class="rpt-photo-toggle" title="Include inspection photos in Excel export">
                    <input type="checkbox" @bind="_includePhotos" />
                    <i class="fa-sharp fa-light fa-camera"></i> Photos
                </label>
            </div>

            @if (_report != null)
            {
                @* ── REPORT DOCUMENT ── *@
                <div class="rpt-document ov-fadeIn" id="rpt-document">

                    @* Document header *@
                    <div class="rpt-doc-header">
                        <div class="rpt-doc-header-left">
                            <div class="rpt-doc-logo"><i class="fa-sharp fa-light fa-shield-check"></i></div>
                            <div>
                                <h1 class="rpt-doc-title">Monthly Maintenance Report</h1>
                                <p class="rpt-doc-meta">@_report.PlantName &nbsp;&middot;&nbsp; @_report.CompanyName</p>
                                <p class="rpt-doc-period">@(new DateTime(_report.Year, _report.Month, 1).ToString("MMMM yyyy"))</p>
                            </div>
                        </div>
                        <div class="rpt-doc-header-right">
                            @if (!string.IsNullOrEmpty(_report.ContactName))
                            {
                                <div class="rpt-doc-contact"><i class="fa-sharp fa-light fa-user-tie"></i> @_report.ContactName</div>
                            }
                            @if (!string.IsNullOrEmpty(_report.ContactPhone))
                            {
                                <div class="rpt-doc-contact"><i class="fa-sharp fa-light fa-phone"></i> @_report.ContactPhone</div>
                            }
                            <div class="rpt-doc-generated">
                                <i class="fa-sharp fa-light fa-clock"></i>
                                Generated @_report.GeneratedAt.ToString("dd MMM yyyy, HH:mm")
                            </div>
                        </div>
                    </div>

                    @* Table of Contents with in-page hyperlinks *@
                    <div class="rpt-toc">
                        <h2 class="rpt-toc-title"><i class="fa-sharp fa-light fa-list-ul"></i> Contents</h2>
                        <div class="rpt-toc-links">
                            <a class="rpt-toc-link" @onclick='() => ScrollTo("rpt-s1")' href="javascript:void(0)">
                                <span class="rpt-toc-num">01</span>
                                <span class="rpt-toc-text">Executive Summary</span>
                                <span class="rpt-toc-arrow"><i class="fa-sharp fa-light fa-arrow-right"></i></span>
                            </a>
                            <a class="rpt-toc-link" @onclick='() => ScrollTo("rpt-s2")' href="javascript:void(0)">
                                <span class="rpt-toc-num">02</span>
                                <span class="rpt-toc-text">Inspection Rounds</span>
                                <span class="rpt-toc-count">@_report.Rounds.Count</span>
                                <span class="rpt-toc-arrow"><i class="fa-sharp fa-light fa-arrow-right"></i></span>
                            </a>
                            <a class="rpt-toc-link" @onclick='() => ScrollTo("rpt-s3")' href="javascript:void(0)">
                                <span class="rpt-toc-num">03</span>
                                <span class="rpt-toc-text">Equipment Checklist Results</span>
                                <span class="rpt-toc-count">@_report.Equipment.Count</span>
                                <span class="rpt-toc-arrow"><i class="fa-sharp fa-light fa-arrow-right"></i></span>
                            </a>
                            <a class="rpt-toc-link" @onclick='() => ScrollTo("rpt-s4")' href="javascript:void(0)">
                                <span class="rpt-toc-num">04</span>
                                <span class="rpt-toc-text">Incidents &amp; Issues</span>
                                <span class="rpt-toc-count @(_report.Issues.Count(i => i.Priority == "Critical" && i.Status is "Open" or "InProgress") > 0 ? "rpt-count-danger" : "")">@_report.Issues.Count</span>
                                <span class="rpt-toc-arrow"><i class="fa-sharp fa-light fa-arrow-right"></i></span>
                            </a>
                            <a class="rpt-toc-link" @onclick='() => ScrollTo("rpt-s5")' href="javascript:void(0)">
                                <span class="rpt-toc-num">05</span>
                                <span class="rpt-toc-text">Service Bookings</span>
                                <span class="rpt-toc-count">@_report.ServiceBookings.Count</span>
                                <span class="rpt-toc-arrow"><i class="fa-sharp fa-light fa-arrow-right"></i></span>
                            </a>
                            <a class="rpt-toc-link" @onclick='() => ScrollTo("rpt-s6")' href="javascript:void(0)">
                                <span class="rpt-toc-num">06</span>
                                <span class="rpt-toc-text">Notes</span>
                                <span class="rpt-toc-count">@_report.Notes.Count</span>
                                <span class="rpt-toc-arrow"><i class="fa-sharp fa-light fa-arrow-right"></i></span>
                            </a>
                        </div>
                    </div>

                    @* ── Section 01: Executive Summary ── *@
                    <div class="rpt-section" id="rpt-s1">
                        <div class="rpt-section-header">
                            <span class="rpt-section-num">01</span>
                            <h2 class="rpt-section-title">Executive Summary</h2>
                        </div>
                        <div class="rpt-kpi-row">
                            <div class="rpt-kpi rpt-kpi-@GetComplianceClass(_report.CompliancePct)">
                                <i class="fa-sharp fa-light fa-shield-check rpt-kpi-icon"></i>
                                <span class="rpt-kpi-value">@_report.CompliancePct<small>%</small></span>
                                <span class="rpt-kpi-label">Compliance Rate</span>
                            </div>
                            @{
                                var roundsDone  = _report.Rounds.Count(r => r.Status is "Completed" or "CompletedWithIssues" or "Reviewed");
                                var roundsTotal = _report.Rounds.Count;
                            }
                            <div class="rpt-kpi @(roundsDone < roundsTotal && roundsTotal > 0 ? "rpt-kpi-warning" : "")">
                                <i class="fa-sharp fa-light fa-clipboard-list rpt-kpi-icon"></i>
                                <span class="rpt-kpi-value">@roundsDone<small>/@roundsTotal</small></span>
                                <span class="rpt-kpi-label">Rounds Completed</span>
                            </div>
                            @{
                                var totalFailed = _report.Equipment.Sum(e => e.FailChecks);
                                var totalChecks = _report.Equipment.Sum(e => e.PassChecks + e.FailChecks);
                                var equipInspected = _report.Equipment.Select(e => e.EquipmentId).Distinct().Count();
                            }
                            <div class="rpt-kpi @(totalFailed > 0 ? "rpt-kpi-danger" : "")">
                                <i class="fa-sharp fa-light fa-circle-xmark rpt-kpi-icon"></i>
                                <span class="rpt-kpi-value">@totalFailed<small>/@totalChecks</small></span>
                                <span class="rpt-kpi-label">Failed Checks</span>
                            </div>
                            <div class="rpt-kpi">
                                <i class="fa-sharp fa-light fa-gears rpt-kpi-icon"></i>
                                <span class="rpt-kpi-value">@equipInspected<small>/@_report.TotalEquipmentInPlant</small></span>
                                <span class="rpt-kpi-label">Equipment Inspected</span>
                            </div>
                            @{
                                var openIssues     = _report.Issues.Count(i => i.Status is "Open" or "InProgress");
                                var criticalIssues = _report.Issues.Count(i => i.Priority == "Critical" && i.Status is "Open" or "InProgress");
                            }
                            <div class="rpt-kpi @(criticalIssues > 0 ? "rpt-kpi-critical" : openIssues > 0 ? "rpt-kpi-danger" : "")">
                                <i class="fa-sharp fa-light fa-triangle-exclamation rpt-kpi-icon"></i>
                                <span class="rpt-kpi-value">@openIssues</span>
                                <span class="rpt-kpi-label">Open Incidents@(criticalIssues > 0 ? $" ({criticalIssues} critical)" : "")</span>
                            </div>
                            @{
                                var activeService = _report.ServiceBookings.Count(b => b.Status is "Sent" or "InService");
                            }
                            <div class="rpt-kpi @(activeService > 0 ? "rpt-kpi-warning" : "")">
                                <i class="fa-sharp fa-light fa-toolbox rpt-kpi-icon"></i>
                                <span class="rpt-kpi-value">@activeService</span>
                                <span class="rpt-kpi-label">Equipment in Service</span>
                            </div>
                        </div>
                    </div>

                    @* ── Section 02: Inspection Rounds ── *@
                    <div class="rpt-section" id="rpt-s2">
                        <div class="rpt-section-header">
                            <span class="rpt-section-num">02</span>
                            <h2 class="rpt-section-title">Inspection Rounds</h2>
                            <span class="rpt-section-badge">@_report.Rounds.Count round@(_report.Rounds.Count != 1 ? "s" : "")</span>
                        </div>
                        @if (_report.Rounds.Count == 0)
                        {
                            <div class="rpt-empty-section">
                                <i class="fa-sharp fa-light fa-clipboard-list"></i>
                                <span>No inspections were conducted this month.</span>
                            </div>
                        }
                        else
                        {
                            <div class="rpt-table-wrap">
                                <table class="rpt-table">
                                    <thead>
                                        <tr>
                                            <th>Date</th>
                                            <th>Status</th>
                                            <th>Inspector</th>
                                            <th>Equipment Done</th>
                                            <th>Completed At</th>
                                            <th>Total Checks</th>
                                            <th>Failed</th>
                                            <th>Compliance</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var r in _report.Rounds)
                                        {
                                            var rComp = r.TotalChecks > 0
                                                ? (int)Math.Round((r.TotalChecks - r.FailedChecks) * 100.0 / r.TotalChecks)
                                                : 100;
                                            <tr class="@(r.FailedChecks > 0 ? "rpt-row-warn" : "")">
                                                <td class="rpt-cell-bold">@r.Date.ToString("dd MMM yyyy")</td>
                                                <td><span class="rpt-badge rpt-badge-@GetRoundStatusClass(r.Status)">@FormatStatus(r.Status)</span></td>
                                                <td>@r.InspectorName</td>
                                                <td>@r.CompletedEquipment / @r.TotalEquipment</td>
                                                <td>@(r.CompletedAt.HasValue ? r.CompletedAt.Value.ToString("dd MMM HH:mm") : "—")</td>
                                                <td>@r.TotalChecks</td>
                                                <td class="@(r.FailedChecks > 0 ? "rpt-cell-danger" : "rpt-cell-pass")">@r.FailedChecks</td>
                                                <td>
                                                    <div class="rpt-bar-wrap">
                                                        <div class="rpt-bar-fill rpt-bar-@GetComplianceClass(rComp)" style="width:@rComp%"></div>
                                                    </div>
                                                    <span class="rpt-bar-pct">@rComp%</span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>

                    @* ── Section 03: Equipment Checklist Results ── *@
                    <div class="rpt-section" id="rpt-s3">
                        <div class="rpt-section-header">
                            <span class="rpt-section-num">03</span>
                            <h2 class="rpt-section-title">Equipment Checklist Results</h2>
                            <span class="rpt-section-badge">@_report.TotalEquipmentInPlant equipment in plant</span>
                        </div>
                        @if (_report.Equipment.Count == 0)
                        {
                            <div class="rpt-empty-section">
                                <i class="fa-sharp fa-light fa-gears"></i>
                                <span>No equipment inspection data for this period.</span>
                            </div>
                        }
                        else
                        {
                            @foreach (var round in _report.Rounds)
                            {
                                var roundEquip = _report.Equipment.Where(e => e.RoundId == round.Id).ToList();
                                if (!roundEquip.Any()) continue;
                                var roundFail = roundEquip.Sum(e => e.FailChecks);

                                <div class="rpt-equip-round-header">
                                    <div class="rpt-equip-round-title">
                                        <i class="fa-sharp fa-light fa-clipboard-list"></i>
                                        Round &mdash; @round.Date.ToString("dd MMMM yyyy")
                                        <span class="rpt-badge rpt-badge-@GetRoundStatusClass(round.Status)">@FormatStatus(round.Status)</span>
                                    </div>
                                    <div class="rpt-equip-round-meta">
                                        Inspector: @round.InspectorName
                                        &nbsp;&middot;&nbsp;
                                        @roundEquip.Count(e => e.IsComplete) / @roundEquip.Count complete
                                        @if (roundFail > 0)
                                        {
                                            <span class="rpt-equip-round-fails">· @roundFail failed check@(roundFail != 1 ? "s" : "")</span>
                                        }
                                    </div>
                                </div>
                                <div class="rpt-table-wrap rpt-table-equip-wrap">
                                    <table class="rpt-table rpt-table-equip">
                                        <thead>
                                            <tr>
                                                <th>Equipment</th>
                                                <th>Type</th>
                                                <th>Section</th>
                                                <th>Result</th>
                                                <th>Pass</th>
                                                <th>Fail</th>
                                                <th>Failed Items</th>
                                                <th>Comments</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var eq in roundEquip)
                                            {
                                                <tr class="@(eq.FailChecks > 0 ? "rpt-row-fail" : eq.IsComplete ? "rpt-row-pass" : "rpt-row-incomplete")">
                                                    <td class="rpt-cell-bold">@eq.Identifier</td>
                                                    <td>@eq.TypeName</td>
                                                    <td>@eq.SectionName</td>
                                                    <td>
                                                        @if (!eq.IsComplete)
                                                        {
                                                            <span class="rpt-badge rpt-badge-incomplete"><i class="fa-sharp fa-light fa-circle-minus"></i> Incomplete</span>
                                                        }
                                                        else if (eq.FailChecks > 0)
                                                        {
                                                            <span class="rpt-badge rpt-badge-fail"><i class="fa-sharp fa-light fa-triangle-exclamation"></i> Issues Found</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="rpt-badge rpt-badge-pass"><i class="fa-sharp fa-light fa-circle-check"></i> Pass</span>
                                                        }
                                                    </td>
                                                    <td class="rpt-cell-pass">@eq.PassChecks</td>
                                                    <td class="@(eq.FailChecks > 0 ? "rpt-cell-danger" : "rpt-cell-pass")">@eq.FailChecks</td>
                                                    <td>
                                                        @if (eq.FailedItems.Any())
                                                        {
                                                            <ul class="rpt-failed-list">
                                                                @foreach (var item in eq.FailedItems)
                                                                {
                                                                    <li>@item</li>
                                                                }
                                                            </ul>
                                                        }
                                                        else
                                                        {
                                                            <span class="rpt-cell-muted">—</span>
                                                        }
                                                    </td>
                                                    <td class="rpt-cell-comment">@(string.IsNullOrEmpty(eq.Comments) ? "—" : eq.Comments)</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        }
                    </div>

                    @* ── Section 04: Incidents & Issues ── *@
                    <div class="rpt-section" id="rpt-s4">
                        <div class="rpt-section-header">
                            <span class="rpt-section-num">04</span>
                            <h2 class="rpt-section-title">Incidents &amp; Issues</h2>
                            <span class="rpt-section-badge @(_report.Issues.Any(i => i.Priority == "Critical" && i.Status is "Open" or "InProgress") ? "rpt-section-badge-danger" : "")">
                                @_report.Issues.Count total &middot; @_report.Issues.Count(i => i.Status is "Open" or "InProgress") open
                            </span>
                        </div>
                        @if (_report.Issues.Count == 0)
                        {
                            <div class="rpt-empty-section rpt-empty-good">
                                <i class="fa-sharp fa-light fa-circle-check"></i>
                                <span>No incidents logged for this plant — all clear!</span>
                            </div>
                        }
                        else
                        {
                            <div class="rpt-table-wrap">
                                <table class="rpt-table">
                                    <thead>
                                        <tr>
                                            <th>Title</th>
                                            <th>Priority</th>
                                            <th>Status</th>
                                            <th>Equipment</th>
                                            <th>Assigned To</th>
                                            <th>Due Date</th>
                                            <th>Logged</th>
                                            <th>Resolved</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var issue in _report.Issues)
                                        {
                                            var isOverdue = issue.DueDate.HasValue
                                                         && issue.DueDate.Value < DateOnly.FromDateTime(DateTime.Today)
                                                         && issue.Status is not "Resolved" and not "Closed";
                                            <tr class="@(issue.Priority == "Critical" && issue.Status is "Open" or "InProgress" ? "rpt-row-critical" : issue.Priority == "High" && issue.Status is "Open" or "InProgress" ? "rpt-row-warn" : "")">
                                                <td class="rpt-cell-bold">@issue.Title</td>
                                                <td><span class="rpt-badge rpt-badge-@GetPriorityClass(issue.Priority)">@issue.Priority</span></td>
                                                <td><span class="rpt-badge rpt-badge-@GetIssueStatusClass(issue.Status)">@FormatStatus(issue.Status)</span></td>
                                                <td>@(string.IsNullOrEmpty(issue.EquipmentIdentifier) ? "—" : issue.EquipmentIdentifier)</td>
                                                <td>@(string.IsNullOrEmpty(issue.AssignedTo) ? "—" : issue.AssignedTo)</td>
                                                <td class="@(isOverdue ? "rpt-cell-danger" : "")">
                                                    @(issue.DueDate.HasValue ? issue.DueDate.Value.ToString("dd MMM yyyy") : "—")
                                                    @if (isOverdue) { <span class="rpt-overdue-chip">overdue</span> }
                                                </td>
                                                <td>@issue.CreatedAt.ToString("dd MMM yyyy")</td>
                                                <td>@(issue.ResolvedAt.HasValue ? issue.ResolvedAt.Value.ToString("dd MMM yyyy") : "—")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>

                    @* ── Section 05: Service Bookings ── *@
                    <div class="rpt-section" id="rpt-s5">
                        <div class="rpt-section-header">
                            <span class="rpt-section-num">05</span>
                            <h2 class="rpt-section-title">Service Bookings</h2>
                            <span class="rpt-section-badge @(_report.ServiceBookings.Any(b => b.Status is "Sent" or "InService") ? "rpt-section-badge-warn" : "")">
                                @_report.ServiceBookings.Count total &middot; @_report.ServiceBookings.Count(b => b.Status is "Sent" or "InService") active
                            </span>
                        </div>
                        @if (_report.ServiceBookings.Count == 0)
                        {
                            <div class="rpt-empty-section">
                                <i class="fa-sharp fa-light fa-toolbox"></i>
                                <span>No service bookings recorded for this period.</span>
                            </div>
                        }
                        else
                        {
                            <div class="rpt-table-wrap">
                                <table class="rpt-table">
                                    <thead>
                                        <tr>
                                            <th>Equipment</th>
                                            <th>Type</th>
                                            <th>Section</th>
                                            <th>Service Provider</th>
                                            <th>Reason</th>
                                            <th>Status</th>
                                            <th>Date Sent</th>
                                            <th>Expected Return</th>
                                            <th>Actual Return</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var b in _report.ServiceBookings)
                                        {
                                            var overdueSvc = b.ExpectedReturn.HasValue
                                                           && b.ExpectedReturn.Value < DateOnly.FromDateTime(DateTime.Today)
                                                           && b.Status is "Sent" or "InService";
                                            <tr class="@(b.Status is "Sent" or "InService" ? "rpt-row-service-active" : "")">
                                                <td class="rpt-cell-bold">@b.EquipmentIdentifier</td>
                                                <td>@b.TypeName</td>
                                                <td>@b.SectionName</td>
                                                <td>@b.Provider</td>
                                                <td class="rpt-cell-reason">@b.Reason</td>
                                                <td><span class="rpt-badge rpt-badge-@GetServiceStatusClass(b.Status)">@FormatStatus(b.Status)</span></td>
                                                <td>@b.SentDate.ToString("dd MMM yyyy")</td>
                                                <td class="@(overdueSvc ? "rpt-cell-danger" : "")">
                                                    @(b.ExpectedReturn.HasValue ? b.ExpectedReturn.Value.ToString("dd MMM yyyy") : "—")
                                                    @if (overdueSvc) { <span class="rpt-overdue-chip">overdue</span> }
                                                </td>
                                                <td>@(b.ActualReturn.HasValue ? b.ActualReturn.Value.ToString("dd MMM yyyy") : "—")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>

                    @* ── Section 06: Notes ── *@
                    <div class="rpt-section" id="rpt-s6">
                        <div class="rpt-section-header">
                            <span class="rpt-section-num">06</span>
                            <h2 class="rpt-section-title">Notes</h2>
                            <span class="rpt-section-badge">@_report.Notes.Count note@(_report.Notes.Count != 1 ? "s" : "")</span>
                        </div>
                        @if (_report.Notes.Count == 0)
                        {
                            <div class="rpt-empty-section">
                                <i class="fa-sharp fa-light fa-memo"></i>
                                <span>No notes recorded for this plant.</span>
                            </div>
                        }
                        else
                        {
                            <div class="rpt-notes-grid">
                                @foreach (var note in _report.Notes)
                                {
                                    <div class="rpt-note-card rpt-note-@note.Category.ToLower() @(note.IsPinned ? "rpt-note-pinned" : "")">
                                        <div class="rpt-note-top">
                                            <div class="rpt-note-badges">
                                                <span class="rpt-badge rpt-badge-note-@note.Category.ToLower()">@note.Category</span>
                                                @if (note.Priority != "Normal")
                                                {
                                                    <span class="rpt-badge rpt-badge-@GetNotePriorityClass(note.Priority)">@note.Priority</span>
                                                }
                                                @if (note.IsPinned)
                                                {
                                                    <span class="rpt-pin-chip"><i class="fa-solid fa-thumbtack"></i> Pinned</span>
                                                }
                                            </div>
                                            <span class="rpt-note-date">@note.CreatedAt.ToString("dd MMM yyyy")</span>
                                        </div>
                                        <h4 class="rpt-note-title">@note.Title</h4>
                                        <p class="rpt-note-content">@note.Content</p>
                                        @if (!string.IsNullOrEmpty(note.EquipmentIdentifier))
                                        {
                                            <div class="rpt-note-equip"><i class="fa-sharp fa-light fa-gear"></i> @note.EquipmentIdentifier</div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>

                </div> @* /rpt-document *@
            }
            else if (!_generatingReport)
            {
                <div class="rpt-prompt ov-fadeIn">
                    <i class="fa-sharp fa-light fa-chart-line-up rpt-prompt-icon"></i>
                    <h3>Select a plant and period</h3>
                    <p>Choose a company, plant, month and year above then click <strong>Generate Report</strong>.</p>
                </div>
            }
        }
    }

</div>

@code {
    private enum RptTab { Summary, Monthly }

    private RptTab _tab      = RptTab.Summary;
    private bool   _loading  = true;
    private bool   _generatingReport = false;

    // Summary tab data
    private List<PlantReportSummaryDto> _summaries = [];

    // Filter controls
    private List<CompanyDto> _companies    = [];
    private List<PlantDto>   _filterPlants = [];
    private int?  _filterCompanyId;
    private int   _filterPlantId = 0;
    private int   _filterMonth   = DateTime.Today.Month;
    private int   _filterYear    = DateTime.Today.Year;

    // Generated report
    private MonthlyReportDto? _report;

    // Excel export state
    private bool _exportingAll     = false;
    private bool _exportingMonthly = false;
    private bool _exportingCard    = false;
    private int  _exportingCardId  = 0;
    private bool _includePhotos    = true;

    protected override async Task OnInitializedAsync()
    {
        _companies = await CompanyService.GetAllCompaniesAsync();
        _summaries = await ReportService.GetPlantSummariesAsync();
        _loading   = false;
    }

    private void SetTab(RptTab tab) => _tab = tab;

    private async Task OnFilterCompanyChanged(ChangeEventArgs e)
    {
        _filterCompanyId = int.TryParse(e.Value?.ToString(), out var id) && id > 0 ? id : (int?)null;
        _filterPlantId   = 0;
        _filterPlants    = _filterCompanyId.HasValue
            ? await PlantService.GetPlantsByCompanyAsync(_filterCompanyId.Value)
            : [];
    }

    private async Task ViewMonthlyReport(int plantId)
    {
        _tab           = RptTab.Monthly;
        _filterPlantId = plantId;

        // Pre-populate company/plant dropdowns for the card's plant
        var summary = _summaries.FirstOrDefault(s => s.PlantId == plantId);
        if (summary != null)
        {
            var company = _companies.FirstOrDefault(c => c.Name == summary.CompanyName);
            if (company != null)
            {
                _filterCompanyId = company.Id;
                _filterPlants    = await PlantService.GetPlantsByCompanyAsync(company.Id);
            }
        }

        await GenerateReport();
    }

    private async Task GenerateReport()
    {
        if (_filterPlantId == 0) return;
        _generatingReport = true;
        _report           = null;
        StateHasChanged();
        _report           = await ReportService.GetMonthlyReportAsync(_filterPlantId, _filterYear, _filterMonth);
        _generatingReport = false;
    }

    // ── Excel export ──────────────────────────────────────────────────────────

    /// <summary>Exports the all-plant summary grid to a single-sheet Excel file.</summary>
    private async Task ExportSummaryExcel()
    {
        if (_exportingAll || _summaries.Count == 0) return;
        _exportingAll = true;
        StateHasChanged();
        try
        {
            var period = DateTime.Today.ToString("MMMM yyyy");
            var bytes  = ExcelExportService.ExportSummary(_summaries, period);
            var base64 = Convert.ToBase64String(bytes);
            var name   = $"MIS-Plant-Summary-{DateTime.Today:MMMM-yyyy}.xlsx";
            await JS.InvokeVoidAsync("downloadExcel", name, base64);
        }
        finally
        {
            _exportingAll = false;
        }
    }

    /// <summary>Fetches the current-month report for a plant card and downloads it.</summary>
    private async Task ExportCardExcel(int plantId)
    {
        if (_exportingCard) return;
        _exportingCard   = true;
        _exportingCardId = plantId;
        StateHasChanged();
        try
        {
            var today  = DateTime.Today;
            var report = await ReportService.GetMonthlyReportAsync(plantId, today.Year, today.Month);
            if (report is not null)
            {
                var photos = _includePhotos ? await LoadPhotoFiles(report) : null;
                var bytes  = ExcelExportService.ExportMonthlyReport(report, photos);
                var base64 = Convert.ToBase64String(bytes);
                var period = new DateTime(report.Year, report.Month, 1).ToString("MMM-yyyy");
                var plant  = report.PlantName.Replace(" ", "-");
                await JS.InvokeVoidAsync("downloadExcel", $"MIS-{plant}-{period}.xlsx", base64);
            }
        }
        finally
        {
            _exportingCard   = false;
            _exportingCardId = 0;
        }
    }

    /// <summary>Exports the currently loaded monthly report.</summary>
    private async Task ExportMonthlyExcel()
    {
        if (_report is null || _exportingMonthly) return;
        _exportingMonthly = true;
        StateHasChanged();
        try
        {
            var photos = _includePhotos ? await LoadPhotoFiles(_report) : null;
            var bytes  = ExcelExportService.ExportMonthlyReport(_report, photos);
            var base64 = Convert.ToBase64String(bytes);
            var period = new DateTime(_report.Year, _report.Month, 1).ToString("MMM-yyyy");
            var plant  = _report.PlantName.Replace(" ", "-");
            await JS.InvokeVoidAsync("downloadExcel", $"MIS-{plant}-{period}.xlsx", base64);
        }
        finally
        {
            _exportingMonthly = false;
        }
    }

    private async Task<Dictionary<string, byte[]>?> LoadPhotoFiles(MonthlyReportDto report)
    {
        var allPaths = report.Equipment
            .SelectMany(e => e.PhotoPaths)
            .Distinct()
            .ToList();

        if (allPaths.Count == 0) return null;

        var result = new Dictionary<string, byte[]>();
        foreach (var path in allPaths)
        {
            var bytes = await PhotoStorage.ReadPhotoAsync(path);
            if (bytes is not null)
                result[path] = bytes;
        }
        return result.Count > 0 ? result : null;
    }

    private ValueTask ScrollTo(string id) =>
        JS.InvokeVoidAsync("eval",
            $"document.getElementById('{id}')?.scrollIntoView({{behavior:'smooth',block:'start'}})");

    // ── Badge / colour helpers ────────────────────────────────────────────────

    private static string GetComplianceClass(int pct) =>
        pct >= 90 ? "success" : pct >= 70 ? "warning" : "danger";

    private static string GetRoundStatusClass(string s) => s switch
    {
        "Completed" or "Reviewed"   => "pass",
        "CompletedWithIssues"       => "warn",
        "InProgress"                => "inprogress",
        _                           => "draft"
    };

    private static string GetPriorityClass(string p) => p switch
    {
        "Critical" => "critical",
        "High"     => "high",
        "Medium"   => "medium",
        _          => "low"
    };

    private static string GetIssueStatusClass(string s) => s switch
    {
        "Open"       => "open",
        "InProgress" => "inprogress",
        "Resolved"   => "pass",
        "Closed"     => "closed",
        _            => ""
    };

    private static string GetServiceStatusClass(string s) => s switch
    {
        "Sent" or "InService" => "warn",
        "Returned"            => "pass",
        "Cancelled"           => "closed",
        _                     => ""
    };

    private static string GetNotePriorityClass(string p) => p switch
    {
        "Urgent"    => "critical",
        "Important" => "high",
        _           => "low"
    };

    private static string FormatStatus(string s) => s switch
    {
        "CompletedWithIssues" => "Issues Found",
        "InProgress"          => "In Progress",
        "InService"           => "In Service",
        _                     => s
    };
}
