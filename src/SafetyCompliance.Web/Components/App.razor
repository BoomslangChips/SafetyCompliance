<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#40A8A0" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="mobile-web-app-capable" content="yes" />
    <title>MIS — Majesty Oil Mills Inspection System</title>
    <base href="/" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" href="/icons/icon-192.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/icons/icon-192.svg" />
    <script>
        (function() {
            var theme = localStorage.getItem('safecheck-theme') || 'light';
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://site-assets.fontawesome.com/releases/v6.7.2/css/all.css" />
    <link rel="stylesheet" href="https://site-assets.fontawesome.com/releases/v6.7.2/css/sharp-thin.css" />
    <link rel="stylesheet" href="https://site-assets.fontawesome.com/releases/v6.7.2/css/sharp-solid.css" />
    <link rel="stylesheet" href="https://site-assets.fontawesome.com/releases/v6.7.2/css/sharp-regular.css" />
    <link rel="stylesheet" href="https://site-assets.fontawesome.com/releases/v6.7.2/css/sharp-light.css" />
    <link rel="stylesheet" href="_content/SafetyCompliance.Shared.UI/css/app.css" />
    <HeadOutlet @rendermode="Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer" />
</head>
<body>
    <Routes @rendermode="Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer" />
    <script>
        function toggleTheme() {
            var current = document.documentElement.getAttribute('data-theme');
            var next = current === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('safecheck-theme', next);
            return next;
        }
        function getTheme() {
            return document.documentElement.getAttribute('data-theme') || 'light';
        }
        function getSidebarCollapsed() {
            return localStorage.getItem('safecheck-sidebar-collapsed') === 'true';
        }
        function setSidebarCollapsed(val) {
            localStorage.setItem('safecheck-sidebar-collapsed', val ? 'true' : 'false');
        }
        function downloadExcel(filename, base64) {
            var a = document.createElement('a');
            a.href = 'data:application/vnd.openxmlformats-officedocument.spreadsheetml.sheet;base64,' + base64;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
        }
        function clickPhotoInput(id) {
            var el = document.getElementById(id);
            if (el) { el.value = ''; el.click(); }
        }
        function downloadFile(filename, base64, contentType) {
            var a = document.createElement('a');
            a.href = 'data:' + contentType + ';base64,' + base64;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
        }
    </script>
    <script src="_content/SafetyCompliance.Shared.UI/js/app-utils.js"></script>
    <script src="_framework/blazor.web.js"></script>
    <script>
        // Register service worker for PWA + offline
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/service-worker.js')
                .then(function() { console.log('[SW] Registered'); })
                .catch(function(e) { console.log('[SW] Registration failed', e); });
        }
    </script>
</body>
</html>
